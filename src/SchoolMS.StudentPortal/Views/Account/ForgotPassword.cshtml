@{
    Layout = null;
    var slug = ViewBag.SchoolSlug as string;
    var error = ViewBag.Error as string;
    var success = ViewBag.Success as string;
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name == "ar";
}
<!DOCTYPE html>
<html lang="@(isRtl ? "ar" : "en")" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(isRtl ? "نسيت كلمة المرور" : "Forgot Password") - SchoolMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/portal.css" asp-append-version="true" />
</head>
<body class="sp-body">
    <div class="sp-auth-page">
        <div class="sp-auth-bg">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>
        </div>

        <div class="sp-auth-card" style="max-width:440px;">
            <div class="sp-auth-header">
                <div class="sp-auth-icon">
                    <i class="fas fa-key"></i>
                </div>
                <h2 class="gradient-text">@(isRtl ? "نسيت كلمة المرور؟" : "Forgot Password?")</h2>
                <p>
                    @(isRtl
                        ? "أدخل رقم هاتفك المسجّل وسنرسل لك رمز لإعادة تعيين كلمة المرور"
                        : "Enter your registered phone number and we'll send you a code to reset your password")
                </p>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="login-error">
                    <i class="fas fa-exclamation-circle"></i> @error
                </div>
            }

            @if (!string.IsNullOrEmpty(success))
            {
                <div class="sp-auth-success">
                    <i class="fas fa-check-circle"></i> @success
                </div>
            }

            <form method="post" class="sp-auth-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="slug" value="@slug" />

                <div class="form-group">
                    <label>
                        <i class="fas fa-phone"></i>
                        @(isRtl ? "رقم الهاتف" : "Phone Number")
                    </label>
                    <input type="tel" name="phone" class="form-input"
                           placeholder="@(isRtl ? "أدخل رقم هاتفك المسجّل" : "Enter your registered phone number")" required autofocus />
                </div>

                <button type="submit" class="sp-auth-btn">
                    <i class="fas fa-paper-plane"></i>
                    @(isRtl ? "إرسال رمز التحقق" : "Send Verification Code")
                </button>
            </form>

            <div class="sp-auth-divider">@(isRtl ? "أو" : "or")</div>

            <div class="sp-auth-links">
                @(isRtl ? "تذكّرت كلمة المرور؟" : "Remember your password?")
                <a asp-controller="Account" asp-action="Login" asp-route-slug="@slug">
                    @(isRtl ? "سجّل الدخول" : "Sign In")
                </a>
            </div>

            <div style="text-align:center;margin-top:12px;">
                <div class="sp-auth-links">
                    @(isRtl ? "ليس لديك حساب؟" : "Don't have an account?")
                    <a asp-controller="Account" asp-action="Register" asp-route-slug="@slug">
                        @(isRtl ? "إنشاء حساب" : "Create Account")
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/portal.js" asp-append-version="true"></script>
</body>
</html>
