@{
    Layout = null;
    var slug = ViewBag.SchoolSlug as string;
    var error = ViewBag.Error as string;
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name == "ar";
}
<!DOCTYPE html>
<html lang="@(isRtl ? "ar" : "en")" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(isRtl ? "إنشاء حساب" : "Register") - SchoolMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/portal.css" asp-append-version="true" />
</head>
<body class="sp-body">
    <div class="sp-auth-page">
        <div class="sp-auth-bg">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>
        </div>

        <div class="sp-auth-card">
            <div class="sp-auth-header">
                <div class="sp-auth-icon">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h2 class="gradient-text">@(isRtl ? "إنشاء حساب جديد" : "Create Account")</h2>
                <p>@(isRtl ? "أنشئ حسابك وابدأ رحلتك التعليمية" : "Create your account and start your learning journey")</p>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="login-error">
                    <i class="fas fa-exclamation-circle"></i> @error
                </div>
            }

            <form method="post" class="sp-auth-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="slug" value="@slug" />

                <div class="form-row">
                    <div class="form-group">
                        <label>
                            <i class="fas fa-user"></i>
                            @(isRtl ? "الاسم الأول" : "First Name")
                        </label>
                        <input type="text" name="firstName" class="form-input"
                               placeholder="@(isRtl ? "أدخل الاسم الأول" : "First name")" required />
                    </div>
                    <div class="form-group">
                        <label>
                            <i class="fas fa-user"></i>
                            @(isRtl ? "الاسم الأخير" : "Last Name")
                        </label>
                        <input type="text" name="lastName" class="form-input"
                               placeholder="@(isRtl ? "أدخل الاسم الأخير" : "Last name")" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>
                        <i class="fas fa-at"></i>
                        @(isRtl ? "اسم المستخدم" : "Username")
                    </label>
                    <input type="text" name="username" class="form-input"
                           placeholder="@(isRtl ? "اختر اسم مستخدم" : "Choose a username")" required />
                </div>

                <div class="form-group">
                    <label>
                        <i class="fas fa-envelope"></i>
                        @(isRtl ? "البريد الإلكتروني" : "Email")
                    </label>
                    <input type="email" name="email" class="form-input"
                           placeholder="@(isRtl ? "أدخل بريدك الإلكتروني" : "Enter your email")" required />
                </div>

                <div class="form-group">
                    <label>
                        <i class="fas fa-phone"></i>
                        @(isRtl ? "رقم الهاتف" : "Phone Number")
                    </label>
                    <input type="tel" name="phone" class="form-input"
                           placeholder="@(isRtl ? "أدخل رقم الهاتف" : "Enter phone number")" required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>
                            <i class="fas fa-lock"></i>
                            @(isRtl ? "كلمة المرور" : "Password")
                        </label>
                        <input type="password" name="password" class="form-input"
                               placeholder="@(isRtl ? "كلمة المرور" : "Password")" required minlength="6" />
                    </div>
                    <div class="form-group">
                        <label>
                            <i class="fas fa-lock"></i>
                            @(isRtl ? "تأكيد كلمة المرور" : "Confirm Password")
                        </label>
                        <input type="password" name="confirmPassword" class="form-input"
                               placeholder="@(isRtl ? "أعد كلمة المرور" : "Confirm password")" required minlength="6" />
                    </div>
                </div>

                <button type="submit" class="sp-auth-btn" style="margin-top:8px;">
                    <i class="fas fa-user-plus"></i>
                    @(isRtl ? "إنشاء الحساب" : "Create Account")
                </button>
            </form>

            <div class="sp-auth-divider">@(isRtl ? "أو" : "or")</div>

            <div class="sp-auth-links">
                @(isRtl ? "لديك حساب بالفعل؟" : "Already have an account?")
                <a asp-controller="Account" asp-action="Login" asp-route-slug="@slug">
                    @(isRtl ? "سجّل الدخول" : "Sign In")
                </a>
            </div>

            <div style="text-align:center;margin-top:16px;">
                <span style="font-size:0.78rem;color:var(--sp-text-muted);">
                    <i class="fas fa-shield-alt" style="margin-inline-end:4px;"></i>
                    @(isRtl ? "سيتم إرسال رمز تأكيد إلى بريدك الإلكتروني" : "A verification code will be sent to your email")
                </span>
            </div>
        </div>
    </div>

    <script src="~/js/portal.js" asp-append-version="true"></script>
</body>
</html>
