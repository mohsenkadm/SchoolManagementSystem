@model Student
@{
    ViewData["Title"] = System.Globalization.CultureInfo.CurrentUICulture.Name == "ar" ? "ملفي الشخصي" : "My Profile";
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name == "ar";
    var subCount = (int)(ViewBag.SubCount ?? 0);
    var seenCount = (int)(ViewBag.SeenCount ?? 0);
}

<div class="sp-page-header">
    <h1 class="sp-page-title"><i class="fas fa-user-circle" style="color:var(--sp-primary);"></i> @ViewData["Title"]</h1>
</div>

<div class="sp-profile-header">
    <div class="sp-profile-avatar">
        @if (!string.IsNullOrEmpty(Model.ProfileImage))
        {
            <img src="@Model.ProfileImage" alt="@Model.FullName" />
        }
        else
        {
            @(Model.FullName.Length > 0 ? Model.FullName[0].ToString() : "?")
        }
    </div>
    <div>
        <div class="sp-profile-name">@Model.FullName</div>
        @if (!string.IsNullOrEmpty(Model.FullNameAr))
        {
            <div class="sp-profile-detail">@Model.FullNameAr</div>
        }
        <div class="sp-profile-detail"><i class="fas fa-building"></i> @Model.Branch?.Name</div>
        <div class="sp-profile-detail"><i class="fas fa-school"></i> @Model.ClassRoom?.Grade?.GradeName - @Model.ClassRoom?.Division?.DivisionName</div>
        <div class="sp-profile-detail"><i class="fas fa-calendar-alt"></i> @Model.AcademicYear?.YearName</div>
    </div>
</div>

<div class="sp-profile-stats">
    <div class="sp-stat-card">
        <div class="sp-stat-num">@subCount</div>
        <div class="sp-stat-label">@(isRtl ? "اشتراك فعّال" : "Active Subscriptions")</div>
    </div>
    <div class="sp-stat-card">
        <div class="sp-stat-num">@seenCount</div>
        <div class="sp-stat-label">@(isRtl ? "فيديو تمت مشاهدته" : "Videos Watched")</div>
    </div>
</div>

<div style="margin-top:28px;">
    <div style="background:var(--sp-bg-card);border:1px solid var(--sp-border);border-radius:var(--sp-radius);padding:24px;">
        <h3 style="font-weight:700;font-size:1rem;margin-bottom:20px;">
            <i class="fas fa-info-circle" style="color:var(--sp-primary);margin-inline-end:8px;"></i>
            @(isRtl ? "المعلومات الشخصية" : "Personal Information")
        </h3>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:16px;">
            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <div>
                    <div style="font-size:0.78rem;color:var(--sp-text-muted);margin-bottom:2px;">@(isRtl ? "البريد الإلكتروني" : "Email")</div>
                    <div style="font-weight:600;">@Model.Email</div>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Phone))
            {
                <div>
                    <div style="font-size:0.78rem;color:var(--sp-text-muted);margin-bottom:2px;">@(isRtl ? "الهاتف" : "Phone")</div>
                    <div style="font-weight:600;">@Model.Phone</div>
                </div>
            }
            <div>
                <div style="font-size:0.78rem;color:var(--sp-text-muted);margin-bottom:2px;">@(isRtl ? "تاريخ الميلاد" : "Date of Birth")</div>
                <div style="font-weight:600;">@Model.DateOfBirth.ToString("yyyy/MM/dd")</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Gender))
            {
                <div>
                    <div style="font-size:0.78rem;color:var(--sp-text-muted);margin-bottom:2px;">@(isRtl ? "الجنس" : "Gender")</div>
                    <div style="font-weight:600;">@Model.Gender</div>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Username))
            {
                <div>
                    <div style="font-size:0.78rem;color:var(--sp-text-muted);margin-bottom:2px;">@(isRtl ? "اسم المستخدم" : "Username")</div>
                    <div style="font-weight:600;">@Model.Username</div>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Address))
            {
                <div>
                    <div style="font-size:0.78rem;color:var(--sp-text-muted);margin-bottom:2px;">@(isRtl ? "العنوان" : "Address")</div>
                    <div style="font-weight:600;">@Model.Address</div>
                </div>
            }
        </div>
    </div>
</div>
