@inject Microsoft.Extensions.Options.IOptions<SchoolMS.Application.Settings.OneSignalSettings> OneSignalOpts
@{
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name == "ar";
    var dir = isRtl ? "rtl" : "ltr";
    var lang = isRtl ? "ar" : "en";
    var studentName = Context.Session.GetString("StudentName") ?? "";
    var initial = !string.IsNullOrEmpty(studentName) ? studentName[0].ToString() : "?";
    var isLoggedIn = Context.Session.GetInt32("StudentId") != null;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var notifs = ViewBag.LayoutNotifications as List<Notification>;
    var oneSignalAppId = OneSignalOpts.Value.AppId;
    var studentId = Context.Session.GetInt32("StudentId");
    var schoolId = Context.Session.GetInt32("SchoolId");
    var branchId = Context.Session.GetInt32("BranchId");
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap@(isRtl ? ".rtl" : "").min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/portal.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="sp-body">
    @if (isLoggedIn)
    {
        <!-- Sidebar -->
        <aside class="sp-sidebar" id="sidebar">
            <div class="sp-sidebar-header">
                <i class="fas fa-graduation-cap" style="font-size:1.4rem;color:var(--sp-primary);"></i>
                <span class="sp-sidebar-brand gradient-text">SchoolMS</span>
            </div>
            <nav class="sp-sidebar-nav">
                <a asp-controller="Home" asp-action="Index" class="sp-nav-item @(currentController == "Home" ? "active" : "")">
                    <i class="fas fa-home"></i> <span>@(isRtl ? "الرئيسية" : "Home")</span>
                </a>
                <a asp-controller="Courses" asp-action="Index" class="sp-nav-item @(currentController == "Courses" && currentAction == "Index" ? "active" : "")">
                    <i class="fas fa-play-circle"></i> <span>@(isRtl ? "الكورسات" : "Courses")</span>
                </a>
                <a asp-controller="Teachers" asp-action="Index" class="sp-nav-item @(currentController == "Teachers" ? "active" : "")">
                    <i class="fas fa-chalkboard-teacher"></i> <span>@(isRtl ? "المعلمين" : "Teachers")</span>
                </a>
                <a asp-controller="Subscriptions" asp-action="Index" class="sp-nav-item @(currentController == "Subscriptions" && currentAction == "Index" ? "active" : "")">
                    <i class="fas fa-bookmark"></i> <span>@(isRtl ? "اشتراكاتي" : "My Subscriptions")</span>
                </a>
                <a asp-controller="Subscriptions" asp-action="Plans" class="sp-nav-item @(currentController == "Subscriptions" && currentAction == "Plans" ? "active" : "")">
                    <i class="fas fa-tags"></i> <span>@(isRtl ? "خطط الاشتراك" : "Plans")</span>
                </a>
                <div class="sp-nav-divider"></div>
                <a asp-controller="LiveStream" asp-action="Index" class="sp-nav-item @(currentController == "LiveStream" ? "active" : "")">
                    <i class="fas fa-broadcast-tower"></i> <span>@(isRtl ? "البث المباشر" : "Live Streams")</span>
                </a>
                <a asp-controller="Notifications" asp-action="Index" class="sp-nav-item @(currentController == "Notifications" ? "active" : "")">
                    <i class="fas fa-bell"></i> <span>@(isRtl ? "الإشعارات" : "Notifications")</span>
                </a>
                <div class="sp-nav-divider"></div>
                <a asp-controller="Profile" asp-action="Index" class="sp-nav-item @(currentController == "Profile" ? "active" : "")">
                    <i class="fas fa-user-circle"></i> <span>@(isRtl ? "ملفي الشخصي" : "Profile")</span>
                </a>
                <a asp-controller="Home" asp-action="DownloadApp" class="sp-nav-item @(currentController == "Home" && currentAction == "DownloadApp" ? "active" : "")">
                    <i class="fas fa-mobile-alt"></i> <span>@(isRtl ? "تحميل التطبيق" : "Download App")</span>
                </a>
            </nav>
            <div class="sp-sidebar-footer">
                <div class="sp-avatar">@initial</div>
                <div class="sp-user-info">
                    <div class="name">@studentName</div>
                    <div class="role">@(isRtl ? "طالب" : "Student")</div>
                </div>
            </div>
        </aside>
        <div class="sp-sidebar-overlay" id="sidebarOverlay"></div>

        <!-- Main Content -->
        <div class="sp-main">
            <header class="sp-topbar">
                <div style="display:flex;align-items:center;gap:12px;">
                    <button class="sp-topbar-btn sp-menu-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">
                        <i class="fas fa-bars"></i>
                    </button>
                    <h1 class="sp-page-title" style="margin:0;font-size:1.1rem;">@ViewData["Title"]</h1>
                </div>
                <div class="sp-topbar-actions">
                    <!-- Language -->
                    <form asp-controller="Language" asp-action="Set" method="post" style="margin:0;">
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                        @if (isRtl)
                        {
                            <button type="submit" name="culture" value="en" class="sp-lang-btn">
                                <i class="fas fa-globe"></i> EN
                            </button>
                        }
                        else
                        {
                            <button type="submit" name="culture" value="ar" class="sp-lang-btn">
                                <i class="fas fa-globe"></i> عربي
                            </button>
                        }
                    </form>
                    <!-- Theme -->
                    <button class="sp-topbar-btn" id="themeToggle" title="@(isRtl ? "تبديل المظهر" : "Toggle theme")">
                        <i class="fas fa-sun"></i>
                    </button>
                    <!-- Notifications -->
                    <div style="position:relative;">
                        <button class="sp-topbar-btn" id="notifDropdownBtn">
                            <i class="fas fa-bell"></i>
                            <span class="badge-dot"></span>
                        </button>
                        <div id="notifDropdownPanel" style="position:absolute;left:0;top:48px;width:340px;background:var(--sp-bg-card);border:1px solid var(--sp-border);border-radius:var(--sp-radius);box-shadow:var(--sp-shadow-lg);display:none;z-index:200;max-height:400px;overflow-y:auto;">
                            <div style="padding:14px 18px;border-bottom:1px solid var(--sp-border);font-weight:700;font-size:0.92rem;">
                                @(isRtl ? "الإشعارات" : "Notifications")
                            </div>
                            <div style="padding:8px;" id="notifDropdownList">
                                <div style="text-align:center;padding:20px;color:var(--sp-text-muted);font-size:0.85rem;">
                                    <i class="fas fa-bell" style="font-size:1.5rem;opacity:0.3;display:block;margin-bottom:8px;"></i>
                                    @(isRtl ? "لا توجد إشعارات جديدة" : "No new notifications")
                                </div>
                            </div>
                            <a asp-controller="Notifications" asp-action="Index" style="display:block;text-align:center;padding:10px;border-top:1px solid var(--sp-border);font-size:0.82rem;font-weight:600;color:var(--sp-primary);">
                                @(isRtl ? "عرض الكل" : "View All")
                            </a>
                        </div>
                    </div>
                    <!-- Logout -->
                    <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0;">
                        <button type="submit" class="sp-topbar-btn" title="@(isRtl ? "تسجيل الخروج" : "Logout")">
                            <i class="fas fa-sign-out-alt"></i>
                        </button>
                    </form>
                </div>
            </header>
            <main class="sp-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/portal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (isLoggedIn && !string.IsNullOrWhiteSpace(oneSignalAppId) && oneSignalAppId != "YOUR_ONESIGNAL_APP_ID")
    {
        <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
        <script>
            window.OneSignalDeferred = window.OneSignalDeferred || [];
            OneSignalDeferred.push(async function(OneSignal) {
                await OneSignal.init({
                    appId: "@oneSignalAppId",
                    allowLocalhostAsSecureOrigin: true,
                    notifyButton: { enable: true }
                });

                // Set tags so notifications from the Web project target this student
                await OneSignal.User.addTags({
                    "schoolId": "@schoolId",
                    "personId": "@studentId",
                    "personType": "Student",
                    @if (branchId.HasValue)
                    {
                        @: "branchId": "@branchId",
                    }
                });

                // Set external ID for individual targeting
                await OneSignal.login("student-@(studentId)-school-@(schoolId)");
            });
        </script>
    }

    <style>
        #notifDropdownPanel.show { display: block !important; animation: fadeIn 0.2s ease; }
    </style>
</body>
</html>
