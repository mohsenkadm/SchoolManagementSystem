@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (AcademicYearDto)Model : null;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditAcademicYear"] : Localizer["AddAcademicYear"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-6">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select name="SchoolId" class="form-select select2" required>
                        <option value="">-- @Localizer["Select"] --</option>
                        @foreach (var s in schools) { <option value="@s.Id" selected="@(item?.SchoolId == s.Id)">@s.Name</option> }
                    </select>
                </div>
            }
            <div class="col-md-6"><label class="form-label">@Localizer["YearName"] *</label><input type="text" name="YearName" class="form-control" value="@item?.YearName" required /></div>
            <div class="col-md-6"><label class="form-label">@Localizer["StartDate"] *</label><input type="date" name="StartDate" class="form-control" value="@item?.StartDate.ToString("yyyy-MM-dd")" required /></div>
            <div class="col-md-6"><label class="form-label">@Localizer["EndDate"] *</label><input type="date" name="EndDate" class="form-control" value="@item?.EndDate.ToString("yyyy-MM-dd")" required /></div>
            <div class="col-md-6">
                <div class="form-check mt-4">
                    <input type="checkbox" name="IsCurrent" value="true" class="form-check-input" id="isCurrent" @(item?.IsCurrent == true ? "checked" : "") />
                    <label class="form-check-label" for="isCurrent">@Localizer["Current"]</label>
                </div>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
