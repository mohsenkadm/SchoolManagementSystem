@{
    ViewData["Title"] = Localizer["AccessDenied"].Value;
}
<div class="text-center py-5" data-aos="fade-up">
    <div style="font-size:4rem;margin-bottom:16px;">🚫</div>
    <h2 style="font-weight:800;">@Localizer["AccessDenied"]</h2>
    <p class="text-muted mb-4">@Localizer["AccessDeniedMsg"]</p>
    <a href="@Url.Action("Index", "Home")" class="btn btn-gradient mt-3">
        <i class="fas fa-home me-2"></i>@Localizer["GoToDashboard"]
    </a>
</div>
