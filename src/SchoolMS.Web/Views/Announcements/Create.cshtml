@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (AnnouncementDto)Model : null;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditAnnouncement"] : Localizer["AddAnnouncement"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-4">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select id="schoolSelect" name="SchoolId" class="form-select select2" required>
                        <option value="">-- @Localizer["Select"] --</option>
                        @foreach (var s in schools) { <option value="@s.Id" selected="@(item?.SchoolId == s.Id)">@s.Name</option> }
                    </select>
                </div>
            }
            <div class="col-md-6"><label class="form-label">@Localizer["Title"] *</label><input type="text" name="Title" class="form-control" value="@item?.Title" required /></div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Priority"]</label>
                <select name="Priority" class="form-select">
                    @foreach (var p in Enum.GetValues<AnnouncementPriority>()) { <option value="@p" selected="@(item?.Priority == p)">@p</option> }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Target"]</label>
                <select name="Target" class="form-select">
                    @foreach (var t in Enum.GetValues<AnnouncementTarget>()) { <option value="@t" selected="@(item?.Target == t)">@t</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Branch"]</label>
                <select id="branchSelect" name="BranchId" class="form-select select2">
                    <option value="">@Localizer["All"]</option>
                    @foreach (var b in branches) { <option value="@b.Id" selected="@(item?.BranchId == b.Id)">@b.Name</option> }
                </select>
            </div>
            <div class="col-md-4"><label class="form-label">@Localizer["ExpiryDate"]</label><input type="date" name="ExpiryDate" class="form-control" value="@item?.ExpiryDate?.ToString("yyyy-MM-dd")" /></div>
            <div class="col-md-4"><div class="form-check form-switch mt-4"><input class="form-check-input" type="checkbox" name="IsPinned" value="true" @(item?.IsPinned == true ? "checked" : "") /><label class="form-check-label">@Localizer["Pinned"]</label></div></div>
            <div class="col-12"><label class="form-label">@Localizer["Content"]</label><textarea name="Content" class="form-control" rows="4">@item?.Content</textarea></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
@if (isSuperAdmin)
{
    @section Scripts {
    <script>
        $(function () {
            $('#schoolSelect').on('change', function () {
                var schoolId = $(this).val();
                var $branch = $('#branchSelect');
                $branch.html('<option value="">@Localizer["All"]</option>');
                if (schoolId) {
                    $.getJSON('@Url.Action("GetBranchesBySchool")', { schoolId: schoolId }, function (data) {
                        $.each(data, function (_, b) { $branch.append('<option value="' + b.id + '">' + b.name + '</option>'); });
                    });
                }
            });
        });
    </script>
    }
}
