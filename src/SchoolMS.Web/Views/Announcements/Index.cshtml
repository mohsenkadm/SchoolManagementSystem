@using SchoolMS.Application.DTOs
@model List<AnnouncementDto>
@{
    ViewData["Title"] = Localizer["Announcements"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-bullhorn text-primary"></i>@Localizer["Announcements"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddAnnouncement"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-bullhorn"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-thumbtack"></i></div><div class="stat-info"><h6>@Localizer["Pinned"]</h6><div class="stat-value">@Model.Count(a => a.IsPinned)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-eye"></i></div><div class="stat-info"><h6>@Localizer["Views"]</h6><div class="stat-value">@Model.Sum(a => a.ViewCount)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterBranch" class="form-select">
                <option value="">@Localizer["AllBranches"]</option>
                @foreach (var b in branches) { <option value="@b.Name">@b.Name</option> }
            </select>
        </div>
        <div class="col-md-3"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2"><select id="filterPriority" class="form-select"><option value="">@Localizer["AllPriorities"]</option><option value="Urgent">Urgent</option><option value="Important">Important</option><option value="Normal">Normal</option></select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Title"]</th><th>@Localizer["Priority"]</th><th>@Localizer["Target"]</th><th>@Localizer["Pinned"]</th><th>@Localizer["Branch"]</th>@if (isSuperAdmin){<th>@Localizer["School"]</th>}<th>@Localizer["Date"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var pBadge = Model[i].Priority == AnnouncementPriority.Urgent ? "bg-danger" : Model[i].Priority == AnnouncementPriority.Important ? "bg-warning" : "bg-info";
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td>@Model[i].Title</td><td><span class="badge @pBadge">@Model[i].Priority</span></td><td>@Model[i].Target</td><td>@(Model[i].IsPinned ? "📌" : "")</td><td>@Model[i].BranchName</td>
                    @if (isSuperAdmin){<td>@Model[i].SchoolName</td>}
                    <td>@Model[i].CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>
                        <div class="action-group">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn-act btn-act-edit" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<script>
    var dt, isSA = @(isSuperAdmin ? "true" : "false");
    var schoolCol = isSA ? 6 : -1, branchCol = 5, prioCol = 2, dateCol = isSA ? 7 : 6;
    $(function () { dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip', order: [[dateCol, 'desc']] }); $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); }); });
    function applyFilters() { dt.search($('#searchInput').val()); if (isSA) dt.column(schoolCol).search($('#filterSchool').val()); dt.column(branchCol).search($('#filterBranch').val()); dt.column(prioCol).search($('#filterPriority').val()); dt.draw(); }
    function resetFilters() { $('#searchInput, #filterPriority, #filterBranch').val(''); if (isSA) $('#filterSchool').val(''); dt.search('').columns().search('').draw(); }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
