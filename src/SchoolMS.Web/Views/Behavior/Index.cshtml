@using SchoolMS.Application.DTOs
@model List<StudentBehaviorDto>
@{
    ViewData["Title"] = Localizer["Behavior"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
    var academicYears = ViewBag.AcademicYears as List<AcademicYearDto> ?? new();
    var selectedAcademicYearId = ViewBag.SelectedAcademicYearId as int?;
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-user-shield text-primary"></i>@Localizer["Behavior"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddRecord"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-thumbs-up"></i></div><div class="stat-info"><h6>@Localizer["Positive"]</h6><div class="stat-value">@Model.Count(b => b.Type == BehaviorType.Positive)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-thumbs-down"></i></div><div class="stat-info"><h6>@Localizer["Negative"]</h6><div class="stat-value">@Model.Count(b => b.Type == BehaviorType.Negative)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-star"></i></div><div class="stat-info"><h6>@Localizer["TotalPoints"]</h6><div class="stat-value">@Model.Sum(b => b.Points)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterAcademicYear" class="form-select">
                <option value="">@Localizer["All"]</option>
                @foreach (var y in academicYears)
                {
                    var isSelected = selectedAcademicYearId == y.Id || (!selectedAcademicYearId.HasValue && y.IsCurrent);
                    if (isSelected)
                    {
                        <option value="@y.Id" selected="selected">@y.YearName</option>
                    }
                    else
                    {
                        <option value="@y.Id">@y.YearName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["SearchStudent"]..." /></div>
        <div class="col-md-2"><select id="filterType" class="form-select"><option value="">@Localizer["AllTypes"]</option><option value="Positive">@Localizer["Positive"]</option><option value="Negative">@Localizer["Negative"]</option></select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Student"]</th><th>@Localizer["Type"]</th><th>@Localizer["Title"]</th><th>@Localizer["Points"]</th><th>@Localizer["Date"]</th><th>@Localizer["AcademicYear"]</th>@if (isSuperAdmin){<th>@Localizer["School"]</th>}<th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var typeBadge = Model[i].Type == BehaviorType.Positive ? "bg-success" : "bg-danger";
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td>@Model[i].StudentName</td><td><span class="badge @typeBadge">@Model[i].Type</span></td><td>@Model[i].Title</td><td>@Model[i].Points</td><td>@Model[i].IncidentDate.ToString("yyyy-MM-dd")</td><td>@(Model[i].AcademicYearName ?? "—")</td>
                    @if (isSuperAdmin){<td>@Model[i].SchoolName</td>}
                    <td>
                        <div class="action-group">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn-act btn-act-edit" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<script>
    var dt, isSA = @(isSuperAdmin ? "true" : "false");
    var typeCol = 2, yearCol = 6, schoolCol = isSA ? 7 : -1;
    $(function () { dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip', order: [[5, 'desc']] }); $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); }); });
    $('#filterAcademicYear').on('change', function() {
        var yearId = $(this).val();
        window.location.href = '@Url.Action("Index")' + (yearId ? '?academicYearId=' + yearId : '');
    });
    function applyFilters() { dt.search($('#searchInput').val()); dt.column(typeCol).search($('#filterType').val()); if (isSA) dt.column(schoolCol).search($('#filterSchool').val()); dt.draw(); }
    function resetFilters() { $('#searchInput, #filterType').val(''); if (isSA) $('#filterSchool').val(''); dt.search('').columns().search('').draw(); }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
