@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (BranchDto)Model : null;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditBranch"] : Localizer["AddBranch"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-4">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select name="SchoolId" class="form-select select2" required>
                        <option value="">-- @Localizer["SelectSchool"] --</option>
                        @foreach (var s in schools)
                        {
                            var isSelected = item?.SchoolId == s.Id;
                            <option value="@s.Id" selected="@isSelected">@s.Name</option>
                        }
                    </select>
                </div>
            }
            <div class="col-md-4"><label class="form-label">@Localizer["Name"] *</label><input type="text" name="Name" class="form-control" value="@item?.Name" required /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Address"]</label><input type="text" name="Address" class="form-control" value="@item?.Address" /></div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Active"]</label>
                <div class="form-check form-switch mt-2"><input class="form-check-input" type="checkbox" name="IsActive" value="true" @(item?.IsActive != false ? "checked" : "") /></div>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
