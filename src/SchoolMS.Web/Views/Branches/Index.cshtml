@model List<SchoolMS.Application.DTOs.BranchDto>
@using SchoolMS.Application.DTOs
@{
    ViewData["Title"] = Localizer["Branches"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-building text-primary"></i>@Localizer["Branches"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddBranch"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-primary-soft"><i class="fas fa-building"></i></div>
        <div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div>
    </div>
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-success-soft"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info"><h6>@Localizer["Active"]</h6><div class="stat-value">@Model.Count(b => b.IsActive)</div></div>
    </div>
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-danger-soft"><i class="fas fa-times-circle"></i></div>
        <div class="stat-info"><h6>@Localizer["Inactive"]</h6><div class="stat-value">@Model.Count(b => !b.IsActive)</div></div>
    </div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        <div class="@(isSuperAdmin ? "col-md-3" : "col-md-5")">
            <input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." />
        </div>
        @if (isSuperAdmin)
        {
            <div class="col-md-3">
                <select id="filterSchool" class="form-select">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools)
                    {
                        <option value="@s.Name">@s.Name</option>
                    }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterStatus" class="form-select">
                <option value="">@Localizer["AllStatuses"]</option>
                <option value="✅">@Localizer["Active"]</option>
                <option value="❌">@Localizer["Inactive"]</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i> @Localizer["Filter"]</button>
        </div>
        <div class="col-md-2">
            <button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i> @Localizer["Reset"]</button>
        </div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["Name"]</th>
                <th>@Localizer["Address"]</th>
                @if (isSuperAdmin)
                {
                    <th>@Localizer["School"]</th>
                }
                <th>@Localizer["Active"]</th>
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td>@Model[i].Name</td>
                    <td>@Model[i].Address</td>
                    @if (isSuperAdmin)
                    {
                        <td>@Model[i].SchoolName</td>
                    }
                    <td>
                        @if (Model[i].IsActive) { <span class="status-badge status-active"><span class="status-dot"></span> @Localizer["Active"]</span> }
                        else { <span class="badge bg-secondary">@Localizer["Inactive"]</span> }
                    </td>
                    <td>
                        <div class="action-group">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn-act btn-act-edit" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<script>
    var dt;
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var schoolColIndex = isSuperAdmin ? 3 : -1;
    var statusColIndex = isSuperAdmin ? 4 : 3;

    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
    });
    function applyFilters() {
        dt.search($('#searchInput').val()).draw();
        if (isSuperAdmin) {
            dt.column(schoolColIndex).search($('#filterSchool').val()).draw();
        }
        dt.column(statusColIndex).search($('#filterStatus').val()).draw();
    }
    function resetFilters() {
        $('#searchInput').val('');
        $('#filterStatus').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
