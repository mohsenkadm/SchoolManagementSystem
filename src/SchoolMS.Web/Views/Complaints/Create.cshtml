@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (ComplaintDto)Model : null;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditComplaint"] : Localizer["AddComplaint"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-6">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select name="SchoolId" class="form-select select2" required>
                        <option value="">-- @Localizer["Select"] --</option>
                        @foreach (var s in schools) { <option value="@s.Id" selected="@(item?.SchoolId == s.Id)">@s.Name</option> }
                    </select>
                </div>
            }
            <div class="col-md-6"><label class="form-label">@Localizer["Subject"] *</label><input type="text" name="Subject" class="form-control" value="@item?.Subject" required /></div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Category"]</label>
                <select name="Category" class="form-select">
                    @foreach (var c in Enum.GetValues<ComplaintCategory>()) { <option value="@c" selected="@(item?.Category == c)">@c</option> }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Priority"]</label>
                <select name="Priority" class="form-select">
                    @foreach (var p in Enum.GetValues<ComplaintPriority>()) { <option value="@p" selected="@(item?.Priority == p)">@p</option> }
                </select>
            </div>
            <div class="col-md-6"><label class="form-label">@Localizer["PersonName"]</label><input type="text" name="PersonName" class="form-control" value="@item?.PersonName" /></div>
            <div class="col-md-3"><div class="form-check form-switch mt-4"><input class="form-check-input" type="checkbox" name="IsAnonymous" value="true" @(item?.IsAnonymous == true ? "checked" : "") /><label class="form-check-label">@Localizer["Anonymous"]</label></div></div>
            <div class="col-12"><label class="form-label">@Localizer["Description"]</label><textarea name="Description" class="form-control" rows="3">@item?.Description</textarea></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
