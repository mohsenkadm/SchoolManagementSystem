@using SchoolMS.Application.DTOs
@model List<ComplaintDto>
@{
    ViewData["Title"] = Localizer["Complaints"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-exclamation-triangle text-primary"></i>@Localizer["Complaints"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddComplaint"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-inbox"></i></div><div class="stat-info"><h6>@Localizer["Open"]</h6><div class="stat-value">@Model.Count(c => c.Status == ComplaintStatus.Open)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-spinner"></i></div><div class="stat-info"><h6>@Localizer["InProgress"]</h6><div class="stat-value">@Model.Count(c => c.Status == ComplaintStatus.InProgress)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-circle"></i></div><div class="stat-info"><h6>@Localizer["Resolved"]</h6><div class="stat-value">@Model.Count(c => c.Status == ComplaintStatus.Resolved)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-3"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2"><select id="filterStatus" class="form-select"><option value="">@Localizer["AllStatuses"]</option><option value="Open">Open</option><option value="InProgress">InProgress</option><option value="Resolved">Resolved</option></select></div>
        <div class="col-md-2"><select id="filterCategory" class="form-select"><option value="">@Localizer["AllCategories"]</option>@foreach (var c in Model.Select(x => x.Category.ToString()).Distinct()) { <option value="@c">@c</option> }</select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Ticket"]</th><th>@Localizer["Subject"]</th><th>@Localizer["Category"]</th><th>@Localizer["Priority"]</th><th>@Localizer["Status"]</th>@if (isSuperAdmin){<th>@Localizer["School"]</th>}<th>@Localizer["Date"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var sBadge = Model[i].Status == ComplaintStatus.Resolved ? "bg-success" : Model[i].Status == ComplaintStatus.InProgress ? "bg-warning" : "bg-info";
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td><code>@Model[i].TicketNumber</code></td><td>@Model[i].Subject</td><td>@Model[i].Category</td><td>@Model[i].Priority</td><td><span class="badge @sBadge">@Model[i].Status</span></td>
                    @if (isSuperAdmin){<td>@Model[i].SchoolName</td>}
                    <td>@Model[i].CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<script>
    var dt, isSA = @(isSuperAdmin ? "true" : "false");
    var statusCol = 5, catCol = 3, schoolCol = isSA ? 6 : -1, dateCol = isSA ? 7 : 6;
    $(function () { dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip', order: [[dateCol, 'desc']] }); $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); }); });
    function applyFilters() { dt.search($('#searchInput').val()); dt.column(statusCol).search($('#filterStatus').val()); dt.column(catCol).search($('#filterCategory').val()); if (isSA) dt.column(schoolCol).search($('#filterSchool').val()); dt.draw(); }
    function resetFilters() { $('#searchInput, #filterStatus, #filterCategory').val(''); if (isSA) $('#filterSchool').val(''); dt.search('').columns().search('').draw(); }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
