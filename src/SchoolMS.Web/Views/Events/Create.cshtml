@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (SchoolEventDto)Model : null;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditEvent"] : Localizer["AddEvent"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-3">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select id="schoolSelect" name="SchoolId" class="form-select select2" required>
                        <option value="">-- @Localizer["Select"] --</option>
                        @foreach (var s in schools) { <option value="@s.Id" selected="@(item?.SchoolId == s.Id)">@s.Name</option> }
                    </select>
                </div>
            }
            <div class="col-md-6"><label class="form-label">@Localizer["Title"] *</label><input type="text" name="Title" class="form-control" value="@item?.Title" required /></div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Category"]</label>
                <select name="EventCategory" class="form-select">
                    @foreach (var e in Enum.GetValues<EventType>()) { <option value="@e" selected="@(item?.EventCategory == e)">@e</option> }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Branch"]</label>
                <select id="branchSelect" name="BranchId" class="form-select select2">
                    <option value="">@Localizer["All"]</option>
                    @foreach (var b in branches) { <option value="@b.Id" selected="@(item?.BranchId == b.Id)">@b.Name</option> }
                </select>
            </div>
            <div class="col-md-3"><label class="form-label">@Localizer["StartDate"] *</label><input type="datetime-local" name="StartDate" class="form-control" value="@item?.StartDate.ToString("yyyy-MM-ddTHH:mm")" required /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["EndDate"] *</label><input type="datetime-local" name="EndDate" class="form-control" value="@item?.EndDate.ToString("yyyy-MM-ddTHH:mm")" required /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Location"]</label><input type="text" name="Location" class="form-control" value="@item?.Location" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Color"]</label><input type="color" name="Color" class="form-control form-control-color" value="@(item?.Color ?? "#3498db")" /></div>
            <div class="col-12"><label class="form-label">@Localizer["Description"]</label><textarea name="Description" class="form-control" rows="3">@item?.Description</textarea></div>
            <div class="col-md-3"><div class="form-check form-switch mt-4"><input class="form-check-input" type="checkbox" name="IsAllDay" value="true" @(item?.IsAllDay == true ? "checked" : "") /><label class="form-check-label">@Localizer["AllDay"]</label></div></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
@if (isSuperAdmin)
{
    @section Scripts {
    <script>
        $(function () {
            $('#schoolSelect').on('change', function () {
                var schoolId = $(this).val();
                var $branch = $('#branchSelect');
                $branch.html('<option value="">@Localizer["All"]</option>');
                if (schoolId) {
                    $.getJSON('@Url.Action("GetBranchesBySchool")', { schoolId: schoolId }, function (data) {
                        $.each(data, function (_, b) { $branch.append('<option value="' + b.id + '">' + b.name + '</option>'); });
                    });
                }
            });
        });
    </script>
    }
}
