@using SchoolMS.Application.DTOs
@model List<SchoolEventDto>
@{
    ViewData["Title"] = Localizer["Events"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-calendar-alt text-primary"></i>@Localizer["Events"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddEvent"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-calendar-alt"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-calendar-check"></i></div><div class="stat-info"><h6>@Localizer["Upcoming"]</h6><div class="stat-value">@Model.Count(e => e.StartDate.Date >= DateTime.Today)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-history"></i></div><div class="stat-info"><h6>@Localizer["Past"]</h6><div class="stat-value">@Model.Count(e => e.EndDate.Date < DateTime.Today)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterBranch" class="form-select">
                <option value="">@Localizer["AllBranches"]</option>
                @foreach (var b in branches) { <option value="@b.Name">@b.Name</option> }
            </select>
        </div>
        <div class="col-md-3"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2"><select id="filterCategory" class="form-select"><option value="">@Localizer["AllCategories"]</option>@foreach (var c in Model.Select(e => e.EventCategory.ToString()).Distinct().OrderBy(c => c)) { <option value="@c">@c</option> }</select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Title"]</th><th>@Localizer["StartDate"]</th><th>@Localizer["EndDate"]</th><th>@Localizer["Location"]</th><th>@Localizer["Category"]</th><th>@Localizer["Branch"]</th>@if (isSuperAdmin){<th>@Localizer["School"]</th>}<th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td>@Model[i].Title</td><td>@Model[i].StartDate.ToString("yyyy-MM-dd")</td><td>@Model[i].EndDate.ToString("yyyy-MM-dd")</td><td>@Model[i].Location</td><td><span class="badge bg-info">@Model[i].EventCategory</span></td><td>@Model[i].BranchName</td>
                    @if (isSuperAdmin){<td>@Model[i].SchoolName</td>}
                    <td>
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<script>
    var dt, isSA = @(isSuperAdmin ? "true" : "false");
    var schoolCol = isSA ? 7 : -1, branchCol = 6, catCol = 5;
    $(function () { dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip', order: [[2, 'desc']] }); $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); }); });
    function applyFilters() { dt.search($('#searchInput').val()); if (isSA) dt.column(schoolCol).search($('#filterSchool').val()); dt.column(branchCol).search($('#filterBranch').val()); dt.column(catCol).search($('#filterCategory').val()); dt.draw(); }
    function resetFilters() { $('#searchInput, #filterCategory, #filterBranch').val(''); if (isSA) $('#filterSchool').val(''); dt.search('').columns().search('').draw(); }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
