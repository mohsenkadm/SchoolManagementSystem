@using SchoolMS.Application.DTOs
@model List<ExpenseTypeDto>
@{ ViewData["Title"] = Localizer["ExpenseTypes"].Value; }
@Html.AntiForgeryToken()
@{
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-tags text-primary"></i>@Localizer["ExpenseTypes"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-primary" onclick="printSchedule()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
        <a href="@Url.Action("Index", "Expenses")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Expenses"]</a>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddExpenseType"]</a>
    </div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-3">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-4"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i> @Localizer["Filter"]</button></div>
        <div class="col-md-2"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i> @Localizer["Reset"]</button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up" id="printArea">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["TypeName"]</th><th>@Localizer["Description"]</th>@if (isSuperAdmin) { <th>@Localizer["School"]</th> }<th class="no-print">@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td>@Model[i].TypeName</td><td>@Model[i].Description</td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td class="no-print">
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<style media="print">
    .page-header, .filter-panel, .no-print, nav, .sidebar, footer { display: none !important; }
    .table-card { box-shadow: none !important; border: none !important; }
    table { font-size: 12px; }
    th, td { padding: 4px 8px !important; }
</style>
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var schoolColIdx = isSuperAdmin ? 3 : -1;
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
    });
    function applyFilters() { dt.search($('#searchInput').val()); if (isSuperAdmin) { dt.column(schoolColIdx).search($('#filterSchool').val()); } dt.draw(); }
    function resetFilters() { $('#searchInput').val(''); if (isSuperAdmin) { $('#filterSchool').val(''); } dt.search('').columns().search('').draw(); }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
    function printSchedule() { window.print(); }
</script>
}
