@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (ExpenseDto)Model : null;
    var types = ViewBag.ExpenseTypes as List<ExpenseTypeDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditExpense"] : Localizer["AddExpense"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-4">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select name="SchoolId" class="form-select select2" required>
                        <option value="">-- @Localizer["Select"] --</option>
                        @foreach (var s in schools) { <option value="@s.Id" selected="@(item?.SchoolId == s.Id)">@s.Name</option> }
                    </select>
                </div>
            }
            <div class="col-md-4">
                <label class="form-label">@Localizer["ExpenseType"] *</label>
                <select name="ExpenseTypeId" class="form-select" required>
                    <option value="">-- @Localizer["Select"] --</option>
                    @foreach (var t in types) { <option value="@t.Id" selected="@(item?.ExpenseTypeId == t.Id)">@t.TypeName</option> }
                </select>
            </div>
            <div class="col-md-4"><label class="form-label">@Localizer["Amount"] *</label><input type="number" step="0.01" name="Amount" class="form-control" value="@(item?.Amount ?? 0)" required /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Date"] *</label><input type="date" name="Date" class="form-control" value="@(item?.Date.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))" required /></div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Branch"] *</label>
                <select name="BranchId" class="form-select" required>
                    @foreach (var b in branches) { <option value="@b.Id" selected="@(item?.BranchId == b.Id)">@b.Name</option> }
                </select>
            </div>
            <div class="col-md-8"><label class="form-label">@Localizer["Description"]</label><textarea name="Description" class="form-control" rows="2">@item?.Description</textarea></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
