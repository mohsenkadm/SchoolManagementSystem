@using SchoolMS.Application.DTOs
@model List<ExpenseDto>
@{ ViewData["Title"] = Localizer["Expenses"].Value; }
@Html.AntiForgeryToken()
@{
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var byType = Model.GroupBy(e => e.ExpenseTypeName ?? "Other").Select(g => new { Name = g.Key, Total = g.Sum(e => e.Amount) }).OrderByDescending(x => x.Total).ToList();
}

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-receipt text-primary"></i>@Localizer["Expenses"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-primary" onclick="printSchedule()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
        <a href="@Url.Action("Index", "ExpenseTypes")" class="btn btn-info"><i class="fas fa-tags me-1"></i>@Localizer["ExpenseTypes"]</a>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddExpense"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-receipt"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-coins"></i></div><div class="stat-info"><h6>@Localizer["TotalAmount"]</h6><div class="stat-value">@Model.Sum(e => e.Amount).ToString("N0")</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-tags"></i></div><div class="stat-info"><h6>@Localizer["Types"]</h6><div class="stat-value">@Model.Select(e => e.ExpenseTypeName).Distinct().Count()</div></div></div>
</div>

<div class="row mb-4" data-aos="fade-up">
    <div class="col-lg-6">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-pie me-2 text-primary"></i>@Localizer["ExpensesByType"]</h6><canvas id="chartByType" height="250"></canvas></div>
    </div>
    <div class="col-lg-6">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-bar me-2 text-primary"></i>@Localizer["TopExpenses"]</h6><canvas id="chartBar" height="250"></canvas></div>
    </div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2"><select id="filterType" class="form-select"><option value="">@Localizer["AllTypes"]</option>@foreach (var t in Model.Select(e => e.ExpenseTypeName).Distinct().OrderBy(t => t)) { <option value="@t">@t</option> }</select></div>
        <div class="col-md-2"><select id="filterBranch" class="form-select"><option value="">@Localizer["AllBranches"]</option>@foreach (var b in Model.Select(e => e.BranchName).Distinct().OrderBy(b => b)) { <option value="@b">@b</option> }</select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up" id="printArea">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["ExpenseType"]</th><th>@Localizer["Amount"]</th><th>@Localizer["Date"]</th><th>@Localizer["Branch"]</th><th>@Localizer["Description"]</th>@if (isSuperAdmin) { <th>@Localizer["School"]</th> }<th class="no-print">@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td>@Model[i].ExpenseTypeName</td><td class="fw-bold">@Model[i].Amount.ToString("N0")</td><td>@Model[i].Date.ToString("yyyy-MM-dd")</td><td>@Model[i].BranchName</td><td>@Model[i].Description</td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td class="no-print">
                        <div class="action-group">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn-act btn-act-edit" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<style media="print">
    .page-header, .stat-ribbon, .filter-panel, .no-print, nav, .sidebar, footer, .row.mb-4 { display: none !important; }
    .table-card { box-shadow: none !important; border: none !important; }
    table { font-size: 12px; }
    th, td { padding: 4px 8px !important; }
</style>
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var typeColIdx = 1, branchColIdx = 4, schoolColIdx = isSuperAdmin ? 6 : -1;
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip', order: [[3, 'desc']] });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
        var labels = [@Html.Raw(string.Join(",", byType.Select(x => $"\"{x.Name}\"")))];
        var data = [@Html.Raw(string.Join(",", byType.Select(x => x.Total.ToString("F0"))))];
        var colors = ['#6366f1','#ec4899','#22c55e','#f59e0b','#06b6d4','#8b5cf6','#ef4444','#14b8a6','#f97316','#64748b'];
        new Chart(document.getElementById('chartByType'), { type: 'doughnut', data: { labels: labels, datasets: [{ data: data, backgroundColor: colors.slice(0, labels.length), borderWidth: 0 }] }, options: { responsive: true, plugins: { legend: { position: 'bottom' } } } });
        new Chart(document.getElementById('chartBar'), { type: 'bar', data: { labels: labels, datasets: [{ label: 'Amount', data: data, backgroundColor: colors.slice(0, labels.length), borderRadius: 8 }] }, options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
    });
    function applyFilters() {
        dt.search($('#searchInput').val());
        dt.column(typeColIdx).search($('#filterType').val());
        dt.column(branchColIdx).search($('#filterBranch').val());
        if (isSuperAdmin) { dt.column(schoolColIdx).search($('#filterSchool').val()); }
        dt.draw();
    }
    function resetFilters() { $('#searchInput, #filterType, #filterBranch').val(''); if (isSuperAdmin) { $('#filterSchool').val(''); } dt.search('').columns().search('').draw(); }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
    function printSchedule() { window.print(); }
</script>
}
