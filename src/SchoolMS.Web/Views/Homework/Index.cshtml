@using SchoolMS.Application.DTOs
@model List<HomeworkDto>
@{ ViewData["Title"] = Localizer["Homework"].Value; }
@Html.AntiForgeryToken()
@{
    var today = DateTime.Today;
    var overdue = Model.Count(h => h.DueDate.Date < today);
    var dueToday = Model.Count(h => h.DueDate.Date == today);
    var upcoming = Model.Count(h => h.DueDate.Date > today);
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-tasks text-primary"></i>@Localizer["Homework"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-primary" onclick="window.print()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddHomework"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-tasks"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-exclamation-circle"></i></div><div class="stat-info"><h6>@Localizer["Overdue"]</h6><div class="stat-value">@overdue</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-clock"></i></div><div class="stat-info"><h6>@Localizer["DueToday"]</h6><div class="stat-value">@dueToday</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-calendar-check"></i></div><div class="stat-info"><h6>@Localizer["Upcoming"]</h6><div class="stat-value">@upcoming</div></div></div>
</div>

@{
    var hwBySubject = Model.GroupBy(h => h.SubjectName ?? "Other").Select(g => new { Name = g.Key, Count = g.Count() }).OrderByDescending(x => x.Count).ToList();
}

<div class="row mb-4" data-aos="fade-up">
    <div class="col-lg-5">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-pie me-2 text-primary"></i>@Localizer["Status"]</h6><canvas id="chartStatus" height="220"></canvas></div>
    </div>
    <div class="col-lg-7">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-bar me-2 text-primary"></i>@Localizer["BySubject"]</h6><canvas id="chartSubject" height="220"></canvas></div>
    </div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2"><option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterBranch" class="form-select"><option value="">@Localizer["AllBranches"]</option>
                @foreach (var b in branches) { <option value="@b.Name">@b.Name</option> }
            </select>
        </div>
        <div class="col-md-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2">
            <select id="filterSubject" class="form-select"><option value="">@Localizer["AllSubjects"]</option>
                @foreach (var s in Model.Select(h => h.SubjectName).Distinct().OrderBy(s => s)) { <option value="@s">@s</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterGrade" class="form-select"><option value="">@Localizer["AllGrades"]</option>
                @foreach (var g in Model.Select(h => h.GradeName).Distinct().OrderBy(g => g)) { <option value="@g">@g</option> }
            </select>
        </div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Title"]</th><th>@Localizer["Subject"]</th><th>@Localizer["Teacher"]</th><th>@Localizer["Grade"]</th><th>@Localizer["DueDate"]</th><th>@Localizer["Attachments"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td>@Model[i].Title</td><td>@Model[i].SubjectName</td><td>@Model[i].TeacherName</td><td>@Model[i].GradeName</td><td>@Model[i].DueDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        @if (Model[i].Attachments.Count > 0)
                        {
                            <button class="btn btn-sm btn-outline-info" onclick="showAttachments(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Attachments"] (@Model[i].Attachments.Count)">
                                <i class="fas fa-paperclip"></i> @Model[i].Attachments.Count
                            </button>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Attachments Modal -->
<div class="modal fade" id="attachmentsModal" tabindex="-1">
    <div class="modal-dialog modal-lg"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="fas fa-paperclip me-2"></i>@Localizer["Attachments"]</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body" id="attachmentsBody"><div class="text-center"><i class="fas fa-spinner fa-spin"></i> Loading...</div></div>
        <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Close"]</button></div>
    </div></div>
</div>
@section Scripts {
<style media="print">
    .page-header .page-actions, .stat-ribbon, .filter-panel, nav, .sidebar, footer, .row.mb-4 { display: none !important; }
    .table-card { box-shadow: none !important; border: none !important; }
    table { font-size: 12px; }
    th, td { padding: 4px 8px !important; }
</style>
<script>
    var isSuperAdmin = @Json.Serialize(isSuperAdmin);
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip', order: [[5, 'desc']] });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });

        if (isSuperAdmin) {
            $('#filterSchool').on('change', function () {
                var schoolId = $(this).val();
                var $branch = $('#filterBranch');
                $branch.html('<option value="">@Localizer["AllBranches"]</option>');
                if (schoolId) {
                    $.getJSON('@Url.Action("GetBranchesBySchool")', { schoolId: schoolId }, function (data) {
                        $.each(data, function (_, b) { $branch.append('<option value="' + b.name + '">' + b.name + '</option>'); });
                    });
                }
            });
        }

        new Chart(document.getElementById('chartStatus'), { type: 'doughnut', data: { labels: ['@Localizer["Overdue"]', '@Localizer["DueToday"]', '@Localizer["Upcoming"]'], datasets: [{ data: [@overdue, @dueToday, @upcoming], backgroundColor: ['#ef4444','#f59e0b','#22c55e'], borderWidth: 0 }] }, options: { responsive: true, plugins: { legend: { position: 'bottom' } } } });

        var hwLabels = [@Html.Raw(string.Join(",", hwBySubject.Select(x => $"\"{x.Name}\"")))];
        var hwData = [@Html.Raw(string.Join(",", hwBySubject.Select(x => x.Count)))];
        var colors = ['#6366f1','#ec4899','#22c55e','#f59e0b','#06b6d4','#8b5cf6','#ef4444','#14b8a6'];
        new Chart(document.getElementById('chartSubject'), { type: 'bar', data: { labels: hwLabels, datasets: [{ label: '@Localizer["Homework"]', data: hwData, backgroundColor: colors.slice(0, hwLabels.length), borderRadius: 8 }] }, options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } } });
    });
    function applyFilters() {
        dt.search($('#searchInput').val());
        dt.column(2).search($('#filterSubject').val());
        dt.column(4).search($('#filterGrade').val());
        dt.draw();
    }
    function resetFilters() { $('#searchInput, #filterSubject, #filterGrade, #filterBranch').val(''); if (isSuperAdmin) { $('#filterSchool').val(''); } dt.search('').columns().search('').draw(); }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }

    function showAttachments(hwId) {
        $('#attachmentsBody').html('<div class="text-center"><i class="fas fa-spinner fa-spin"></i> Loading...</div>');
        new bootstrap.Modal('#attachmentsModal').show();
        $.get('@Url.Action("GetAttachments")', { homeworkId: hwId }, function (data) {
            if (!data || data.length === 0) { $('#attachmentsBody').html('<p class="text-muted text-center">No attachments.</p>'); return; }
            var html = '<div class="row g-3">';
            $.each(data, function (i, att) {
                var isImage = att.fileType && att.fileType.startsWith('image');
                html += '<div class="col-md-4 text-center">';
                if (isImage) {
                    html += '<a href="' + att.fileUrl + '" target="_blank"><img src="' + att.fileUrl + '" class="img-fluid rounded mb-2" style="max-height:200px" /></a>';
                } else {
                    html += '<a href="' + att.fileUrl + '" target="_blank" class="btn btn-outline-primary btn-lg mb-2"><i class="fas fa-file fa-3x"></i></a>';
                }
                html += '<br/><small>' + att.fileName + '</small></div>';
            });
            html += '</div>';
            $('#attachmentsBody').html(html);
        });
    }
</script>
}
