@model SchoolMS.Application.DTOs.HrDashboardDto
@{ ViewData["Title"] = Localizer["HrDashboard"].Value; }

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-tachometer-alt text-primary"></i> @Localizer["HrDashboard"]</h4></div>
</div>

<div class="row g-3 mb-4" data-aos="fade-up">
    <div class="col-md-3"><div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-users"></i></div><div class="stat-info"><h6>@Localizer["ActiveEmployees"]</h6><div class="stat-value">@Model.TotalActiveEmployees</div></div></div></div>
    <div class="col-md-3"><div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-user-times"></i></div><div class="stat-info"><h6>@Localizer["AbsentToday"]</h6><div class="stat-value">@Model.AbsentToday</div></div></div></div>
    <div class="col-md-3"><div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-clock"></i></div><div class="stat-info"><h6>@Localizer["LateToday"]</h6><div class="stat-value">@Model.LateToday</div></div></div></div>
    <div class="col-md-3"><div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-calendar-minus"></i></div><div class="stat-info"><h6>@Localizer["OnLeaveToday"]</h6><div class="stat-value">@Model.OnLeaveToday</div></div></div></div>
</div>

<div class="row g-3 mb-4" data-aos="fade-up">
    <div class="col-md-3"><div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-percentage"></i></div><div class="stat-info"><h6>@Localizer["AttendanceRate"]</h6><div class="stat-value">@Model.AverageAttendanceRate%</div></div></div></div>
    <div class="col-md-3"><div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-money-bill-wave"></i></div><div class="stat-info"><h6>@Localizer["MonthlyPayroll"]</h6><div class="stat-value">@Model.TotalPayrollThisMonth.ToString("N0")</div></div></div></div>
    <div class="col-md-3"><div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-hourglass-half"></i></div><div class="stat-info"><h6>@Localizer["PendingRequests"]</h6><div class="stat-value">@Model.PendingRequests</div></div></div></div>
    <div class="col-md-3"><div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-exclamation-triangle"></i></div><div class="stat-info"><h6>@Localizer["ExpiringContracts"]</h6><div class="stat-value">@Model.ExpiringContracts</div></div></div></div>
</div>

<div class="row g-3" data-aos="fade-up">
    <div class="col-md-4">
        <div class="dashboard-card card p-3">
            <h6><i class="fas fa-sitemap me-1 text-primary"></i> @Localizer["ByDepartment"]</h6>
            <ul class="list-group list-group-flush">
                @foreach (var d in Model.EmployeesByDepartment)
                {
                    <li class="list-group-item d-flex justify-content-between"><span>@d.Key</span><span class="badge bg-primary rounded-pill">@d.Value</span></li>
                }
            </ul>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card card p-3">
            <h6><i class="fas fa-briefcase me-1 text-info"></i> @Localizer["ByType"]</h6>
            <ul class="list-group list-group-flush">
                @foreach (var t in Model.EmployeesByType)
                {
                    <li class="list-group-item d-flex justify-content-between"><span>@t.Key</span><span class="badge bg-info rounded-pill">@t.Value</span></li>
                }
            </ul>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card card p-3">
            <h6><i class="fas fa-tasks me-1 text-warning"></i> @Localizer["PendingItems"]</h6>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between"><span>@Localizer["HrLeaves"]</span><span class="badge bg-warning rounded-pill">@Model.PendingLeaves</span></li>
                <li class="list-group-item d-flex justify-content-between"><span>@Localizer["Advances"]</span><span class="badge bg-warning rounded-pill">@Model.PendingAdvances</span></li>
                <li class="list-group-item d-flex justify-content-between"><span>@Localizer["Overtime"]</span><span class="badge bg-warning rounded-pill">@Model.PendingOvertime</span></li>
                <li class="list-group-item d-flex justify-content-between"><span>@Localizer["ExpiringDocuments"]</span><span class="badge bg-danger rounded-pill">@Model.ExpiringDocuments</span></li>
            </ul>
        </div>
    </div>
</div>
