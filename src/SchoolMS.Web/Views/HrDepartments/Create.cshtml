@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (HrDepartmentDto)Model : null;
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
    var departments = ViewBag.Departments as List<HrDepartmentDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditDepartment"] : Localizer["AddDepartment"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label">@Localizer["Name"] *</label><input type="text" name="DepartmentName" class="form-control" value="@item?.DepartmentName" required /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["NameAr"]</label><input type="text" name="DepartmentNameAr" class="form-control" value="@item?.DepartmentNameAr" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Code"]</label><input type="text" name="DepartmentCode" class="form-control" value="@item?.DepartmentCode" /></div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Branch"]</label>
                <select name="BranchId" class="form-select select2">
                    <option value="">—</option>
                    @foreach (var b in branches) { <option value="@b.Id" selected="@(item?.BranchId == b.Id)">@b.Name</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["ParentDepartment"]</label>
                <select name="ParentDepartmentId" class="form-select select2">
                    <option value="">—</option>
                    @foreach (var d in departments.Where(d => d.Id != item?.Id)) { <option value="@d.Id" selected="@(item?.ParentDepartmentId == d.Id)">@d.DepartmentName</option> }
                </select>
            </div>
            <div class="col-md-2"><label class="form-label">@Localizer["Color"]</label><input type="color" name="Color" class="form-control form-control-color" value="@(item?.Color ?? "#3b82f6")" /></div>
            <div class="col-md-2">
                <label class="form-label">@Localizer["Active"]</label>
                <div class="form-check form-switch mt-2"><input class="form-check-input" type="checkbox" name="IsActive" value="true" @(item?.IsActive != false ? "checked" : "") /></div>
            </div>
            <div class="col-12"><label class="form-label">@Localizer["Description"]</label><textarea name="Description" class="form-control" rows="2">@item?.Description</textarea></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
