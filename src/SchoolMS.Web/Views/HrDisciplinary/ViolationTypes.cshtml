@model List<SchoolMS.Application.DTOs.HrViolationTypeDto>
@{ ViewData["Title"] = Localizer["ViolationTypes"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-list text-primary"></i> @Localizer["ViolationTypes"]</h4></div>
    <div class="page-actions"><a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a></div>
</div>

<div class="row g-3" data-aos="fade-up">
    <div class="col-md-8">
        <div class="table-card hover-lift">
            <table id="dataTable" class="table table-hover" style="width:100%">
                <thead><tr><th>#</th><th>@Localizer["Name"]</th><th>@Localizer["Severity"]</th><th>@Localizer["DefaultAction"]</th><th>@Localizer["Penalty"]</th><th>@Localizer["Active"]</th><th>@Localizer["Actions"]</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var v = Model[i];
                        var sevCls = v.Severity switch { ViolationSeverity.Minor => "bg-info", ViolationSeverity.Moderate => "bg-warning", ViolationSeverity.Major => "bg-danger", ViolationSeverity.Critical => "bg-dark", _ => "bg-secondary" };
                        <tr>
                            <td>@(i + 1)</td><td>@v.ViolationName</td>
                            <td><span class="badge @sevCls">@v.Severity</span></td>
                            <td>@v.DefaultAction</td><td>@(v.DefaultPenaltyAmount?.ToString("N0") ?? "—")</td>
                            <td>@(v.IsActive ? "✅" : "❌")</td>
                            <td><div class="action-group"><button class="btn-act btn-act-delete" onclick="del(@v.Id)"><i class="fas fa-trash"></i></button></div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card card p-3">
            <h6><i class="fas fa-plus me-1"></i>@Localizer["Add"] @Localizer["ViolationType"]</h6>
            <form asp-action="CreateViolationType" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-2"><input type="text" name="ViolationName" class="form-control form-control-sm" placeholder="@Localizer["Name"] *" required /></div>
                <div class="mb-2"><select name="Severity" class="form-select form-select-sm">@foreach (var s in Enum.GetValues<ViolationSeverity>()) { <option value="@s">@s</option> }</select></div>
                <div class="mb-2"><input type="text" name="DefaultAction" class="form-control form-control-sm" placeholder="@Localizer["DefaultAction"]" /></div>
                <div class="mb-2"><input type="number" step="0.01" name="DefaultPenaltyAmount" class="form-control form-control-sm" placeholder="@Localizer["DefaultPenalty"]" /></div>
                <div class="mb-2"><input type="number" name="DefaultSuspensionDays" class="form-control form-control-sm" placeholder="@Localizer["SuspensionDays"]" /></div>
                <div class="mb-2"><textarea name="Description" class="form-control form-control-sm" rows="2" placeholder="@Localizer["Description"]"></textarea></div>
                <button type="submit" class="btn btn-accent btn-sm w-100"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () { $('#dataTable').DataTable({ responsive: true, dom: 'rtip' }); });
    function del(id) { confirmDelete('@Url.Action("DeleteViolationType")', id, function () { location.reload(); }); }
</script>
}
