@using SchoolMS.Application.DTOs
@model List<HrEmployeeDto>
@{
    ViewData["Title"] = Localizer["Employees"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-users text-primary"></i> @Localizer["Employees"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions"><a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddEmployee"]</a></div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-users"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-circle"></i></div><div class="stat-info"><h6>@Localizer["Active"]</h6><div class="stat-value">@Model.Count(e => e.Status == HrEmployeeStatus.Active)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-user-clock"></i></div><div class="stat-info"><h6>@Localizer["OnProbation"]</h6><div class="stat-value">@Model.Count(e => e.Status == HrEmployeeStatus.OnProbation)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-calendar-minus"></i></div><div class="stat-info"><h6>@Localizer["OnLeave"]</h6><div class="stat-value">@Model.Count(e => e.Status == HrEmployeeStatus.OnLeave)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterBranch" class="form-select">
                <option value="">@Localizer["AllBranches"]</option>
                @foreach (var b in branches) { <option value="@b.Name">@b.Name</option> }
            </select>
        </div>
        <div class="col-md-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2">
            <select id="filterStatus" class="form-select">
                <option value="">@Localizer["AllStatuses"]</option>
                @foreach (var s in Enum.GetValues<HrEmployeeStatus>()) { <option value="@s">@s</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterType" class="form-select">
                <option value="">@Localizer["AllTypes"]</option>
                @foreach (var t in Enum.GetValues<EmployeeType>()) { <option value="@t">@t</option> }
            </select>
        </div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Photo"]</th><th>@Localizer["EmployeeNo"]</th><th>@Localizer["Name"]</th><th>@Localizer["Department"]</th><th>@Localizer["JobTitle"]</th><th>@Localizer["Type"]</th><th>@Localizer["Status"]</th>@if (isSuperAdmin) { <th>@Localizer["School"]</th> }<th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var e = Model[i];
                <tr>
                    <td>@(i + 1)</td>
                    <td><img src="@(e.ProfileImage ?? "/img/avatar.png")" class="rounded-circle" width="35" height="35" /></td>
                    <td><span class="badge bg-dark">@e.EmployeeNumber</span></td>
                    <td><a href="@Url.Action("Details", new { id = e.Id })">@e.FullName</a></td>
                    <td>@e.DepartmentName</td><td>@e.JobTitleName</td>
                    <td><span class="badge bg-info">@e.EmployeeType</span></td>
                    <td>
                        @{
                            var statusClass = e.Status switch { HrEmployeeStatus.Active => "bg-success", HrEmployeeStatus.OnProbation => "bg-warning", HrEmployeeStatus.OnLeave => "bg-info", HrEmployeeStatus.Suspended => "bg-danger", _ => "bg-secondary" };
                        }
                        <span class="badge @statusClass">@e.Status</span>
                    </td>
                    @if (isSuperAdmin) { <td>@e.SchoolName</td> }
                    <td>
                        <div class="action-group">
                            <a href="@Url.Action("Details", new { id = e.Id })" class="btn-act btn-act-view"><i class="fas fa-eye"></i></a>
                            <a href="@Url.Action("Edit", new { id = e.Id })" class="btn-act btn-act-edit"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@e.Id)"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var dt;
    var schoolCol = isSuperAdmin ? 8 : -1;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
    });
    function applyFilters() {
        dt.search($('#searchInput').val());
        dt.column(7).search($('#filterStatus').val());
        dt.column(6).search($('#filterType').val());
        if (isSuperAdmin) { dt.column(schoolCol).search($('#filterSchool').val()); }
        dt.draw();
    }
    function resetFilters() {
        $('#searchInput, #filterBranch, #filterStatus, #filterType').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
