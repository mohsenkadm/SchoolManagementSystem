@model List<SchoolMS.Application.DTOs.HrEndOfServiceDto>
@{ ViewData["Title"] = Localizer["HrEndOfService"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-door-open text-primary"></i> @Localizer["HrEndOfService"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions"><a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["Add"]</a></div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-hourglass-half"></i></div><div class="stat-info"><h6>@Localizer["InProgress"]</h6><div class="stat-value">@Model.Count(e => e.Status == EndOfServiceStatus.InProgress || e.Status == EndOfServiceStatus.ClearancePhase)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-double"></i></div><div class="stat-info"><h6>@Localizer["Completed"]</h6><div class="stat-value">@Model.Count(e => e.Status == EndOfServiceStatus.Completed)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-money-bill"></i></div><div class="stat-info"><h6>@Localizer["TotalSettlement"]</h6><div class="stat-value">@Model.Sum(e => e.FinalSettlementAmount).ToString("N0")</div></div></div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Employee"]</th><th>@Localizer["Type"]</th><th>@Localizer["EffectiveDate"]</th><th>@Localizer["ServiceYears"]</th><th>@Localizer["Settlement"]</th><th>@Localizer["Settled"]</th><th>@Localizer["Status"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var e = Model[i];
                var cls = e.Status switch { EndOfServiceStatus.Requested => "bg-warning", EndOfServiceStatus.InProgress => "bg-info", EndOfServiceStatus.ClearancePhase => "bg-primary", EndOfServiceStatus.Approved => "bg-success", EndOfServiceStatus.Settled => "bg-dark", EndOfServiceStatus.Completed => "bg-success", _ => "bg-secondary" };
                <tr>
                    <td>@(i + 1)</td><td>@e.EmployeeName</td>
                    <td><span class="badge bg-info">@e.Type</span></td>
                    <td>@e.EffectiveDate.ToString("dd/MM/yyyy")</td>
                    <td>@e.TotalServiceYears y @e.TotalServiceMonths m</td>
                    <td class="fw-bold text-success">@e.FinalSettlementAmount.ToString("N0")</td>
                    <td>@(e.IsSettled ? "✅" : "❌")</td>
                    <td><span class="badge @cls">@e.Status</span></td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Details", new { id = e.Id })" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            @if (e.Status == EndOfServiceStatus.Requested || e.Status == EndOfServiceStatus.InProgress)
                            {
                                <form asp-action="Approve" method="post" class="d-inline"><input type="hidden" name="id" value="@e.Id" /><button class="btn btn-sm btn-success"><i class="fas fa-check"></i></button></form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>$(function () { $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' }); });</script>
}
