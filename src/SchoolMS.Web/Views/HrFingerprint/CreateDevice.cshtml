@{ ViewData["Title"] = Localizer["AddDevice"].Value; }

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas fa-plus-circle me-2 text-primary"></i>@Localizer["AddDevice"]</h4>
    <a href="@Url.Action("Devices")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="CreateDevice" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label">@Localizer["DeviceName"] *</label><input type="text" name="DeviceName" class="form-control" required /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["DeviceModel"]</label><input type="text" name="DeviceModel" class="form-control" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["SerialNumber"]</label><input type="text" name="SerialNumber" class="form-control" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["IpAddress"]</label><input type="text" name="IpAddress" class="form-control" placeholder="192.168.1.x" /></div>
            <div class="col-md-2"><label class="form-label">@Localizer["Port"]</label><input type="number" name="Port" class="form-control" value="4370" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["ConnectionType"]</label><input type="text" name="ConnectionType" class="form-control" placeholder="TCP/IP" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Location"]</label><input type="text" name="Location" class="form-control" /></div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Status"]</label>
                <select name="Status" class="form-select">@foreach (var s in Enum.GetValues<DeviceStatus>()) { <option value="@s">@s</option> }</select>
            </div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button></div>
    </form>
</div>
