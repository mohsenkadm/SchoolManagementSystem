@using SchoolMS.Application.DTOs
@model List<HrJobTitleDto>
@{
    ViewData["Title"] = Localizer["JobTitles"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-briefcase text-primary"></i> @Localizer["JobTitles"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions"><a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["Add"]</a></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterBranch" class="form-select">
                <option value="">@Localizer["AllBranches"]</option>
                @foreach (var b in branches) { <option value="@b.Name">@b.Name</option> }
            </select>
        </div>
        <div class="col-md-3"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i> @Localizer["Search"]</button></div>
        <div class="col-md-2"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i> @Localizer["Reset"]</button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Name"]</th><th>@Localizer["Code"]</th><th>@Localizer["Department"]</th><th>@Localizer["MinSalary"]</th><th>@Localizer["MaxSalary"]</th><th>@Localizer["Active"]</th>@if (isSuperAdmin) { <th>@Localizer["School"]</th> }<th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>
                    <td>@(i + 1)</td><td>@Model[i].TitleName</td><td>@Model[i].TitleCode</td><td>@Model[i].DepartmentName</td>
                    <td>@Model[i].MinSalary?.ToString("N0")</td><td>@Model[i].MaxSalary?.ToString("N0")</td>
                    <td>@if (Model[i].IsActive) { <span class="status-badge status-active"><span class="status-dot"></span> @Localizer["Active"]</span> } else { <span class="badge bg-secondary">@Localizer["Inactive"]</span> }</td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td>
                        <div class="action-group">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn-act btn-act-edit"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@Model[i].Id)"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
    });
    function applyFilters() {
        dt.search($('#searchInput').val());
        if (isSuperAdmin) { dt.column(7).search($('#filterSchool').val()); }
        dt.draw();
    }
    function resetFilters() {
        $('#searchInput, #filterBranch').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
