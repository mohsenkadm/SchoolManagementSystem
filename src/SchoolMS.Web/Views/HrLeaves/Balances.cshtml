@model List<SchoolMS.Application.DTOs.HrLeaveBalanceDto>
@{ ViewData["Title"] = Localizer["LeaveBalances"].Value; }

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-balance-scale text-primary"></i> @Localizer["LeaveBalances"]</h4></div>
    <div class="page-actions"><a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a></div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Employee"]</th><th>@Localizer["LeaveType"]</th><th>@Localizer["Year"]</th><th>@Localizer["Entitlement"]</th><th>@Localizer["Used"]</th><th>@Localizer["Pending"]</th><th>@Localizer["Remaining"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var b = Model[i];
                <tr>
                    <td>@(i + 1)</td><td>@b.EmployeeName</td><td>@b.LeaveTypeName</td><td>@b.Year</td>
                    <td><span class="badge bg-primary">@b.TotalAvailable</span></td>
                    <td><span class="badge bg-success">@b.Used</span></td>
                    <td><span class="badge bg-warning">@b.Pending</span></td>
                    <td><span class="badge @(b.Remaining > 0 ? "bg-info" : "bg-danger")">@b.Remaining</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>$(function () { $('#dataTable').DataTable({ responsive: true, dom: 'rtip' }); });</script>
}
