@using SchoolMS.Application.DTOs
@{
    var employees = ViewBag.Employees as List<HrEmployeeDto> ?? new();
    var leaveTypes = ViewBag.LeaveTypes as List<HrLeaveTypeDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas fa-plus-circle me-2 text-primary"></i>@Localizer["NewRequest"]</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">@Localizer["Employee"] *</label>
                <select name="EmployeeId" class="form-select select2" required><option value="">—</option>@foreach (var e in employees) { <option value="@e.Id">@e.FullName</option> }</select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["LeaveType"] *</label>
                <select name="LeaveTypeId" class="form-select select2" required><option value="">—</option>@foreach (var t in leaveTypes) { <option value="@t.Id">@t.LeaveTypeName</option> }</select>
            </div>
            <div class="col-md-2"><label class="form-label">@Localizer["From"] *</label><input type="date" name="StartDate" class="form-control" required /></div>
            <div class="col-md-2"><label class="form-label">@Localizer["To"] *</label><input type="date" name="EndDate" class="form-control" required /></div>
            <div class="col-md-2">
                <label class="form-label">@Localizer["HalfDay"]</label>
                <div class="form-check form-switch mt-2"><input class="form-check-input" type="checkbox" name="IsHalfDay" value="true" /></div>
            </div>
            <div class="col-md-10"><label class="form-label">@Localizer["Reason"]</label><textarea name="Reason" class="form-control" rows="2"></textarea></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Submit"]</button></div>
    </form>
</div>
