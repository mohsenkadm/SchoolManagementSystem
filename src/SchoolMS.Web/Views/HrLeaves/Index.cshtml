@model List<SchoolMS.Application.DTOs.HrLeaveRequestDto>
@{ ViewData["Title"] = Localizer["HrLeaves"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-calendar-minus text-primary"></i> @Localizer["HrLeaves"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions">
        <a href="@Url.Action("Types")" class="btn btn-secondary"><i class="fas fa-list me-1"></i>@Localizer["LeaveTypes"]</a>
        <a href="@Url.Action("Holidays")" class="btn btn-secondary"><i class="fas fa-calendar me-1"></i>@Localizer["Holidays"]</a>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["NewRequest"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-hourglass-half"></i></div><div class="stat-info"><h6>@Localizer["Pending"]</h6><div class="stat-value">@Model.Count(l => l.Status == HrLeaveStatus.Pending)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-double"></i></div><div class="stat-info"><h6>@Localizer["Approved"]</h6><div class="stat-value">@Model.Count(l => l.Status == HrLeaveStatus.ApprovedByHR)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-times"></i></div><div class="stat-info"><h6>@Localizer["Rejected"]</h6><div class="stat-value">@Model.Count(l => l.Status == HrLeaveStatus.Rejected)</div></div></div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Employee"]</th><th>@Localizer["LeaveType"]</th><th>@Localizer["From"]</th><th>@Localizer["To"]</th><th>@Localizer["Days"]</th><th>@Localizer["Status"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var l = Model[i];
                var cls = l.Status switch { HrLeaveStatus.Pending => "bg-warning", HrLeaveStatus.ApprovedByManager => "bg-info", HrLeaveStatus.ApprovedByHR => "bg-success", HrLeaveStatus.Rejected => "bg-danger", HrLeaveStatus.Cancelled => "bg-secondary", _ => "bg-secondary" };
                <tr>
                    <td>@(i + 1)</td><td>@l.EmployeeName</td><td>@l.LeaveTypeName</td>
                    <td>@l.StartDate.ToString("dd/MM/yyyy")</td><td>@l.EndDate.ToString("dd/MM/yyyy")</td><td>@l.TotalDays</td>
                    <td><span class="badge @cls">@l.Status</span></td>
                    <td>
                        @if (l.Status == HrLeaveStatus.Pending)
                        {
                            <form asp-action="ApproveManager" method="post" class="d-inline"><input type="hidden" name="id" value="@l.Id" /><button class="btn btn-sm btn-info" title="@Localizer["ApproveManager"]"><i class="fas fa-user-check"></i></button></form>
                            <form asp-action="Reject" method="post" class="d-inline"><input type="hidden" name="id" value="@l.Id" /><button class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button></form>
                        }
                        @if (l.Status == HrLeaveStatus.ApprovedByManager)
                        {
                            <form asp-action="ApproveHr" method="post" class="d-inline"><input type="hidden" name="id" value="@l.Id" /><button class="btn btn-sm btn-success" title="@Localizer["ApproveHR"]"><i class="fas fa-check-double"></i></button></form>
                            <form asp-action="Reject" method="post" class="d-inline"><input type="hidden" name="id" value="@l.Id" /><button class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button></form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>$(function () { $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' }); });</script>
}
