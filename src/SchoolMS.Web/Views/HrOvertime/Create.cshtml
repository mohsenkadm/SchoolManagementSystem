@using SchoolMS.Application.DTOs
@{ var employees = ViewBag.Employees as List<HrEmployeeDto> ?? new(); }

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas fa-plus-circle me-2 text-primary"></i>@Localizer["Add"] @Localizer["Overtime"]</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">@Localizer["Employee"] *</label>
                <select name="EmployeeId" class="form-select select2" required><option value="">—</option>@foreach (var e in employees) { <option value="@e.Id">@e.FullName</option> }</select>
            </div>
            <div class="col-md-3"><label class="form-label">@Localizer["Date"] *</label><input type="date" name="OvertimeDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required /></div>
            <div class="col-md-2"><label class="form-label">@Localizer["Hours"] *</label><input type="number" step="0.5" name="TotalHours" class="form-control" required /></div>
            <div class="col-12"><label class="form-label">@Localizer["Reason"]</label><textarea name="Reason" class="form-control" rows="2"></textarea></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button></div>
    </form>
</div>
