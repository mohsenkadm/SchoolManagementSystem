@using SchoolMS.Application.DTOs
@{
    var employees = ViewBag.Employees as List<HrEmployeeDto> ?? new();
    var cycles = ViewBag.Cycles as List<HrPerformanceCycleDto> ?? new();
    ViewData["Title"] = Localizer["CreateReview"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas fa-plus-circle me-2 text-primary"></i>@Localizer["CreateReview"]</h4>
    <a href="@Url.Action("Reviews")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="CreateReview" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">@Localizer["Employee"] *</label>
                <select name="EmployeeId" class="form-select select2" required><option value="">—</option>@foreach (var e in employees) { <option value="@e.Id">@e.FullName</option> }</select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Cycle"] *</label>
                <select name="PerformanceCycleId" class="form-select select2" required><option value="">—</option>@foreach (var c in cycles) { <option value="@c.Id">@c.CycleName</option> }</select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Reviewer"] *</label>
                <select name="ReviewerId" class="form-select select2" required><option value="">—</option>@foreach (var e in employees) { <option value="@e.Id">@e.FullName</option> }</select>
            </div>
            <div class="col-md-4"><label class="form-label">@Localizer["PerformanceRating"]</label><input type="text" name="PerformanceRating" class="form-control" /></div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Status"]</label>
                <select name="Status" class="form-select">@foreach (var s in Enum.GetValues<ReviewStatus>()) { <option value="@s">@s</option> }</select>
            </div>
            <div class="col-md-4"><label class="form-label">@Localizer["CompletedDate"]</label><input type="date" name="CompletedDate" class="form-control" /></div>
            <div class="col-md-6"><label class="form-label">@Localizer["Strengths"]</label><textarea name="Strengths" class="form-control" rows="2"></textarea></div>
            <div class="col-md-6"><label class="form-label">@Localizer["AreasForImprovement"]</label><textarea name="AreasForImprovement" class="form-control" rows="2"></textarea></div>
            <div class="col-md-6"><label class="form-label">@Localizer["Goals"]</label><textarea name="Goals" class="form-control" rows="2"></textarea></div>
            <div class="col-md-6"><label class="form-label">@Localizer["ManagerComments"]</label><textarea name="ManagerComments" class="form-control" rows="2"></textarea></div>
            <div class="col-md-6"><label class="form-label">@Localizer["Recommendation"]</label><textarea name="Recommendation" class="form-control" rows="2"></textarea></div>
            <div class="col-md-6"><label class="form-label">@Localizer["Notes"]</label><textarea name="Notes" class="form-control" rows="2"></textarea></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button></div>
    </form>
</div>
