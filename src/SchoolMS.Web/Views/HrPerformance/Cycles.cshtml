@model List<SchoolMS.Application.DTOs.HrPerformanceCycleDto>
@{ ViewData["Title"] = Localizer["PerformanceCycles"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-sync text-primary"></i> @Localizer["PerformanceCycles"]</h4></div>
    <div class="page-actions">
        <a href="@Url.Action("Criteria")" class="btn btn-secondary"><i class="fas fa-list me-1"></i>@Localizer["Criteria"]</a>
        <a href="@Url.Action("Reviews")" class="btn btn-info"><i class="fas fa-star me-1"></i>@Localizer["Reviews"]</a>
        <a href="@Url.Action("Kpis")" class="btn btn-warning"><i class="fas fa-bullseye me-1"></i>KPIs</a>
    </div>
</div>

<div class="row g-3" data-aos="fade-up">
    <div class="col-md-8">
        <div class="table-card hover-lift">
            <table id="dataTable" class="table table-hover" style="width:100%">
                <thead><tr><th>#</th><th>@Localizer["Name"]</th><th>@Localizer["StartDate"]</th><th>@Localizer["EndDate"]</th><th>@Localizer["Status"]</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var c = Model[i];
                        var cls = c.Status switch { CycleStatus.Active => "bg-success", CycleStatus.Completed => "bg-primary", CycleStatus.Planning => "bg-warning", _ => "bg-secondary" };
                        <tr><td>@(i + 1)</td><td>@c.CycleName</td><td>@c.StartDate.ToString("dd/MM/yyyy")</td><td>@c.EndDate.ToString("dd/MM/yyyy")</td><td><span class="badge @cls">@c.Status</span></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card card p-3">
            <h6><i class="fas fa-plus me-1"></i>@Localizer["AddCycle"]</h6>
            <form asp-action="CreateCycle" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-2"><input type="text" name="CycleName" class="form-control form-control-sm" placeholder="@Localizer["Name"] *" required /></div>
                <div class="mb-2"><input type="date" name="StartDate" class="form-control form-control-sm" required /></div>
                <div class="mb-2"><input type="date" name="EndDate" class="form-control form-control-sm" required /></div>
                <div class="mb-2"><select name="Status" class="form-select form-select-sm">@foreach (var s in Enum.GetValues<CycleStatus>()) { <option value="@s">@s</option> }</select></div>
                <div class="mb-2"><textarea name="Description" class="form-control form-control-sm" rows="2" placeholder="@Localizer["Description"]"></textarea></div>
                <button type="submit" class="btn btn-accent btn-sm w-100"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>$(function () { $('#dataTable').DataTable({ responsive: true, dom: 'rtip' }); });</script>
}
