@model List<SchoolMS.Application.DTOs.HrPerformanceReviewDto>
@{ ViewData["Title"] = Localizer["PerformanceReviews"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-star text-primary"></i> @Localizer["PerformanceReviews"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions">
        <a href="@Url.Action("Cycles")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
        <a href="@Url.Action("CreateReview")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["Add"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-hourglass-half"></i></div><div class="stat-info"><h6>@Localizer["Pending"]</h6><div class="stat-value">@Model.Count(r => r.Status != ReviewStatus.Completed)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-double"></i></div><div class="stat-info"><h6>@Localizer["Completed"]</h6><div class="stat-value">@Model.Count(r => r.Status == ReviewStatus.Completed)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-percentage"></i></div><div class="stat-info"><h6>@Localizer["AvgScore"]</h6><div class="stat-value">@(Model.Any() ? Model.Average(r => r.Percentage).ToString("N1") : "0")%</div></div></div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Employee"]</th><th>@Localizer["Cycle"]</th><th>@Localizer["Score"]</th><th>@Localizer["Percentage"]</th><th>@Localizer["Rating"]</th><th>@Localizer["Status"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var r = Model[i];
                var cls = r.Status switch { ReviewStatus.Completed => "bg-success", ReviewStatus.Draft => "bg-secondary", _ => "bg-warning" };
                <tr>
                    <td>@(i + 1)</td><td>@r.EmployeeName</td><td>@r.CycleName</td>
                    <td>@r.TotalScore / @r.MaxPossibleScore</td>
                    <td><span class="badge @(r.Percentage >= 80 ? "bg-success" : r.Percentage >= 60 ? "bg-warning" : "bg-danger")">@r.Percentage.ToString("N1")%</span></td>
                    <td>@r.PerformanceRating</td>
                    <td><span class="badge @cls">@r.Status</span></td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("ReviewDetails", new { id = r.Id })" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            @if (r.Status != ReviewStatus.Completed)
                            {
                                <form asp-action="CompleteReview" method="post" class="d-inline"><input type="hidden" name="id" value="@r.Id" /><button class="btn btn-sm btn-success"><i class="fas fa-check"></i></button></form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>$(function () { $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' }); });</script>
}
