@model List<SchoolMS.Application.DTOs.HrBonusDto>
@{ ViewData["Title"] = Localizer["Bonuses"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-gift text-success"></i> @Localizer["Bonuses"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions"><a href="@Url.Action("Payroll")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a></div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Employee"]</th><th>@Localizer["Type"]</th><th>@Localizer["Amount"]</th><th>@Localizer["Reason"]</th><th>@Localizer["Status"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var b = Model[i];
                var cls = b.Status switch { BonusStatus.Pending => "bg-warning", BonusStatus.Approved => "bg-success", BonusStatus.Rejected => "bg-danger", BonusStatus.Paid => "bg-dark", _ => "bg-secondary" };
                <tr>
                    <td>@(i + 1)</td><td>@b.EmployeeName</td><td>@b.BonusType</td><td class="text-success fw-bold">@b.Amount.ToString("N0")</td>
                    <td>@b.Reason</td><td><span class="badge @cls">@b.Status</span></td>
                    <td>
                        @if (b.Status == BonusStatus.Pending)
                        {
                            <form asp-action="ApproveBonus" method="post" class="d-inline"><input type="hidden" name="id" value="@b.Id" /><button class="btn btn-sm btn-success"><i class="fas fa-check"></i></button></form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>$(function () { $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' }); });</script>
}
