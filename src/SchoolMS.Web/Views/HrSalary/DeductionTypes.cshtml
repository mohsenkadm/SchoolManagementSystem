@model List<SchoolMS.Application.DTOs.HrDeductionTypeDto>
@{ ViewData["Title"] = Localizer["DeductionTypes"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-minus-circle text-danger"></i> @Localizer["DeductionTypes"]</h4></div>
    <div class="page-actions"><a href="@Url.Action("Payroll")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a></div>
</div>

<div class="row g-3" data-aos="fade-up">
    <div class="col-md-8">
        <div class="table-card hover-lift">
            <table id="dataTable" class="table table-hover" style="width:100%">
                <thead><tr><th>#</th><th>@Localizer["Name"]</th><th>@Localizer["Code"]</th><th>@Localizer["CalcType"]</th><th>@Localizer["Default"]</th><th>@Localizer["Mandatory"]</th><th>@Localizer["Active"]</th><th>@Localizer["Actions"]</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var d = Model[i];
                        <tr>
                            <td>@(i + 1)</td><td>@d.DeductionName</td><td>@d.DeductionCode</td>
                            <td><span class="badge bg-warning">@d.CalculationType</span></td><td>@d.DefaultValue?.ToString("N0")</td>
                            <td>@(d.IsMandatory ? "✅" : "❌")</td><td>@(d.IsActive ? "✅" : "❌")</td>
                            <td><div class="action-group"><button class="btn-act btn-act-delete" onclick="del(@d.Id)"><i class="fas fa-trash"></i></button></div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card card p-3">
            <h6><i class="fas fa-plus me-1"></i>@Localizer["Add"]</h6>
            <form asp-action="CreateDeductionType" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-2"><input type="text" name="DeductionName" class="form-control form-control-sm" placeholder="@Localizer["Name"] *" required /></div>
                <div class="mb-2"><input type="text" name="DeductionCode" class="form-control form-control-sm" placeholder="@Localizer["Code"]" /></div>
                <div class="mb-2"><select name="CalculationType" class="form-select form-select-sm">@foreach (var t in Enum.GetValues<DeductionCalculation>()) { <option value="@t">@t</option> }</select></div>
                <div class="mb-2"><input type="number" step="0.01" name="DefaultValue" class="form-control form-control-sm" placeholder="@Localizer["Default"]" /></div>
                <div class="form-check mb-2"><input class="form-check-input" type="checkbox" name="IsMandatory" value="true" /><label class="form-check-label">@Localizer["Mandatory"]</label></div>
                <div class="form-check mb-2"><input class="form-check-input" type="checkbox" name="IsRecurring" value="true" checked /><label class="form-check-label">@Localizer["Recurring"]</label></div>
                <button type="submit" class="btn btn-accent btn-sm w-100"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () { $('#dataTable').DataTable({ responsive: true, dom: 'rtip' }); });
    function del(id) { confirmDelete('@Url.Action("DeleteDeductionType")', id, function () { location.reload(); }); }
</script>
}
