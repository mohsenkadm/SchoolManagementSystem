@using SchoolMS.Application.DTOs
@{ var branches = ViewBag.Branches as List<BranchDto> ?? new(); ViewData["Title"] = Localizer["GeneratePayroll"].Value; }

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas fa-calculator me-2 text-primary"></i>@Localizer["GeneratePayroll"]</h4>
    <a href="@Url.Action("Payroll")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="GeneratePayroll" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">@Localizer["Month"] *</label>
                <select name="month" class="form-select" required>
                    @for (int m = 1; m <= 12; m++) { <option value="@m" selected="@(m == DateTime.Now.Month)">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option> }
                </select>
            </div>
            <div class="col-md-4"><label class="form-label">@Localizer["Year"] *</label><input type="number" name="year" class="form-control" value="@DateTime.Now.Year" required /></div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Branch"] *</label>
                <select name="branchId" class="form-select select2" required>
                    @foreach (var b in branches) { <option value="@b.Id">@b.Name</option> }
                </select>
            </div>
        </div>
        <div class="mt-4">
            <div class="alert alert-warning"><i class="fas fa-exclamation-triangle me-1"></i>@Localizer["GeneratePayrollWarning"]</div>
            <button type="submit" class="btn btn-accent"><i class="fas fa-calculator me-1"></i>@Localizer["GeneratePayroll"]</button>
        </div>
    </form>
</div>
