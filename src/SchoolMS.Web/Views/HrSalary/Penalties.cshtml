@model List<SchoolMS.Application.DTOs.HrPenaltyDto>
@{ ViewData["Title"] = Localizer["Penalties"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-ban text-danger"></i> @Localizer["Penalties"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions"><a href="@Url.Action("Payroll")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a></div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Employee"]</th><th>@Localizer["Type"]</th><th>@Localizer["Amount"]</th><th>@Localizer["Reason"]</th><th>@Localizer["Status"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var p = Model[i];
                var cls = p.Status switch { PenaltyStatus.Pending => "bg-warning", PenaltyStatus.Approved => "bg-success", PenaltyStatus.Rejected => "bg-danger", PenaltyStatus.Deducted => "bg-dark", _ => "bg-secondary" };
                <tr>
                    <td>@(i + 1)</td><td>@p.EmployeeName</td><td>@p.PenaltyType</td><td class="text-danger fw-bold">@p.Amount.ToString("N0")</td>
                    <td>@p.Reason</td><td><span class="badge @cls">@p.Status</span></td>
                    <td>
                        @if (p.Status == PenaltyStatus.Pending)
                        {
                            <form asp-action="ApprovePenalty" method="post" class="d-inline"><input type="hidden" name="id" value="@p.Id" /><button class="btn btn-sm btn-success"><i class="fas fa-check"></i></button></form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>$(function () { $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' }); });</script>
}
