@model SchoolMS.Application.DTOs.HrSettingsDto
@{ ViewData["Title"] = Localizer["HrSettings"].Value; }

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-cog text-primary"></i> @Localizer["HrSettings"]</h4></div>
</div>

<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="Update" method="post">
        @Html.AntiForgeryToken()

        <h6 class="mb-3"><i class="fas fa-sliders-h me-1 text-info"></i>@Localizer["GeneralSettings"]</h6>
        <div class="row g-3 mb-4">
            <div class="col-md-4"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="HrRequireApprovalForLeaves" value="true" @(Model.HrRequireApprovalForLeaves ? "checked" : "") /><label class="form-check-label">@Localizer["RequireApprovalForLeaves"]</label></div></div>
            <div class="col-md-4"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="HrAutoCalculateOvertime" value="true" @(Model.HrAutoCalculateOvertime ? "checked" : "") /><label class="form-check-label">@Localizer["AutoCalculateOvertime"]</label></div></div>
            <div class="col-md-4"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="HrAutoDeductAbsence" value="true" @(Model.HrAutoDeductAbsence ? "checked" : "") /><label class="form-check-label">@Localizer["AutoDeductAbsence"]</label></div></div>
            <div class="col-md-4"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="HrEnableFingerprintIntegration" value="true" @(Model.HrEnableFingerprintIntegration ? "checked" : "") /><label class="form-check-label">@Localizer["EnableFingerprint"]</label></div></div>
            <div class="col-md-4"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="HrEnableSelfService" value="true" @(Model.HrEnableSelfService ? "checked" : "") /><label class="form-check-label">@Localizer["EnableSelfService"]</label></div></div>
        </div>

        <h6 class="mb-3"><i class="fas fa-clock me-1 text-warning"></i>@Localizer["WorkSchedule"]</h6>
        <div class="row g-3 mb-4">
            <div class="col-md-3"><label class="form-label">@Localizer["WorkDayStart"]</label><input type="time" name="HrWorkDayStart" class="form-control" value="@Model.HrWorkDayStart.ToString(@"hh\:mm")" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["WorkDayEnd"]</label><input type="time" name="HrWorkDayEnd" class="form-control" value="@Model.HrWorkDayEnd.ToString(@"hh\:mm")" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["WorkingDaysPerMonth"]</label><input type="number" name="HrWorkingDaysPerMonth" class="form-control" value="@Model.HrWorkingDaysPerMonth" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["LateGracePeriod"] (@Localizer["Minutes"])</label><input type="number" name="HrLateGracePeriodMinutes" class="form-control" value="@Model.HrLateGracePeriodMinutes" /></div>
        </div>

        <h6 class="mb-3"><i class="fas fa-business-time me-1 text-info"></i>@Localizer["OvertimeSettings"]</h6>
        <div class="row g-3 mb-4">
            <div class="col-md-4"><label class="form-label">@Localizer["MaxOvertimeHours"]</label><input type="number" name="HrMaxOvertimeHoursPerMonth" class="form-control" value="@Model.HrMaxOvertimeHoursPerMonth" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["OvertimeMultiplier"]</label><input type="number" step="0.01" name="HrOvertimeRateMultiplier" class="form-control" value="@Model.HrOvertimeRateMultiplier" /></div>
        </div>

        <h6 class="mb-3"><i class="fas fa-calculator me-1 text-danger"></i>@Localizer["DeductionSettings"]</h6>
        <div class="row g-3 mb-4">
            <div class="col-md-3"><label class="form-label">@Localizer["AbsenceDeductionPerDay"]</label><input type="number" step="0.01" name="HrAbsenceDeductionPerDay" class="form-control" value="@Model.HrAbsenceDeductionPerDay" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["AbsenceDeductionType"]</label><input type="text" name="HrAbsenceDeductionType" class="form-control" value="@Model.HrAbsenceDeductionType" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["LateDeductionPerMinute"]</label><input type="number" step="0.01" name="HrLateDeductionPerMinute" class="form-control" value="@Model.HrLateDeductionPerMinute" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["EarlyLeaveDeduction"]</label><input type="number" step="0.01" name="HrEarlyLeaveDeductionPerMinute" class="form-control" value="@Model.HrEarlyLeaveDeductionPerMinute" /></div>
        </div>

        <h6 class="mb-3"><i class="fas fa-money-bill me-1 text-success"></i>@Localizer["SalarySettings"]</h6>
        <div class="row g-3 mb-4">
            <div class="col-md-4"><label class="form-label">@Localizer["SalaryCalculationMethod"]</label><input type="text" name="HrSalaryCalculationMethod" class="form-control" value="@Model.HrSalaryCalculationMethod" /></div>
        </div>

        <div class="mt-4"><button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button></div>
    </form>
</div>
