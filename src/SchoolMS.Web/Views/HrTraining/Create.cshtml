@model SchoolMS.Application.DTOs.HrTrainingProgramDto
@{ ViewData["Title"] = (Model?.Id > 0 ? Localizer["Edit"] : Localizer["Add"]).Value + " " + Localizer["TrainingProgram"].Value; }

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas fa-graduation-cap me-2 text-primary"></i>@ViewData["Title"]</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(Model?.Id > 0 ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (Model?.Id > 0) { <input type="hidden" name="Id" value="@Model.Id" /> }
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">@Localizer["Name"] *</label><input type="text" name="ProgramName" class="form-control" value="@Model?.ProgramName" required /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Category"]</label><input type="text" name="Category" class="form-control" value="@Model?.Category" /></div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Status"]</label>
                <select name="Status" class="form-select">@foreach (var s in Enum.GetValues<TrainingStatus>()) { <option value="@s" selected="@(Model?.Status == s)">@s</option> }</select>
            </div>
            <div class="col-md-4"><label class="form-label">@Localizer["Provider"]</label><input type="text" name="Provider" class="form-control" value="@Model?.Provider" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Trainer"]</label><input type="text" name="Trainer" class="form-control" value="@Model?.Trainer" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Location"]</label><input type="text" name="Location" class="form-control" value="@Model?.Location" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["StartDate"] *</label><input type="date" name="StartDate" class="form-control" value="@(Model?.StartDate.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd"))" required /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["EndDate"] *</label><input type="date" name="EndDate" class="form-control" value="@(Model?.EndDate.ToString("yyyy-MM-dd") ?? DateTime.Today.AddDays(5).ToString("yyyy-MM-dd"))" required /></div>
            <div class="col-md-2"><label class="form-label">@Localizer["Hours"]</label><input type="number" name="DurationHours" class="form-control" value="@(Model?.DurationHours ?? 0)" /></div>
            <div class="col-md-2"><label class="form-label">@Localizer["MaxParticipants"]</label><input type="number" name="MaxParticipants" class="form-control" value="@(Model?.MaxParticipants ?? 30)" /></div>
            <div class="col-md-2"><label class="form-label">@Localizer["Cost"]</label><input type="number" step="0.01" name="Cost" class="form-control" value="@Model?.Cost" /></div>
            <div class="col-12"><div class="form-check"><input class="form-check-input" type="checkbox" name="IsMandatory" value="true" @(Model?.IsMandatory == true ? "checked" : "") /><label class="form-check-label">@Localizer["Mandatory"]</label></div></div>
            <div class="col-12"><label class="form-label">@Localizer["Description"]</label><textarea name="Description" class="form-control" rows="3">@Model?.Description</textarea></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button></div>
    </form>
</div>
