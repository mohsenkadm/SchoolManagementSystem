@using SchoolMS.Application.DTOs
@{
    var employees = ViewBag.Employees as List<HrEmployeeDto> ?? new();
    int programId = ViewBag.ProgramId ?? 0;
    ViewData["Title"] = Localizer["EnrollEmployee"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas fa-user-plus me-2 text-primary"></i>@Localizer["EnrollEmployee"]</h4>
    <a href="@Url.Action("Records", new { programId })" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="Enroll" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="TrainingProgramId" value="@programId" />
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">@Localizer["Employee"] *</label>
                <select name="EmployeeId" class="form-select select2" required><option value="">—</option>@foreach (var e in employees) { <option value="@e.Id">@e.FullName</option> }</select>
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["Status"]</label>
                <select name="Status" class="form-select">@foreach (var s in Enum.GetValues<TrainingParticipantStatus>()) { <option value="@s">@s</option> }</select>
            </div>
            <div class="col-md-4"><label class="form-label">@Localizer["Score"]</label><input type="number" step="0.01" name="Score" class="form-control" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Rating"] (1-5)</label><input type="number" name="Rating" class="form-control" min="1" max="5" /></div>
            <div class="col-md-4"><div class="form-check mt-4"><input class="form-check-input" type="checkbox" name="CertificateIssued" value="true" /><label class="form-check-label">@Localizer["CertificateIssued"]</label></div></div>
            <div class="col-12"><label class="form-label">@Localizer["Feedback"]</label><textarea name="Feedback" class="form-control" rows="2"></textarea></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Enroll"]</button></div>
    </form>
</div>
