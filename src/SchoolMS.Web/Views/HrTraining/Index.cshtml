@model List<SchoolMS.Application.DTOs.HrTrainingProgramDto>
@{ ViewData["Title"] = Localizer["HrTraining"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-graduation-cap text-primary"></i> @Localizer["HrTraining"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions">
        <a href="@Url.Action("Records")" class="btn btn-secondary"><i class="fas fa-users me-1"></i>@Localizer["Records"]</a>
        <a href="@Url.Action("Requests")" class="btn btn-info"><i class="fas fa-paper-plane me-1"></i>@Localizer["Requests"]</a>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["Add"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-calendar"></i></div><div class="stat-info"><h6>@Localizer["Planned"]</h6><div class="stat-value">@Model.Count(t => t.Status == TrainingStatus.Planned)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-spinner"></i></div><div class="stat-info"><h6>@Localizer["InProgress"]</h6><div class="stat-value">@Model.Count(t => t.Status == TrainingStatus.InProgress)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-double"></i></div><div class="stat-info"><h6>@Localizer["Completed"]</h6><div class="stat-value">@Model.Count(t => t.Status == TrainingStatus.Completed)</div></div></div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Name"]</th><th>@Localizer["Category"]</th><th>@Localizer["Provider"]</th><th>@Localizer["StartDate"]</th><th>@Localizer["EndDate"]</th><th>@Localizer["Participants"]</th><th>@Localizer["Status"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var t = Model[i];
                var cls = t.Status switch { TrainingStatus.Planned => "bg-warning", TrainingStatus.InProgress => "bg-primary", TrainingStatus.Completed => "bg-success", TrainingStatus.Cancelled => "bg-danger", _ => "bg-secondary" };
                <tr>
                    <td>@(i + 1)</td><td>@t.ProgramName @if (t.IsMandatory) { <span class="badge bg-danger ms-1">@Localizer["Mandatory"]</span> }</td>
                    <td>@t.Category</td><td>@t.Provider</td>
                    <td>@t.StartDate.ToString("dd/MM/yyyy")</td><td>@t.EndDate.ToString("dd/MM/yyyy")</td>
                    <td><span class="badge bg-info">@t.ParticipantCount / @t.MaxParticipants</span></td>
                    <td><span class="badge @cls">@t.Status</span></td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Details", new { id = t.Id })" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a href="@Url.Action("Edit", new { id = t.Id })" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a href="@Url.Action("Enroll", new { programId = t.Id })" class="btn btn-sm btn-success"><i class="fas fa-user-plus"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@t.Id)"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    $(function () { $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' }); });
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
