@model List<SchoolMS.Application.DTOs.HrTrainingRecordDto>
@{ ViewData["Title"] = Localizer["TrainingRecords"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-users text-primary"></i> @Localizer["TrainingRecords"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions"><a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a></div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Employee"]</th><th>@Localizer["Program"]</th><th>@Localizer["Status"]</th><th>@Localizer["Score"]</th><th>@Localizer["Certificate"]</th><th>@Localizer["Rating"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var r = Model[i];
                var cls = r.Status switch { TrainingParticipantStatus.Completed => "bg-success", TrainingParticipantStatus.Enrolled => "bg-info", TrainingParticipantStatus.Attended => "bg-primary", TrainingParticipantStatus.Failed => "bg-danger", TrainingParticipantStatus.NoShow => "bg-dark", _ => "bg-secondary" };
                <tr>
                    <td>@(i + 1)</td><td>@r.EmployeeName</td><td>@r.ProgramName</td>
                    <td><span class="badge @cls">@r.Status</span></td>
                    <td>@(r.Score?.ToString("N1") ?? "—")</td>
                    <td>@(r.CertificateIssued ? "✅ " + r.CertificateNumber : "❌")</td>
                    <td>
                        @if (r.Rating.HasValue)
                        {
                            @for (int s = 1; s <= 5; s++) { <i class="fas fa-star @(s <= r.Rating ? "text-warning" : "text-muted")"></i> }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>$(function () { $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' }); });</script>
}
