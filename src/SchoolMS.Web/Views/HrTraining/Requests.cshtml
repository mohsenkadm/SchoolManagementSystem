@model List<SchoolMS.Application.DTOs.HrTrainingRequestDto>
@{ ViewData["Title"] = Localizer["TrainingRequests"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div><h4 class="page-title"><i class="fas fa-paper-plane text-primary"></i> @Localizer["TrainingRequests"]</h4><span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span></div>
    <div class="page-actions"><a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a></div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-hourglass-half"></i></div><div class="stat-info"><h6>@Localizer["Pending"]</h6><div class="stat-value">@Model.Count(r => r.Status == TrainingRequestStatus.Pending)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check"></i></div><div class="stat-info"><h6>@Localizer["Approved"]</h6><div class="stat-value">@Model.Count(r => r.Status == TrainingRequestStatus.Approved)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-times"></i></div><div class="stat-info"><h6>@Localizer["Rejected"]</h6><div class="stat-value">@Model.Count(r => r.Status == TrainingRequestStatus.Rejected)</div></div></div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Employee"]</th><th>@Localizer["Training"]</th><th>@Localizer["Category"]</th><th>@Localizer["Cost"]</th><th>@Localizer["PreferredDate"]</th><th>@Localizer["Status"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var r = Model[i];
                var cls = r.Status switch { TrainingRequestStatus.Pending => "bg-warning", TrainingRequestStatus.Approved => "bg-success", TrainingRequestStatus.Rejected => "bg-danger", TrainingRequestStatus.Scheduled => "bg-info", _ => "bg-secondary" };
                <tr>
                    <td>@(i + 1)</td><td>@r.EmployeeName</td><td>@r.RequestedTraining</td><td>@r.Category</td>
                    <td>@(r.EstimatedCost?.ToString("N0") ?? "—")</td>
                    <td>@(r.PreferredStartDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                    <td><span class="badge @cls">@r.Status</span></td>
                    <td>
                        @if (r.Status == TrainingRequestStatus.Pending)
                        {
                            <form asp-action="ApproveRequest" method="post" class="d-inline"><input type="hidden" name="id" value="@r.Id" /><button class="btn btn-sm btn-success"><i class="fas fa-check"></i></button></form>
                            <form asp-action="RejectRequest" method="post" class="d-inline"><input type="hidden" name="id" value="@r.Id" /><button class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button></form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>$(function () { $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' }); });</script>
}
