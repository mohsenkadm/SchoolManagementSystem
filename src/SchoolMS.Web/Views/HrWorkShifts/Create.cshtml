@using SchoolMS.Application.DTOs
@{ var isEdit = Model != null; var item = isEdit ? (HrWorkShiftDto)Model : null; }

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["Edit"] : Localizer["Add"]) @Localizer["WorkShift"]</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label">@Localizer["Name"] *</label><input type="text" name="ShiftName" class="form-control" value="@item?.ShiftName" required /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["NameAr"]</label><input type="text" name="ShiftNameAr" class="form-control" value="@item?.ShiftNameAr" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Code"]</label><input type="text" name="ShiftCode" class="form-control" value="@item?.ShiftCode" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["StartTime"] *</label><input type="time" name="StartTime" class="form-control" value="@item?.StartTime.ToString(@"hh\:mm")" required /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["EndTime"] *</label><input type="time" name="EndTime" class="form-control" value="@item?.EndTime.ToString(@"hh\:mm")" required /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["WorkingHours"]</label><input type="number" step="0.5" name="TotalWorkHours" class="form-control" value="@item?.TotalWorkHours" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["LateGraceMinutes"]</label><input type="number" name="GracePeriodMinutes" class="form-control" value="@(item?.GracePeriodMinutes ?? 15)" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["EarlyLeaveMinutes"]</label><input type="number" name="EarlyLeaveGraceMinutes" class="form-control" value="@(item?.EarlyLeaveGraceMinutes ?? 15)" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["BreakMinutes"]</label><input type="number" name="BreakDurationMinutes" class="form-control" value="@item?.BreakDurationMinutes" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["BreakStart"]</label><input type="time" name="BreakStartTime" class="form-control" value="@item?.BreakStartTime?.ToString(@"hh\:mm")" /></div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Active"]</label>
                <div class="form-check form-switch mt-2"><input class="form-check-input" type="checkbox" name="IsActive" value="true" @(item?.IsActive != false ? "checked" : "") /></div>
            </div>
            <div class="col-12"><label class="form-label">@Localizer["WorkingDays"]</label><input type="text" name="WorkingDays" class="form-control" value="@item?.WorkingDays" placeholder="Sun,Mon,Tue,Wed,Thu" /></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
