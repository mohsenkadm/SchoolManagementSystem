@using SchoolMS.Application.DTOs
@model List<FeeInstallmentDto>
@{ ViewData["Title"] = Localizer["Installments"].Value; }
@Html.AntiForgeryToken()
@{
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var allPayments = Model.SelectMany(m => m.Payments).ToList();
    var paidCount = allPayments.Count(p => p.Status == PaymentStatus.Paid);
    var pendingCount = allPayments.Count(p => p.Status != PaymentStatus.Paid);
    var paidAmt = allPayments.Where(p => p.Status == PaymentStatus.Paid).Sum(p => p.Amount);
    var pendingAmt = allPayments.Where(p => p.Status != PaymentStatus.Paid).Sum(p => p.Amount);
    var totalAmt = Model.Sum(m => m.TotalAmount);
}

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-file-invoice-dollar text-primary"></i>@Localizer["Installments"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-primary" onclick="printSchedule()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
        <a href="@Url.Action("PaymentsReport")" class="btn btn-info"><i class="fas fa-list-alt me-1"></i>@Localizer["PaymentsReport"]</a>
        <a href="@Url.Action("StudentReport")" class="btn btn-warning"><i class="fas fa-user-graduate me-1"></i>@Localizer["StudentReport"]</a>
        <a href="@Url.Action("ExportExcel")" class="btn btn-success"><i class="fas fa-file-excel me-1"></i>@Localizer["Export"]</a>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddInstallment"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-file-invoice-dollar"></i></div><div class="stat-info"><h6>@Localizer["TotalAmount"]</h6><div class="stat-value">@totalAmt.ToString("N0")</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-circle"></i></div><div class="stat-info"><h6>@Localizer["PaidAmount"]</h6><div class="stat-value text-success">@paidAmt.ToString("N0")</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-times-circle"></i></div><div class="stat-info"><h6>@Localizer["UnpaidAmount"]</h6><div class="stat-value text-danger">@pendingAmt.ToString("N0")</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-receipt"></i></div><div class="stat-info"><h6>@Localizer["PaidPayments"]</h6><div class="stat-value">@paidCount</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-clock"></i></div><div class="stat-info"><h6>@Localizer["PendingPayments"]</h6><div class="stat-value">@pendingCount</div></div></div>
</div>

<div class="row mb-4" data-aos="fade-up">
    <div class="col-lg-5">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-pie me-2 text-primary"></i>@Localizer["PaymentStatus"]</h6><canvas id="chartPayStatus" height="220"></canvas></div>
    </div>
    <div class="col-lg-7">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-bar me-2 text-primary"></i>@Localizer["AmountBreakdown"]</h6><canvas id="chartPayAmount" height="220"></canvas></div>
    </div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-3"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["SearchStudent"]..." /></div>
        <div class="col-md-2"><select id="filterYear" class="form-select"><option value="">@Localizer["AllYears"]</option>@foreach (var y in Model.Select(m => m.AcademicYearName).Distinct().OrderBy(y => y)) { <option value="@y">@y</option> }</select></div>
        <div class="col-md-2"><select id="filterPayStatus" class="form-select"><option value="">@Localizer["All"]</option><option value="fully-paid">@Localizer["FullyPaid"]</option><option value="has-pending">@Localizer["HasPending"]</option></select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up" id="printArea">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Student"]</th><th>@Localizer["TotalAmount"]</th><th>@Localizer["PaidAmount"]</th><th>@Localizer["Remaining"]</th><th>@Localizer["Progress"]</th><th>@Localizer["AcademicYear"]</th>@if (isSuperAdmin) { <th>@Localizer["School"]</th> }<th class="no-print">@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var paid = Model[i].Payments.Where(p => p.Status == PaymentStatus.Paid).Sum(p => p.Amount);
                var remaining = Model[i].TotalAmount - paid;
                var pct = Model[i].TotalAmount > 0 ? (int)(paid / Model[i].TotalAmount * 100) : 0;
                var barCls = pct == 100 ? "bg-success" : pct >= 50 ? "bg-info" : pct > 0 ? "bg-warning" : "bg-danger";
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td><strong>@Model[i].StudentName</strong></td>
                    <td class="fw-bold">@Model[i].TotalAmount.ToString("N0")</td>
                    <td class="text-success fw-bold">@paid.ToString("N0")</td>
                    <td class="text-danger fw-bold">@remaining.ToString("N0")</td>
                    <td style="min-width:140px"><div class="progress" style="height:20px"><div class="progress-bar @barCls" style="width:@(pct)%">@(pct)%</div></div></td>
                    <td>@Model[i].AcademicYearName</td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td class="no-print">
                        <div class="action-group">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn-act btn-act-edit" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<style media="print">
    .page-header, .stat-ribbon, .filter-panel, .no-print, nav, .sidebar, footer, .row.mb-4 { display: none !important; }
    .table-card { box-shadow: none !important; border: none !important; }
    table { font-size: 12px; }
    th, td { padding: 4px 8px !important; }
</style>
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var yearColIdx = 6;
    var schoolColIdx = isSuperAdmin ? 7 : -1;
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
        new Chart(document.getElementById('chartPayStatus'), { type: 'doughnut', data: { labels: ['Paid', 'Pending'], datasets: [{ data: [@paidCount, @pendingCount], backgroundColor: ['#22c55e','#f59e0b'], borderWidth: 0 }] }, options: { responsive: true, plugins: { legend: { position: 'bottom' } } } });
        new Chart(document.getElementById('chartPayAmount'), { type: 'bar', data: { labels: ['Paid', 'Pending'], datasets: [{ label: 'Amount', data: [@paidAmt.ToString("F0"), @pendingAmt.ToString("F0")], backgroundColor: ['#22c55e','#f59e0b'], borderRadius: 8 }] }, options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
    });
    function applyFilters() {
        dt.search($('#searchInput').val());
        dt.column(yearColIdx).search($('#filterYear').val());
        if (isSuperAdmin) { dt.column(schoolColIdx).search($('#filterSchool').val()); }
        var payFilter = $('#filterPayStatus').val();
        if (payFilter === 'fully-paid') { dt.column(5).search('100%'); }
        else if (payFilter === 'has-pending') { dt.column(5).search('').draw(); dt.rows().every(function () { var d = this.data(); if (d[5] && d[5].indexOf('100%') !== -1) { $(this.node()).hide(); } else { $(this.node()).show(); } }); }
        else { dt.column(5).search(''); }
        dt.draw();
    }
    function resetFilters() {
        $('#searchInput, #filterYear, #filterPayStatus').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
        dt.rows().every(function () { $(this.node()).show(); });
    }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
    function printSchedule() { window.print(); }
</script>
}
