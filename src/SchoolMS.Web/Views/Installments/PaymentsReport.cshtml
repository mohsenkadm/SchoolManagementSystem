@using SchoolMS.Application.DTOs
@model List<InstallmentPaymentDto>
@{ ViewData["Title"] = Localizer["PaymentsReport"].Value; }
@Html.AntiForgeryToken()
@{
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var currentFilter = ViewBag.CurrentFilter as string;
    var paidItems = Model.Where(p => p.Status == PaymentStatus.Paid).ToList();
    var pendingItems = Model.Where(p => p.Status != PaymentStatus.Paid).ToList();
    var overdueItems = Model.Where(p => p.Status == PaymentStatus.Overdue).ToList();
    var totalAmt = Model.Sum(p => p.Amount);
    var paidAmt = paidItems.Sum(p => p.Amount);
    var pendingAmt = pendingItems.Sum(p => p.Amount);
}

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-list-alt text-primary"></i>@Localizer["PaymentsReport"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
        <a href="@Url.Action("ExportPaymentsExcel", new { status = currentFilter })" class="btn btn-success"><i class="fas fa-file-excel me-1"></i>@Localizer["Export"]</a>
        <button class="btn btn-outline-primary" onclick="printSchedule()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-receipt"></i></div><div class="stat-info"><h6>@Localizer["TotalPayments"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-circle"></i></div><div class="stat-info"><h6>@Localizer["Paid"]</h6><div class="stat-value text-success">@paidItems.Count (@paidAmt.ToString("N0"))</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-clock"></i></div><div class="stat-info"><h6>@Localizer["Pending"]</h6><div class="stat-value text-warning">@pendingItems.Count (@pendingAmt.ToString("N0"))</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-exclamation-triangle"></i></div><div class="stat-info"><h6>@Localizer["Overdue"]</h6><div class="stat-value text-danger">@overdueItems.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-coins"></i></div><div class="stat-info"><h6>@Localizer["TotalAmount"]</h6><div class="stat-value">@totalAmt.ToString("N0")</div></div></div>
</div>

<div class="row mb-4" data-aos="fade-up">
    <div class="col-lg-5">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-pie me-2 text-primary"></i>@Localizer["PaymentStatus"]</h6><canvas id="chartStatus" height="220"></canvas></div>
    </div>
    <div class="col-lg-7">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-bar me-2 text-primary"></i>@Localizer["AmountBreakdown"]</h6><canvas id="chartAmount" height="220"></canvas></div>
    </div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["SearchStudent"]..." /></div>
        <div class="col-md-2">
            <select id="filterStatus" class="form-select" onchange="location.href='@Url.Action("PaymentsReport")?status='+this.value">
                @{ var statuses = new[] { ("", "AllStatuses"), ("paid", "Paid"), ("pending", "Pending"), ("overdue", "Overdue") }; }
                @foreach (var (val, key) in statuses)
                {
                    <option value="@val" selected="@(currentFilter == (val == "" ? null : val))">@Localizer[key]</option>
                }
            </select>
        </div>
        <div class="col-md-2"><select id="filterGrade" class="form-select"><option value="">@Localizer["AllGrades"]</option>@foreach (var g in Model.Select(p => p.GradeName).Where(g => g != null).Distinct().OrderBy(g => g)) { <option value="@g">@g</option> }</select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up" id="printArea">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr><th>#</th><th>@Localizer["Student"]</th><th>@Localizer["Grade"]</th><th>@Localizer["Division"]</th><th>@Localizer["Phone"]</th><th>@Localizer["Payment"] #</th><th>@Localizer["Amount"]</th><th>@Localizer["DueDate"]</th><th>@Localizer["PaidDate"]</th><th>@Localizer["Status"]</th>@if (isSuperAdmin) { <th>@Localizer["School"]</th> }<th class="no-print">@Localizer["Actions"]</th></tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var p = Model[i];
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td><strong>@p.StudentName</strong></td>
                    <td>@p.GradeName</td>
                    <td>@p.DivisionName</td>
                    <td>@p.Phone</td>
                    <td>@p.PaymentNumber</td>
                    <td class="fw-bold">@p.Amount.ToString("N0")</td>
                    <td>@p.DueDate.ToString("yyyy-MM-dd")</td>
                    <td>@(p.PaidDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                    <td>
                        @if (p.Status == PaymentStatus.Paid) { <span class="badge bg-success"><i class="fas fa-check me-1"></i>@Localizer["Paid"]</span> }
                        else if (p.Status == PaymentStatus.Overdue) { <span class="badge bg-danger"><i class="fas fa-exclamation-triangle me-1"></i>@Localizer["Overdue"]</span> }
                        else { <span class="badge bg-warning"><i class="fas fa-clock me-1"></i>@Localizer["Pending"]</span> }
                    </td>
                    @if (isSuperAdmin) { <td>@p.SchoolName</td> }
                    <td class="no-print">
                        <div class="action-group">
                            @if (p.Status != PaymentStatus.Paid)
                            {
                                <button class="btn-act btn-act-success" onclick="payAction(@p.Id, 'record')" data-bs-toggle="tooltip" title="@Localizer["MarkPaid"]"><i class="fas fa-check"></i></button>
                            }
                            else
                            {
                                <button class="btn-act btn-act-warning" onclick="payAction(@p.Id, 'cancel')" data-bs-toggle="tooltip" title="@Localizer["CancelPayment"]"><i class="fas fa-undo"></i></button>
                                <button class="btn-act btn-act-print" onclick="printReceipt(@i)" data-bs-toggle="tooltip" title="@Localizer["PrintReceipt"]"><i class="fas fa-print"></i></button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<style media="print">
    .page-header, .stat-ribbon, .filter-panel, .no-print, nav, .sidebar, footer, .row.mb-4 { display: none !important; }
    .table-card { box-shadow: none !important; border: none !important; }
    table { font-size: 12px; }
    th, td { padding: 4px 8px !important; }
</style>
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var gradeColIdx = 2, schoolColIdx = isSuperAdmin ? 10 : -1;
    var dt;
    var payments = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(p => new { p.StudentName, p.PaymentNumber, Amount = p.Amount.ToString("N0"), DueDate = p.DueDate.ToString("yyyy-MM-dd"), PaidDate = p.PaidDate?.ToString("yyyy-MM-dd") ?? "—" })));

    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
        new Chart(document.getElementById('chartStatus'), { type: 'doughnut', data: { labels: ['Paid', 'Pending', 'Overdue'], datasets: [{ data: [@paidItems.Count, @(pendingItems.Count - overdueItems.Count), @overdueItems.Count], backgroundColor: ['#22c55e','#f59e0b','#ef4444'], borderWidth: 0 }] }, options: { responsive: true, plugins: { legend: { position: 'bottom' } } } });
        new Chart(document.getElementById('chartAmount'), { type: 'bar', data: { labels: ['Paid', 'Pending'], datasets: [{ label: 'Amount', data: [@paidAmt.ToString("F0"), @pendingAmt.ToString("F0")], backgroundColor: ['#22c55e','#f59e0b'], borderRadius: 8 }] }, options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
    });

    function applyFilters() {
        dt.search($('#searchInput').val());
        dt.column(gradeColIdx).search($('#filterGrade').val());
        if (isSuperAdmin) { dt.column(schoolColIdx).search($('#filterSchool').val()); }
        dt.draw();
    }
    function resetFilters() {
        $('#searchInput, #filterGrade').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }

    function payAction(id, action) {
        var url = action === 'record' ? '@Url.Action("RecordPayment")' : '@Url.Action("CancelPayment")';
        if (!confirm(action === 'record' ? 'Mark as paid?' : 'Cancel payment?')) return;
        $.ajax({
            url: url, type: 'POST', data: { paymentId: id },
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            success: function () { toastr.success(action === 'record' ? 'Payment recorded' : 'Payment cancelled'); location.reload(); },
            error: function () { toastr.error('An error occurred'); }
        });
    }

    function printReceipt(idx) {
        var p = payments[idx];
        var html = '<html><head><title>Receipt</title><style>body{font-family:Arial;max-width:400px;margin:auto;padding:20px}table{width:100%;font-size:14px}td{padding:4px}h3{text-align:center}</style></head><body>';
        html += '<h3>Payment Receipt</h3><hr>';
        html += '<table><tr><td><b>Student:</b></td><td>' + p.studentName + '</td></tr>';
        html += '<tr><td><b>Payment #:</b></td><td>' + p.paymentNumber + '</td></tr>';
        html += '<tr><td><b>Amount:</b></td><td>' + p.amount + '</td></tr>';
        html += '<tr><td><b>Due Date:</b></td><td>' + p.dueDate + '</td></tr>';
        html += '<tr><td><b>Paid Date:</b></td><td>' + p.paidDate + '</td></tr></table>';
        html += '<hr><p style="text-align:center;font-size:12px;color:#666">Thank you for your payment</p>';
        html += '<script>window.print();window.close();<\/script></body></html>';
        var w = window.open('', '_blank', 'width=500,height=500');
        w.document.write(html);
        w.document.close();
    }

    function printSchedule() { window.print(); }
</script>
}
