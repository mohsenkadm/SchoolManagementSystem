@model List<SchoolMS.Application.DTOs.LeaveRequestDto>
@{ ViewData["Title"] = Localizer["Leaves"].Value; }
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-calendar-minus text-primary"></i>@Localizer["Leaves"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddLeave"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-clock"></i></div><div class="stat-info"><h6>@Localizer["Pending"]</h6><div class="stat-value">@Model.Count(l => l.Status == LeaveStatus.Pending)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-circle"></i></div><div class="stat-info"><h6>@Localizer["Approved"]</h6><div class="stat-value">@Model.Count(l => l.Status == LeaveStatus.Approved)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-times-circle"></i></div><div class="stat-info"><h6>@Localizer["Rejected"]</h6><div class="stat-value">@Model.Count(l => l.Status == LeaveStatus.Rejected)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        <div class="col-md-4"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-3"><select id="filterStatus" class="form-select"><option value="">@Localizer["AllStatuses"]</option><option value="Pending">@Localizer["Pending"]</option><option value="Approved">@Localizer["Approved"]</option><option value="Rejected">@Localizer["Rejected"]</option></select></div>
        <div class="col-md-2"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i> @Localizer["Filter"]</button></div>
        <div class="col-md-3"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i> @Localizer["Reset"]</button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Person"]</th><th>@Localizer["Type"]</th><th>@Localizer["StartDate"]</th><th>@Localizer["EndDate"]</th><th>@Localizer["Reason"]</th><th>@Localizer["Status"]</th><th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var sBadge = Model[i].Status == LeaveStatus.Approved ? "bg-success" : Model[i].Status == LeaveStatus.Rejected ? "bg-danger" : "bg-warning";
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td>@Model[i].PersonName</td><td>@Model[i].PersonType</td><td>@Model[i].StartDate.ToString("yyyy-MM-dd")</td><td>@Model[i].EndDate.ToString("yyyy-MM-dd")</td><td>@Model[i].Reason</td><td><span class="badge @sBadge">@Model[i].Status</span></td>
                    <td>
                        <div class="d-flex gap-1">
                            @if (Model[i].Status == LeaveStatus.Pending)
                            {
                                <button class="btn btn-sm btn-success" onclick="approve(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Approve"]"><i class="fas fa-check"></i></button>
                                <button class="btn btn-sm btn-warning" onclick="reject(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Reject"]"><i class="fas fa-times"></i></button>
                            }
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<script>
    var dt;
    $(function () { dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip', order: [[3, 'desc']] }); $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); }); });
    function applyFilters() { dt.search($('#searchInput').val()); dt.column(6).search($('#filterStatus').val()); dt.draw(); }
    function resetFilters() { $('#searchInput, #filterStatus').val(''); dt.search('').columns().search('').draw(); }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
    function approve(id) { $.ajax({ url: '@Url.Action("Approve")?id=' + id, type: 'POST', headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }, success: function () { toastr.success('Approved'); location.reload(); } }); }
    function reject(id) { $.ajax({ url: '@Url.Action("Reject")?id=' + id, type: 'POST', headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }, success: function () { toastr.success('Rejected'); location.reload(); } }); }
</script>
}
