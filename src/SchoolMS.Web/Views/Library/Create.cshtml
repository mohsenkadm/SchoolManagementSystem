@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (LibraryBookDto)Model : null;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditBook"] : Localizer["AddBook"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-3">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select id="schoolSelect" name="SchoolId" class="form-select select2" required>
                        <option value="">-- @Localizer["Select"] --</option>
                        @foreach (var s in schools) { <option value="@s.Id" selected="@(item?.SchoolId == s.Id)">@s.Name</option> }
                    </select>
                </div>
            }
            <div class="col-md-6"><label class="form-label">@Localizer["Title"] *</label><input type="text" name="Title" class="form-control" value="@item?.Title" required /></div>
            <div class="col-md-6"><label class="form-label">@Localizer["Author"]</label><input type="text" name="Author" class="form-control" value="@item?.Author" /></div>
            <div class="col-md-4"><label class="form-label">ISBN</label><input type="text" name="ISBN" class="form-control" value="@item?.ISBN" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Publisher"]</label><input type="text" name="Publisher" class="form-control" value="@item?.Publisher" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Category"]</label><input type="text" name="Category" class="form-control" value="@item?.Category" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["ShelfLocation"]</label><input type="text" name="ShelfLocation" class="form-control" value="@item?.ShelfLocation" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["TotalCopies"] *</label><input type="number" name="TotalCopies" class="form-control" value="@(item?.TotalCopies ?? 1)" required min="1" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Barcode"]</label><input type="text" name="Barcode" class="form-control" value="@item?.Barcode" /></div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Branch"] *</label>
                <select id="branchSelect" name="BranchId" class="form-select" required>
                    @foreach (var b in branches) { <option value="@b.Id" selected="@(item?.BranchId == b.Id)">@b.Name</option> }
                </select>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
@if (isSuperAdmin)
{
    @section Scripts {
    <script>
        $(function () {
            $('#schoolSelect').on('change', function () {
                var schoolId = $(this).val();
                var $branch = $('#branchSelect');
                $branch.html('');
                if (schoolId) {
                    $.getJSON('@Url.Action("GetBranchesBySchool")', { schoolId: schoolId }, function (data) {
                        $.each(data, function (_, b) { $branch.append('<option value="' + b.id + '">' + b.name + '</option>'); });
                    });
                }
            });
        });
    </script>
    }
}
