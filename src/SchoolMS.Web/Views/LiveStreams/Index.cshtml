@model List<SchoolMS.Application.DTOs.LiveStreamDto>
@using SchoolMS.Application.DTOs
@{
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}

@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-broadcast-tower text-danger"></i>@Localizer["LiveStreams"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["CreateLiveStream"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-calendar-check"></i></div><div class="stat-info"><h6>@Localizer["Scheduled"]</h6><div class="stat-value">@Model.Count(l => l.Status == LiveStreamStatus.Scheduled)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-circle"></i></div><div class="stat-info"><h6>@Localizer["Live"]</h6><div class="stat-value">@Model.Count(l => l.Status == LiveStreamStatus.Live)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-flag-checkered"></i></div><div class="stat-info"><h6>@Localizer["Ended"]</h6><div class="stat-value">@Model.Count(l => l.Status == LiveStreamStatus.Ended)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon" style="background:rgba(14,165,233,0.15);"><i class="fas fa-user-check" style="color:#0ea5e9;"></i></div><div class="stat-info"><h6>@Localizer["TotalSeen"]</h6><div class="stat-value">@Model.Sum(l => l.SeenCount)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2">
            <select id="filterSubject" class="form-select"><option value="">@Localizer["AllSubjects"]</option>
                @foreach (var s in Model.Select(l => l.SubjectName).Where(s => s != null).Distinct().OrderBy(s => s)) { <option value="@s">@s</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterCourse" class="form-select"><option value="">@Localizer["AllCourses"]</option>
                @foreach (var c in Model.Where(l => l.CourseTitle != null).Select(l => l.CourseTitle).Distinct().OrderBy(c => c)) { <option value="@c">@c</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterStatus" class="form-select"><option value="">@Localizer["AllStatuses"]</option>
                <option value="Scheduled">@Localizer["Scheduled"]</option>
                <option value="Live">@Localizer["Live"]</option>
                <option value="Ended">@Localizer["Ended"]</option>
            </select>
        </div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["Title"]</th>
                <th>@Localizer["Subject"]</th>
                <th>@Localizer["Course"]</th>
                <th>@Localizer["Teacher"]</th>
                <th>@Localizer["ScheduledAt"]</th>
                <th>@Localizer["Seen"]</th>
                <th>@Localizer["Status"]</th>
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var ls = Model[i];
                var statusBadge = ls.Status switch
                {
                    LiveStreamStatus.Scheduled => "bg-info",
                    LiveStreamStatus.Live => "bg-danger",
                    LiveStreamStatus.Ended => "bg-secondary",
                    _ => "bg-secondary"
                };
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td>@ls.Title</td>
                    <td>@ls.SubjectName</td>
                    <td>
                        @if (ls.IsStandalone)
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-broadcast-tower me-1"></i>@Localizer["Standalone"]</span>
                        }
                        else
                        {
                            @ls.CourseTitle
                        }
                    </td>
                    <td>@ls.TeacherName</td>
                    <td>@ls.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td><span class="badge" style="background:#0ea5e9;color:#fff;"><i class="fas fa-user-check me-1"></i>@ls.SeenCount</span></td>
                    <td>
                        <span class="badge @statusBadge">@ls.Status</span>
                    </td>
                    <td>
                        <div class="action-group">
                            <button class="btn-act btn-act-view" onclick="openChat(@ls.Id, '@ls.Title.Replace("'", "\\'")')" data-bs-toggle="tooltip" title="Chat">
                                <i class="fas fa-comments"></i>
                            </button>
                            @if (ls.Status == LiveStreamStatus.Scheduled)
                            {
                                <button class="btn-act btn-act-success" onclick="updateStatus(@ls.Id, @((int)LiveStreamStatus.Live))" data-bs-toggle="tooltip" title="@Localizer["GoLive"]">
                                    <i class="fas fa-play"></i>
                                </button>
                            }
                            @if (ls.Status == LiveStreamStatus.Live)
                            {
                                <button class="btn-act btn-act-warning" onclick="updateStatus(@ls.Id, @((int)LiveStreamStatus.Ended))" data-bs-toggle="tooltip" title="@Localizer["EndStream"]">
                                    <i class="fas fa-stop"></i>
                                </button>
                            }
                            <button class="btn-act btn-act-delete" onclick="del(@ls.Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Live Stream Chat Modal -->
<div class="modal fade" id="liveChatModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-comments me-2 text-info"></i><span id="liveChatTitle">Live Chat</span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" style="height:450px;display:flex;flex-direction:column;">
                <div id="liveChatMessages" style="flex:1;overflow-y:auto;padding:16px;background:#f8f9fa;">
                    <div class="text-center text-muted py-5">Select a live stream to view chat.</div>
                </div>
                <div class="border-top p-2 text-center text-muted small">
                    <i class="fas fa-eye me-1"></i>View-only mode — Chat is for students & teachers via the app
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var subjectCol = 2, courseCol = 3, statusCol = 7;
    var dt;
    $(function () { dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip', order: [[5, 'desc']] }); $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); }); });

    function applyFilters() {
        dt.search($('#searchInput').val());
        dt.column(subjectCol).search($('#filterSubject').val());
        dt.column(courseCol).search($('#filterCourse').val());
        dt.column(statusCol).search($('#filterStatus').val());
        if (isSuperAdmin) { /* school column filtering if needed */ }
        dt.draw();
    }
    function resetFilters() {
        $('#searchInput, #filterSubject, #filterCourse, #filterStatus').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }

    function updateStatus(id, status) {
        $.ajax({
            url: '@Url.Action("UpdateStatus")?id=' + id,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(status),
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            success: function () { toastr.success('Status updated'); location.reload(); },
            error: function () { toastr.error('Error updating status'); }
        });
    }

    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }

    /* ── Live Stream Chat ── */
    var liveConnection = new signalR.HubConnectionBuilder().withUrl('/hubs/livestream-chat').build();
    var currentLiveStreamId = null;

    liveConnection.on('ReceiveLiveComment', function (senderName, senderType, comment, time) {
        var t = new Date(time).toLocaleTimeString();
        var badgeClass = senderType === 'Teacher' ? 'text-danger' : 'text-primary';
        var icon = senderType === 'Teacher' ? '<i class="fas fa-chalkboard-teacher me-1"></i>' : '<i class="fas fa-user-graduate me-1"></i>';
        var html = '<div class="mb-2 p-2 rounded" style="background:#fff">' + icon + '<strong class="' + badgeClass + '">' + senderName + '</strong> <small class="text-muted">' + t + '</small><br/><span>' + comment + '</span></div>';
        $('#liveChatMessages').append(html);
        $('#liveChatMessages').scrollTop($('#liveChatMessages')[0].scrollHeight);
    });

    liveConnection.start().catch(function (err) { console.error('LiveStream SignalR error:', err); });

    function openChat(liveStreamId, title) {
        currentLiveStreamId = liveStreamId;
        if (currentLiveStreamId) liveConnection.invoke('LeaveLiveStream', currentLiveStreamId.toString()).catch(function () {});
        liveConnection.invoke('JoinLiveStream', liveStreamId.toString());
        $('#liveChatTitle').text(title);
        $('#liveChatMessages').html('<div class="text-center text-muted small py-2">Loading chat...</div>');

        $.getJSON('@Url.Action("GetComments")?liveStreamId=' + liveStreamId, function (comments) {
            $('#liveChatMessages').html('');
            if (comments.length === 0) {
                $('#liveChatMessages').html('<div class="text-center text-muted py-3">No messages yet.</div>');
            }
            $.each(comments, function (i, c) {
                var t = new Date(c.sentAt).toLocaleTimeString();
                var badgeClass = c.senderType === 'Teacher' ? 'text-danger' : 'text-primary';
                var icon = c.senderType === 'Teacher' ? '<i class="fas fa-chalkboard-teacher me-1"></i>' : '<i class="fas fa-user-graduate me-1"></i>';
                var html = '<div class="mb-2 p-2 rounded" style="background:#fff">' + icon + '<strong class="' + badgeClass + '">' + (c.senderName || 'Unknown') + '</strong> <small class="text-muted">' + t + '</small><br/><span>' + c.comment + '</span></div>';
                $('#liveChatMessages').append(html);
            });
            $('#liveChatMessages').scrollTop($('#liveChatMessages')[0].scrollHeight);
        });

        new bootstrap.Modal('#liveChatModal').show();
    }
</script>
}
