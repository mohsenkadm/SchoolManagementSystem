@using SchoolMS.Application.DTOs
@using SchoolMS.Domain.Enums
@{
    var isEdit = Model != null;
    var item = isEdit ? (OnlineSubscriptionPlanDto)Model : null;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var subjects = ViewBag.Subjects as List<SubjectDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditPlan"] : Localizer["AddPlan"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-6">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select name="SchoolId" class="form-select select2" required>
                        <option value="">-- @Localizer["Select"] --</option>
                        @foreach (var s in schools) { <option value="@s.Id" selected="@(item?.SchoolId == s.Id)">@s.Name</option> }
                    </select>
                </div>
            }
            <div class="col-md-6">
                <label class="form-label">@Localizer["PlanName"] *</label>
                <input type="text" name="PlanName" class="form-control" value="@item?.PlanName" required />
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["Subject"] *</label>
                <select name="SubjectId" class="form-select select2" required>
                    <option value="">-- @Localizer["Select"] --</option>
                    @foreach (var s in subjects) { <option value="@s.Id" selected="@(item?.SubjectId == s.Id)">@s.SubjectName</option> }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["SubscriptionType"] *</label>
                <select name="SubscriptionType" class="form-select" required>
                    @foreach (var st in Enum.GetValues<SubscriptionType>())
                    {
                        <option value="@((int)st)" selected="@(item?.SubscriptionType == st)">
                            @(st == SubscriptionType.Course ? Localizer["Course"] : Localizer["LiveStream"])
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["Price"] *</label>
                <input type="number" name="Price" class="form-control" step="0.01" value="@item?.Price" required />
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["DurationMonths"] *</label>
                <input type="number" name="DurationMonths" class="form-control" min="1" value="@item?.DurationMonths" required />
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
