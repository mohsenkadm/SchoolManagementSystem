@using SchoolMS.Application.DTOs
@using SchoolMS.Domain.Enums
@model List<OnlineSubscriptionPlanDto>
@{
    ViewData["Title"] = Localizer["OnlineSubscriptionPlans"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-tags text-primary"></i>@Localizer["OnlineSubscriptionPlans"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("ExportExcel")" class="btn btn-success"><i class="fas fa-file-excel me-1"></i>@Localizer["ExportExcel"]</a>
        <button class="btn btn-outline-secondary" onclick="window.print()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddPlan"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-tags"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-users"></i></div><div class="stat-info"><h6>@Localizer["TotalSubscribers"]</h6><div class="stat-value">@Model.Sum(p => p.StudentSubscriptionCount)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-book"></i></div><div class="stat-info"><h6>@Localizer["Subjects"]</h6><div class="stat-value">@Model.Select(p => p.SubjectName).Distinct().Count()</div></div></div>
</div>

@{
    var bySubject = Model.GroupBy(p => p.SubjectName ?? "Other").Select(g => new { Name = g.Key, Count = g.Count(), Subs = g.Sum(p => p.StudentSubscriptionCount) }).OrderByDescending(x => x.Count).ToList();
}

<div class="row mb-4" data-aos="fade-up">
    <div class="col-lg-4">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-pie me-2 text-primary"></i>@Localizer["PlansBySubject"]</h6><canvas id="chartSubject" height="220"></canvas></div>
    </div>
    <div class="col-lg-8">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-bar me-2 text-primary"></i>@Localizer["SubscribersBySubject"]</h6><canvas id="chartSubscribers" height="220"></canvas></div>
    </div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterBranch" class="form-select">
                <option value="">@Localizer["AllBranches"]</option>
                @foreach (var b in branches) { <option value="@b.Name">@b.Name</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterSubject" class="form-select">
                <option value="">@Localizer["AllSubjects"]</option>
                @foreach (var s in Model.Select(p => p.SubjectName).Distinct().OrderBy(s => s)) { <option value="@s">@s</option> }
            </select>
        </div>
        <div class="col-md-3">
            <input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." />
        </div>
        <div class="col-md-1">
            <button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button>
        </div>
        <div class="col-md-1">
            <button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button>
        </div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["PlanName"]</th>
                <th>@Localizer["Subject"]</th>
                <th>@Localizer["Type"]</th>
                <th>@Localizer["Price"]</th>
                <th>@Localizer["Duration"]</th>
                <th>@Localizer["Subscribers"]</th>
                @if (isSuperAdmin) { <th>@Localizer["School"]</th> }
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var typeBadge = Model[i].SubscriptionType == SubscriptionType.LiveStream ? "bg-danger" : "bg-primary";
                var typeIcon = Model[i].SubscriptionType == SubscriptionType.LiveStream ? "fa-broadcast-tower" : "fa-graduation-cap";
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td><strong>@Model[i].PlanName</strong></td>
                    <td>@Model[i].SubjectName</td>
                    <td><span class="badge @typeBadge"><i class="fas @typeIcon me-1"></i>@Model[i].SubscriptionType</span></td>
                    <td><span class="badge bg-success">@Model[i].Price.ToString("N2")</span></td>
                    <td><span class="badge bg-info">@Model[i].DurationMonths @Localizer["Months"]</span></td>
                    <td><span class="badge bg-primary">@Model[i].StudentSubscriptionCount</span></td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td>
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });

        var subLabels = [@Html.Raw(string.Join(",", bySubject.Select(x => $"\"{x.Name}\"")))];
        var subCounts = [@Html.Raw(string.Join(",", bySubject.Select(x => x.Count)))];
        var subSubs = [@Html.Raw(string.Join(",", bySubject.Select(x => x.Subs)))];
        var colors = ['#6366f1','#ec4899','#22c55e','#f59e0b','#06b6d4','#8b5cf6','#ef4444','#14b8a6'];

        new Chart(document.getElementById('chartSubject'), { type: 'doughnut', data: { labels: subLabels, datasets: [{ data: subCounts, backgroundColor: colors.slice(0, subLabels.length), borderWidth: 0 }] }, options: { responsive: true, plugins: { legend: { position: 'bottom' } } } });

        new Chart(document.getElementById('chartSubscribers'), { type: 'bar', data: { labels: subLabels, datasets: [{ label: '@Localizer["Subscribers"]', data: subSubs, backgroundColor: colors.slice(0, subLabels.length), borderRadius: 8 }] }, options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
    });

    function applyFilters() {
        dt.search($('#searchInput').val());
        var subjectCol = 2;
        var schoolCol = @(isSuperAdmin ? 6 : -1);
        dt.column(subjectCol).search($('#filterSubject').val());
        if (isSuperAdmin) { dt.column(schoolCol).search($('#filterSchool').val()); }
        dt.draw();
    }

    function resetFilters() {
        $('#searchInput, #filterSubject, #filterBranch').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }

    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
