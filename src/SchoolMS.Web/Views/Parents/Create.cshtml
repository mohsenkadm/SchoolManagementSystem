@using SchoolMS.Application.DTOs
@{
    var item = Model as ParentDto;
    var isEdit = item != null && item.Id > 0;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditParent"] : Localizer["AddParent"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }

        <!-- Profile Image -->
        <h6 class="text-muted mb-3"><i class="fas fa-camera me-1"></i>@Localizer["ProfileImage"]</h6>
        <div class="row g-3 mb-4">
            <div class="col-md-12">
                <div id="dropZone" style="border:2px dashed #cbd5e1;border-radius:12px;padding:1.5rem;text-align:center;cursor:pointer;transition:all 0.3s ease;background:#f8fafc;">
                    <div id="dropContent">
                        <i class="fas fa-cloud-upload-alt fa-2x text-muted mb-2 d-block"></i>
                        <p class="text-muted small mb-1">@Localizer["DragDropImage"]</p>
                        <label for="profileImageFile" class="btn btn-outline-primary btn-sm"><i class="fas fa-folder-open me-1"></i>@Localizer["BrowseFiles"]</label>
                        <input type="file" id="profileImageFile" name="ProfileImageFile" class="d-none" accept="image/png,image/jpeg,image/webp,image/gif" />
                        <p class="text-muted small mt-1 mb-0">PNG, JPG, WEBP, GIF — Max 5MB</p>
                    </div>
                </div>
            </div>
            <div class="col-md-12" id="previewContainer" style="@(isEdit && !string.IsNullOrEmpty(item?.ProfileImage) ? "" : "display:none;")">
                <div class="position-relative d-inline-block">
                    <img id="imagePreview" src="@(item?.ProfileImage ?? "")" style="max-height:160px;border-radius:12px;object-fit:cover;box-shadow:0 4px 15px rgba(0,0,0,.12);" alt="" />
                    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1" onclick="clearImage()" style="border-radius:50%;width:28px;height:28px;padding:0;">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- School / Branch / Student -->
        <h6 class="text-muted mb-3"><i class="fas fa-school me-1"></i>@Localizer["SchoolInfo"]</h6>
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-4">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select name="SchoolId" id="schoolSelect" class="form-select select2" required>
                        <option value="">-- @Localizer["SelectSchool"] --</option>
                        @foreach (var s in schools)
                        {
                            var isSelected = item?.SchoolId == s.Id;
                            <option value="@s.Id" selected="@isSelected">@s.Name</option>
                        }
                    </select>
                </div>
            }
            <div class="col-md-4">
                <label class="form-label">@Localizer["Branch"]</label>
                <select id="branchSelect" class="form-select select2">
                    <option value="">-- @Localizer["SelectBranch"] --</option>
                    @foreach (var b in branches)
                    {
                        <option value="@b.Id">@b.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Students"]</label>
                <select name="StudentIds" id="studentSelect" class="form-select select2" multiple>
                </select>
            </div>
        </div>

        <h6 class="text-muted mb-3 mt-4"><i class="fas fa-male me-1"></i>@Localizer["FatherInfo"]</h6>
        <div class="row g-3">
            <div class="col-md-3"><label class="form-label">@Localizer["FatherName"] *</label><input type="text" name="FatherName" class="form-control" value="@item?.FatherName" required /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Phone"]</label><input type="tel" name="FatherPhone" class="form-control" value="@item?.FatherPhone" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Email"]</label><input type="email" name="FatherEmail" class="form-control" value="@item?.FatherEmail" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Occupation"]</label><input type="text" name="FatherOccupation" class="form-control" value="@item?.FatherOccupation" /></div>
        </div>
        <h6 class="text-muted mb-3 mt-4"><i class="fas fa-female me-1"></i>@Localizer["MotherInfo"]</h6>
        <div class="row g-3">
            <div class="col-md-3"><label class="form-label">@Localizer["MotherName"]</label><input type="text" name="MotherName" class="form-control" value="@item?.MotherName" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Phone"]</label><input type="tel" name="MotherPhone" class="form-control" value="@item?.MotherPhone" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Email"]</label><input type="email" name="MotherEmail" class="form-control" value="@item?.MotherEmail" /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["Occupation"]</label><input type="text" name="MotherOccupation" class="form-control" value="@item?.MotherOccupation" /></div>
        </div>
        <h6 class="text-muted mb-3 mt-4"><i class="fas fa-shield-alt me-1"></i>@Localizer["GuardianInfo"]</h6>
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label">@Localizer["GuardianName"]</label><input type="text" name="GuardianName" class="form-control" value="@item?.GuardianName" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Phone"]</label><input type="tel" name="GuardianPhone" class="form-control" value="@item?.GuardianPhone" /></div>
            <div class="col-md-4"><label class="form-label">@Localizer["Relation"]</label><input type="text" name="GuardianRelation" class="form-control" value="@item?.GuardianRelation" /></div>
        </div>
        <div class="row g-3 mt-2">
            <div class="col-md-12"><label class="form-label">@Localizer["Address"]</label><input type="text" name="Address" class="form-control" value="@item?.Address" /></div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var editStudentIds = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(item?.StudentIds ?? new List<int>()));

    // ===== Image upload =====
    var maxSize = 5 * 1024 * 1024;
    var validTypes = ['image/png', 'image/jpeg', 'image/webp', 'image/gif'];
    var dropZone = document.getElementById('dropZone');
    var fileInput = document.getElementById('profileImageFile');

    if (dropZone) {
        ['dragenter', 'dragover'].forEach(function (evt) {
            dropZone.addEventListener(evt, function (e) { e.preventDefault(); dropZone.style.borderColor = '#6366f1'; dropZone.style.background = '#eef2ff'; });
        });
        ['dragleave', 'drop'].forEach(function (evt) {
            dropZone.addEventListener(evt, function (e) { e.preventDefault(); dropZone.style.borderColor = '#cbd5e1'; dropZone.style.background = '#f8fafc'; });
        });
        dropZone.addEventListener('drop', function (e) {
            if (e.dataTransfer.files.length > 0) { fileInput.files = e.dataTransfer.files; onFileSelected(e.dataTransfer.files[0]); }
        });
        dropZone.addEventListener('click', function (e) {
            if (e.target === dropZone || e.target.closest('#dropContent')) fileInput.click();
        });
    }
    if (fileInput) {
        fileInput.addEventListener('change', function () { if (this.files.length > 0) onFileSelected(this.files[0]); });
    }
    function onFileSelected(file) {
        if (!validTypes.includes(file.type)) { toastr.error('Invalid file type.'); return; }
        if (file.size > maxSize) { toastr.error('File too large. Max 5MB.'); return; }
        var reader = new FileReader();
        reader.onload = function (e) { $('#imagePreview').attr('src', e.target.result); $('#previewContainer').show(); };
        reader.readAsDataURL(file);
    }
    function clearImage() {
        fileInput.value = '';
        $('#imagePreview').attr('src', '');
        $('#previewContainer').hide();
    }

    // ===== Cascading dropdowns =====
    $(function () {
        // School → Branch (SuperAdmin)
        if (isSuperAdmin) {
            $('#schoolSelect').on('change', function () {
                var schoolId = $(this).val();
                var brSel = $('#branchSelect');
                var stSel = $('#studentSelect');
                brSel.html('<option value="">-- @Localizer["SelectBranch"] --</option>');
                stSel.html('');
                if (brSel.hasClass('select2-hidden-accessible')) brSel.trigger('change.select2');
                if (stSel.hasClass('select2-hidden-accessible')) stSel.trigger('change.select2');
                if (!schoolId) return;

                $.get('@Url.Action("GetBranchesBySchool")?schoolId=' + schoolId, function (data) {
                    data.forEach(function (b) { brSel.append('<option value="' + b.id + '">' + b.name + '</option>'); });
                    if (brSel.hasClass('select2-hidden-accessible')) brSel.trigger('change.select2');
                });
            });
        }

        // Branch → Students
        $('#branchSelect').on('change', function () {
            var branchId = $(this).val();
            var stSel = $('#studentSelect');
            stSel.html('');
            if (stSel.hasClass('select2-hidden-accessible')) stSel.trigger('change.select2');
            if (!branchId) return;

            $.get('@Url.Action("GetStudentsByBranch")?branchId=' + branchId, function (data) {
                data.forEach(function (s) {
                    var sel = editStudentIds.includes(s.id) ? ' selected' : '';
                    stSel.append('<option value="' + s.id + '"' + sel + '>' + s.fullName + '</option>');
                });
                if (stSel.hasClass('select2-hidden-accessible')) stSel.trigger('change.select2');
            });
        });

        // On edit: trigger branch change to load students
        @if (isEdit && item!.StudentIds.Count > 0)
        {
            <text>
        var branchVal = $('#branchSelect').val();
        if (branchVal) { $('#branchSelect').trigger('change'); }
            </text>
        }
    });
</script>
}
