@model List<SchoolMS.Application.DTOs.ParentDto>
@using SchoolMS.Application.DTOs
@{
    ViewData["Title"] = Localizer["Parents"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-users text-primary"></i>@Localizer["Parents"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddParent"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-users"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-child"></i></div><div class="stat-info"><h6>@Localizer["Children"]</h6><div class="stat-value">@Model.Sum(p => p.ChildrenCount)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        <div class="@(isSuperAdmin ? "col-md-3" : "col-md-5")">
            <input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["SearchParent"]..." />
        </div>
        @if (isSuperAdmin)
        {
            <div class="col-md-3">
                <select id="filterSchool" class="form-select">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools)
                    {
                        <option value="@s.Name">@s.Name</option>
                    }
                </select>
            </div>
        }
        <div class="col-md-2">
            <button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i> @Localizer["Filter"]</button>
        </div>
        <div class="col-md-2">
            <button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i> @Localizer["Reset"]</button>
        </div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["FatherName"]</th>
                <th>@Localizer["FatherPhone"]</th>
                <th>@Localizer["MotherName"]</th>
                <th>@Localizer["Students"]</th>
                <th>@Localizer["Branch"]</th>
                @if (isSuperAdmin)
                {
                    <th>@Localizer["School"]</th>
                }
                <th>@Localizer["Children"]</th>
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td>@Model[i].FatherName</td>
                    <td>@Model[i].FatherPhone</td>
                    <td>@Model[i].MotherName</td>
                    <td>
                        @foreach (var st in Model[i].Students)
                        {
                            <span class="badge bg-primary me-1 mb-1" style="font-size:.75rem;">
                                <i class="fas fa-user-graduate me-1"></i>@st.FullName
                                @if (!string.IsNullOrEmpty(st.BranchName)) { <small class="opacity-75">(@st.BranchName)</small> }
                            </span>
                        }
                    </td>
                    <td>@Model[i].BranchName</td>
                    @if (isSuperAdmin)
                    {
                        <td>@Model[i].SchoolName</td>
                    }
                    <td><span class="badge bg-info">@Model[i].ChildrenCount</span></td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<script>
    var dt;
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var schoolCol = isSuperAdmin ? 6 : -1;

    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
    });
    function applyFilters() {
        dt.search($('#searchInput').val()).draw();
        if (isSuperAdmin) { dt.column(schoolCol).search($('#filterSchool').val()).draw(); }
    }
    function resetFilters() {
        $('#searchInput').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
