@using SchoolMS.Application.DTOs
@model List<StoragePlanDto>

@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-tags text-primary"></i> @Localizer["StoragePlans"]</h4>
        <p class="text-muted mb-0">@Localizer["ManageStoragePlansDesc"]</p>
    </div>
    <button class="btn btn-success" onclick="openCreate()" data-bs-toggle="modal" data-bs-target="#planModal">
        <i class="fas fa-plus me-1"></i>@Localizer["AddStoragePlan"]
    </button>
</div>

<!-- Plans Cards -->
<div class="row g-4 mb-4">
    @foreach (var plan in Model)
    {
        <div class="col-md-4 col-lg-3" data-aos="fade-up">
            <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px;">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-hdd fa-3x @(plan.IsActive ? "text-primary" : "text-muted")"></i>
                    </div>
                    <h5 class="fw-bold">@plan.PlanName</h5>
                    <div class="mb-2">
                        <span class="badge bg-info fs-6">@plan.StorageGB GB</span>
                    </div>
                    <h4 class="text-success">$@plan.Price</h4>
                    @if (!string.IsNullOrEmpty(plan.Description))
                    {
                        <p class="text-muted small">@plan.Description</p>
                    }
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="badge @(plan.IsActive ? "bg-success" : "bg-secondary")">
                            @(plan.IsActive ? Localizer["Active"] : Localizer["Inactive"])
                        </span>
                        <small class="text-muted">@plan.RequestCount @Localizer["Requests"]</small>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3 px-3">
                    <div class="action-group" style="width:100%;">
                        <button class="btn-act btn-act-edit" style="flex:1;" onclick="editPlan(@plan.Id, '@plan.PlanName.Replace("'", "\\'")' , @plan.StorageGB, @plan.Price, '@plan.Description?.Replace("'", "\\'")' , @plan.IsActive.ToString().ToLower())" title="@Localizer["Edit"]">
                            <i class="fas fa-edit"></i>
                        </button>
                        <span class="action-divider"></span>
                        <button class="btn-act btn-act-delete" onclick="deletePlan(@plan.Id)" title="@Localizer["Delete"]">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info" data-aos="fade-up">
        <i class="fas fa-info-circle me-1"></i> @Localizer["NoStoragePlans"]
    </div>
}

<!-- Plan Modal -->
<div class="modal fade" id="planModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="planModalTitle"><i class="fas fa-hdd me-2 text-primary"></i>@Localizer["AddStoragePlan"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="planId" />
                <div class="mb-3">
                    <label class="form-label">@Localizer["PlanName"] *</label>
                    <input type="text" class="form-control" id="planName" required placeholder="e.g. Basic Storage" />
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">@Localizer["StorageGB"] *</label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="planStorageGB" min="1" step="1" value="10" required />
                            <span class="input-group-text">GB</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@Localizer["Price"] *</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control" id="planPrice" min="0" step="0.01" value="5.00" required />
                        </div>
                    </div>
                </div>
                <div class="mb-3 mt-3">
                    <label class="form-label">@Localizer["Description"]</label>
                    <textarea class="form-control" id="planDescription" rows="2" placeholder="@Localizer["OptionalDescription"]"></textarea>
                </div>
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="planActive" checked />
                    <label class="form-check-label">@Localizer["Active"]</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                <button type="button" class="btn btn-success" onclick="savePlan()"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const token = $('input[name="__RequestVerificationToken"]').val();
    function getHeaders() { return { 'Content-Type': 'application/json', 'RequestVerificationToken': token }; }
    let isEdit = false;

    function openCreate() {
        isEdit = false;
        $('#planModalTitle').html('<i class="fas fa-hdd me-2 text-primary"></i>@Localizer["AddStoragePlan"]');
        $('#planId').val(''); $('#planName').val(''); $('#planStorageGB').val(10);
        $('#planPrice').val(5.00); $('#planDescription').val(''); $('#planActive').prop('checked', true);
    }

    function editPlan(id, name, gb, price, desc, active) {
        isEdit = true;
        $('#planModalTitle').html('<i class="fas fa-edit me-2 text-primary"></i>@Localizer["EditStoragePlan"]');
        $('#planId').val(id); $('#planName').val(name); $('#planStorageGB').val(gb);
        $('#planPrice').val(price); $('#planDescription').val(desc || ''); $('#planActive').prop('checked', active);
        new bootstrap.Modal('#planModal').show();
    }

    function savePlan() {
        var data = {
            planName: $('#planName').val(),
            storageGB: parseFloat($('#planStorageGB').val()),
            price: parseFloat($('#planPrice').val()),
            description: $('#planDescription').val() || null,
            isActive: $('#planActive').is(':checked')
        };
        if (!data.planName || !data.storageGB || data.storageGB <= 0) {
            toastr.warning('@Localizer["FillRequiredFields"]');
            return;
        }
        if (isEdit) {
            data.id = +$('#planId').val();
            $.ajax({
                url: '@Url.Action("UpdateStoragePlan", "Platform")', method: 'PUT', headers: getHeaders(),
                data: JSON.stringify(data),
                success: () => { toastr.success('@Localizer["PlanUpdated"]'); location.reload(); },
                error: (xhr) => toastr.error(xhr.responseJSON?.error || '@Localizer["Error"]')
            });
        } else {
            $.ajax({
                url: '@Url.Action("CreateStoragePlan", "Platform")', method: 'POST', headers: getHeaders(),
                data: JSON.stringify(data),
                success: () => { toastr.success('@Localizer["PlanCreated"]'); location.reload(); },
                error: (xhr) => toastr.error(xhr.responseJSON?.error || '@Localizer["Error"]')
            });
        }
    }

    function deletePlan(id) {
        Swal.fire({
            title: '@Localizer["DeleteStoragePlan"]?',
            icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33',
            confirmButtonText: '@Localizer["Delete"]', cancelButtonText: '@Localizer["Cancel"]'
        }).then(r => {
            if (r.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("DeleteStoragePlan", "Platform")?id=' + id, method: 'DELETE', headers: getHeaders(),
                    success: () => { toastr.success('@Localizer["PlanDeleted"]'); location.reload(); },
                    error: () => toastr.error('@Localizer["Error"]')
                });
            }
        });
    }
</script>
}
