@using SchoolMS.Application.DTOs
@using SchoolMS.Domain.Enums
@model List<SchoolMS.Application.DTOs.PromoCodeDto>
@{
    ViewData["Title"] = Localizer["PromoCodes"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-ticket-alt text-primary"></i>@Localizer["PromoCodes"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("ExportExcel")" class="btn btn-success"><i class="fas fa-file-excel me-1"></i>@Localizer["ExportExcel"]</a>
        <button class="btn btn-outline-secondary" onclick="window.print()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddPromoCode"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-ticket-alt"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-circle"></i></div><div class="stat-info"><h6>@Localizer["Active"]</h6><div class="stat-value">@Model.Count(p => p.IsActive)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-infinity"></i></div><div class="stat-info"><h6>@Localizer["Unlimited"]</h6><div class="stat-value">@Model.Count(p => p.IsUnlimited)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-users"></i></div><div class="stat-info"><h6>@Localizer["TotalUsage"]</h6><div class="stat-value">@Model.Sum(p => p.CurrentUsage)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterActive" class="form-select">
                <option value="">@Localizer["All"]</option>
                <option value="Active">@Localizer["Active"]</option>
                <option value="Inactive">@Localizer["Inactive"]</option>
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterType" class="form-select">
                <option value="">@Localizer["AllTypes"]</option>
                <option value="Percentage">@Localizer["Percentage"]</option>
                <option value="FixedAmount">@Localizer["FixedAmount"]</option>
            </select>
        </div>
        <div class="col-md-3">
            <input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." />
        </div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["Code"]</th>
                <th>@Localizer["DiscountType"]</th>
                <th>@Localizer["DiscountValue"]</th>
                <th>@Localizer["ExpiryDate"]</th>
                <th>@Localizer["Usage"]</th>
                <th>@Localizer["Status"]</th>
                <th>@Localizer["UsedBy"]</th>
                @if (isSuperAdmin) { <th>@Localizer["School"]</th> }
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td><code class="fs-6">@Model[i].Code</code></td>
                    <td><span class="badge bg-info">@Model[i].DiscountType</span></td>
                    <td>
                        @if (Model[i].DiscountType == DiscountType.Percentage)
                        { <span class="badge bg-primary">@Model[i].DiscountValue%</span> }
                        else
                        { <span class="badge bg-success">@Model[i].DiscountValue.ToString("N2")</span> }
                    </td>
                    <td>
                        @if (Model[i].IsUnlimited)
                        { <span class="badge bg-warning text-dark"><i class="fas fa-infinity me-1"></i>@Localizer["Unlimited"]</span> }
                        else
                        { @(Model[i].ExpiryDate?.ToString("yyyy-MM-dd") ?? "—") }
                    </td>
                    <td><span class="badge bg-secondary">@Model[i].CurrentUsage / @(Model[i].IsUnlimited ? "∞" : Model[i].MaxUsage.ToString())</span></td>
                    <td>
                        @if (Model[i].IsActive)
                        { <span class="status-badge status-active"><span class="status-dot"></span> Active</span> }
                        else
                        { <span class="badge bg-secondary">Inactive</span> }
                    </td>
                    <td>
                        @if (Model[i].Usages.Any())
                        {
                            <span class="badge bg-info" data-bs-toggle="tooltip" title="@string.Join(", ", Model[i].Usages.Select(u => u.StudentName))">
                                <i class="fas fa-users me-1"></i>@Model[i].Usages.Count
                            </span>
                        }
                        else { <span class="text-muted">—</span> }
                    </td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td>
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
    });
    function applyFilters() {
        dt.search($('#searchInput').val());
        dt.column(2).search($('#filterType').val());
        dt.column(6).search($('#filterActive').val());
        if (isSuperAdmin) { dt.column(@(isSuperAdmin ? 8 : -1)).search($('#filterSchool').val()); }
        dt.draw();
    }
    function resetFilters() {
        $('#searchInput, #filterActive, #filterType').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
