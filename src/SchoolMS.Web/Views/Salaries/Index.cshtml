@using SchoolMS.Application.DTOs
@model List<SalarySetupDto>
@{ ViewData["Title"] = Localizer["Salaries"].Value; }
@Html.AntiForgeryToken()
@{
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var totalBase = Model.Sum(s => s.BaseSalary);
    var totalAllow = Model.Sum(s => s.Allowances);
    var totalDeduct = Model.Sum(s => s.Deductions);
    var salByType = Model.GroupBy(s => s.PersonType.ToString()).Select(g => new { Name = g.Key, Net = g.Sum(x => x.NetSalary) }).OrderByDescending(x => x.Net).ToList();
}

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-money-bill-wave text-primary"></i>@Localizer["Salaries"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-primary" onclick="printSchedule()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
        <a href="@Url.Action("ExportExcel")" class="btn btn-success"><i class="fas fa-file-excel me-1"></i>@Localizer["Export"]</a>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddSalary"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-users"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-coins"></i></div><div class="stat-info"><h6>@Localizer["TotalNet"]</h6><div class="stat-value">@Model.Sum(s => s.NetSalary).ToString("N0")</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-plus-circle"></i></div><div class="stat-info"><h6>@Localizer["Allowances"]</h6><div class="stat-value">@Model.Sum(s => s.Allowances).ToString("N0")</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-minus-circle"></i></div><div class="stat-info"><h6>@Localizer["Deductions"]</h6><div class="stat-value">@Model.Sum(s => s.Deductions).ToString("N0")</div></div></div>
</div>

<div class="row mb-4" data-aos="fade-up">
    <div class="col-lg-5">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-pie me-2 text-primary"></i>@Localizer["SalaryBreakdown"]</h6><canvas id="chartBreak" height="220"></canvas></div>
    </div>
    <div class="col-lg-7">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-bar me-2 text-primary"></i>@Localizer["NetByType"]</h6><canvas id="chartType" height="220"></canvas></div>
    </div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-3"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["SearchPerson"]..." /></div>
        <div class="col-md-2"><select id="filterType" class="form-select"><option value="">@Localizer["AllTypes"]</option>@foreach (var t in Model.Select(s => s.PersonType.ToString()).Distinct()) { <option value="@t">@t</option> }</select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up" id="printArea">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Person"]</th><th>@Localizer["Type"]</th><th>@Localizer["BaseSalary"]</th><th>@Localizer["Allowances"]</th><th>@Localizer["Deductions"]</th><th>@Localizer["NetSalary"]</th>@if (isSuperAdmin) { <th>@Localizer["School"]</th> }<th class="no-print">@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td>@Model[i].PersonName</td><td><span class="badge bg-secondary">@Model[i].PersonType</span></td><td>@Model[i].BaseSalary.ToString("N0")</td><td class="text-success">+@Model[i].Allowances.ToString("N0")</td><td class="text-danger">-@Model[i].Deductions.ToString("N0")</td><td class="fw-bold">@Model[i].NetSalary.ToString("N0")</td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td class="no-print">
                        <div class="action-group">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn-act btn-act-edit" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<style media="print">
    .page-header, .stat-ribbon, .filter-panel, .no-print, nav, .sidebar, footer, .row.mb-4 { display: none !important; }
    .table-card { box-shadow: none !important; border: none !important; }
    table { font-size: 12px; }
    th, td { padding: 4px 8px !important; }
</style>
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var typeColIdx = 2, schoolColIdx = isSuperAdmin ? 7 : -1;
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
        new Chart(document.getElementById('chartBreak'), { type: 'doughnut', data: { labels: ['Base Salary', 'Allowances', 'Deductions'], datasets: [{ data: [@totalBase.ToString("F0"), @totalAllow.ToString("F0"), @totalDeduct.ToString("F0")], backgroundColor: ['#6366f1','#22c55e','#ef4444'], borderWidth: 0 }] }, options: { responsive: true, plugins: { legend: { position: 'bottom' } } } });
        var typeLabels = [@Html.Raw(string.Join(",", salByType.Select(x => $"\"{x.Name}\"")))];
        var typeData = [@Html.Raw(string.Join(",", salByType.Select(x => x.Net.ToString("F0"))))];
        var colors = ['#6366f1','#ec4899','#22c55e','#f59e0b','#06b6d4','#8b5cf6'];
        new Chart(document.getElementById('chartType'), { type: 'bar', data: { labels: typeLabels, datasets: [{ label: 'Net Salary', data: typeData, backgroundColor: colors.slice(0, typeLabels.length), borderRadius: 8 }] }, options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
    });
    function applyFilters() { dt.search($('#searchInput').val()); dt.column(typeColIdx).search($('#filterType').val()); if (isSuperAdmin) { dt.column(schoolColIdx).search($('#filterSchool').val()); } dt.draw(); }
    function resetFilters() { $('#searchInput, #filterType').val(''); if (isSuperAdmin) { $('#filterSchool').val(''); } dt.search('').columns().search('').draw(); }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
    function printSchedule() { window.print(); }
</script>
}
