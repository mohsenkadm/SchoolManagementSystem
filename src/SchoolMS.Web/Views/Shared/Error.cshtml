@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5" data-aos="fade-up">
    <div style="font-size:4rem;margin-bottom:16px;">⚠️</div>
    <h2 style="font-weight:800;">An error occurred</h2>
    <p class="text-muted mb-4">Sorry, something went wrong while processing your request.</p>
    @if (Model.ShowRequestId)
    {
        <p class="text-muted" style="font-size:0.85rem;">
            Request ID: <code style="color:var(--primary-500);">@Model.RequestId</code>
        </p>
    }
    <a href="@Url.Action("Index", "Home")" class="btn btn-gradient mt-3">
        <i class="fas fa-home me-2"></i>Return to Dashboard
    </a>
</div>
