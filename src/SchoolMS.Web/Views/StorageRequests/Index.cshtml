@using SchoolMS.Application.DTOs
@model List<StorageRequestDto>
@{
    var quota = ViewBag.Quota as StorageQuotaDto;
    var plans = ViewBag.StoragePlans as List<StoragePlanDto> ?? new();
}

@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-hdd text-primary"></i> @Localizer["StorageRequests"]</h4>
        <p class="text-muted mb-0">@Localizer["StorageRequestsDesc"]</p>
    </div>
</div>

<!-- Storage Quota Overview -->
@if (quota != null)
{
    var pct = quota.TotalStorageGB > 0 ? Math.Min(100, Math.Round(quota.UsedStorageGB / quota.TotalStorageGB * 100, 0)) : 0;
    var color = pct > 90 ? "danger" : pct > 70 ? "warning" : "info";
    <div class="row mb-4">
        <div class="col-md-3" data-aos="fade-up" data-aos-delay="100">
            <div class="dashboard-card card p-3 text-center">
                <i class="fas fa-database fa-2x text-primary mb-2"></i>
                <h5 class="mb-0">@quota.TotalStorageGB.ToString("F2") GB</h5>
                <small class="text-muted">@Localizer["TotalStorage"]</small>
            </div>
        </div>
        <div class="col-md-3" data-aos="fade-up" data-aos-delay="200">
            <div class="dashboard-card card p-3 text-center">
                <i class="fas fa-chart-pie fa-2x text-@color mb-2"></i>
                <h5 class="mb-0">@quota.UsedStorageGB.ToString("F2") GB</h5>
                <small class="text-muted">@Localizer["UsedStorage"]</small>
            </div>
        </div>
        <div class="col-md-3" data-aos="fade-up" data-aos-delay="300">
            <div class="dashboard-card card p-3 text-center">
                <i class="fas fa-folder-open fa-2x text-success mb-2"></i>
                <h5 class="mb-0">@quota.AvailableGB.ToString("F2") GB</h5>
                <small class="text-muted">@Localizer["AvailableStorage"]</small>
            </div>
        </div>
        <div class="col-md-3" data-aos="fade-up" data-aos-delay="400">
            <div class="dashboard-card card p-3 text-center">
                <i class="fas fa-plus-circle fa-2x text-info mb-2"></i>
                <h5 class="mb-0">@quota.ExtraStorageGB.ToString("F2") GB</h5>
                <small class="text-muted">@Localizer["ExtraStorage"]</small>
            </div>
        </div>
    </div>
    <div class="dashboard-card card p-3 mb-4" data-aos="fade-up">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <strong>@Localizer["StorageUsage"]: @pct%</strong>
            <span class="text-muted">@quota.UsedStorageGB.ToString("F2") / @quota.TotalStorageGB.ToString("F2") GB</span>
        </div>
        <div class="progress" style="height: 12px; border-radius: 8px;">
            <div class="progress-bar bg-@color progress-bar-striped progress-bar-animated" style="width: @pct%"></div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning mb-4" data-aos="fade-up">
        <i class="fas fa-exclamation-triangle me-1"></i> @Localizer["NoActiveSubscription"]
    </div>
}

<!-- Available Storage Plans -->
@if (quota != null && plans.Count > 0)
{
    <div class="dashboard-card card p-4 mb-4" data-aos="fade-up">
        <h6 class="mb-3"><i class="fas fa-tags me-2 text-success"></i>@Localizer["AvailableStoragePlans"]</h6>
        <div class="row g-3">
            @foreach (var plan in plans)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm text-center p-3" style="border-radius:12px;">
                        <div class="mb-2">
                            <i class="fas fa-hdd fa-3x text-primary"></i>
                        </div>
                        <h5 class="fw-bold mb-1">@plan.PlanName</h5>
                        <div class="mb-2">
                            <span class="badge bg-info fs-6">@plan.StorageGB GB</span>
                        </div>
                        <h4 class="text-success mb-2">$@plan.Price</h4>
                        @if (!string.IsNullOrEmpty(plan.Description))
                        {
                            <p class="text-muted small mb-3">@plan.Description</p>
                        }
                        <button class="btn btn-success w-100" onclick="requestPlan(@plan.Id, '@plan.PlanName', @plan.StorageGB, @plan.Price)">
                            <i class="fas fa-paper-plane me-1"></i>@Localizer["RequestThisPlan"]
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
}
else if (quota != null)
{
    <div class="alert alert-info mb-4" data-aos="fade-up">
        <i class="fas fa-info-circle me-1"></i> @Localizer["NoStoragePlansAvailable"]
    </div>
}

<!-- My Requests History -->
<div class="dashboard-card card p-4" data-aos="fade-up">
    <h6 class="mb-3"><i class="fas fa-history me-2 text-info"></i>@Localizer["MyRequests"]</h6>
    @if (Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@Localizer["StoragePlan"]</th>
                        <th>@Localizer["RequestedGB"]</th>
                        <th>@Localizer["TotalPrice"]</th>
                        <th>@Localizer["Notes"]</th>
                        <th>@Localizer["Status"]</th>
                        <th>@Localizer["RequestDate"]</th>
                        <th>@Localizer["ProcessedDate"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var status = !r.IsProcessed ? "Pending" : r.IsApproved ? "Approved" : "Rejected";
                        var badgeClass = !r.IsProcessed ? "bg-warning" : r.IsApproved ? "bg-success" : "bg-danger";
                        var icon = !r.IsProcessed ? "fas fa-clock" : r.IsApproved ? "fas fa-check" : "fas fa-times";
                        <tr>
                            <td>@r.Id</td>
                            <td><span class="badge bg-primary">@r.StoragePlanName</span></td>
                            <td><strong>@r.RequestedGB GB</strong></td>
                            <td><strong>$@r.TotalPrice</strong></td>
                            <td>@(r.Notes ?? "—")</td>
                            <td><span class="badge @badgeClass"><i class="@icon me-1"></i>@Localizer[status]</span></td>
                            <td>@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>@(r.ProcessedAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info mb-0"><i class="fas fa-info-circle me-1"></i>@Localizer["NoStorageRequests"]</div>
    }
</div>

@section Scripts {
<script>
    const token = $('input[name="__RequestVerificationToken"]').val();
    function getHeaders() { return { 'Content-Type': 'application/json', 'RequestVerificationToken': token }; }

    function requestPlan(planId, planName, gb, price) {
        Swal.fire({
            title: '@Localizer["ConfirmRequest"]',
            html: '<div class="text-start">'
                + '<p><strong>@Localizer["StoragePlan"]:</strong> ' + planName + '</p>'
                + '<p><strong>@Localizer["Storage"]:</strong> ' + gb + ' GB</p>'
                + '<p><strong>@Localizer["Price"]:</strong> $' + price.toFixed(2) + '</p>'
                + '</div>'
                + '<div class="mt-3"><label class="form-label">@Localizer["Notes"]</label>'
                + '<input type="text" id="swalNotes" class="form-control" placeholder="@Localizer["OptionalNotes"]" /></div>',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#22c55e',
            confirmButtonText: '<i class="fas fa-paper-plane me-1"></i>@Localizer["Submit"]',
            cancelButtonText: '@Localizer["Cancel"]'
        }).then(result => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("Create", "StorageRequests")',
                    method: 'POST',
                    headers: getHeaders(),
                    data: JSON.stringify({ storagePlanId: planId, notes: document.getElementById('swalNotes')?.value || null }),
                    success: function () {
                        toastr.success('@Localizer["RequestSubmitted"]');
                        setTimeout(() => location.reload(), 1000);
                    },
                    error: function (xhr) {
                        toastr.error(xhr.responseJSON?.error || '@Localizer["Error"]');
                    }
                });
            }
        });
    }
</script>
}
