@using SchoolMS.Application.DTOs
@{
    var students = ViewBag.Students as List<StudentDto> ?? new();
    var subjects = ViewBag.Subjects as List<SubjectDto> ?? new();
    var examTypes = ViewBag.ExamTypes as List<ExamTypeDto> ?? new();
    var years = ViewBag.AcademicYears as List<AcademicYearDto> ?? new();
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas fa-layer-group me-2 text-primary"></i>@Localizer["BulkAddGrades"]</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>

<div class="dashboard-card card p-4" data-aos="fade-up">
    @Html.AntiForgeryToken()
    <div class="row g-3 mb-4">
        @if (isSuperAdmin)
        {
            <div class="col-md-3">
                <label class="form-label">@Localizer["School"]</label>
                <select id="bulkSchoolId" class="form-select select2">
                    <option value="">-- @Localizer["Select"] --</option>
                    @foreach (var s in schools) { <option value="@s.Id">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-3">
            <label class="form-label">@Localizer["Subject"] *</label>
            <select id="bulkSubjectId" class="form-select select2" required>
                <option value="">-- @Localizer["SelectSubject"] --</option>
                @foreach (var s in subjects) { <option value="@s.Id">@s.SubjectName</option> }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">@Localizer["ExamType"] *</label>
            <select id="bulkExamTypeId" class="form-select" required>
                <option value="">-- @Localizer["Select"] --</option>
                @foreach (var e in examTypes) { <option value="@e.Id">@e.TypeName</option> }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">@Localizer["AcademicYear"] *</label>
            <select id="bulkAcademicYearId" class="form-select" required>
                @foreach (var y in years) { <option value="@y.Id">@y.YearName</option> }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">@Localizer["MaxMark"]</label>
            <input type="number" step="0.01" id="bulkMaxMark" class="form-control" value="100" />
        </div>
    </div>

    <h6 class="mb-3"><i class="fas fa-list me-2 text-primary"></i>@Localizer["StudentGrades"]</h6>
    <div class="table-responsive">
        <table class="table table-bordered table-hover" id="bulkTable">
            <thead class="table-light">
                <tr>
                    <th style="width:40px"><input type="checkbox" id="selectAll" checked /></th>
                    <th>@Localizer["Student"]</th>
                    <th style="width:120px">@Localizer["Mark"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in students)
                {
                    <tr data-student-id="@s.Id">
                        <td><input type="checkbox" class="student-check" checked /></td>
                        <td>@s.FullName</td>
                        <td><input type="number" step="0.01" class="form-control form-control-sm mark-input" value="0" min="0" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="button" class="btn btn-accent" onclick="saveBulk()"><i class="fas fa-save me-1"></i>@Localizer["SaveAll"]</button>
        <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
    </div>
</div>

@section Scripts {
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");

    $('#selectAll').on('change', function () {
        $('.student-check').prop('checked', this.checked);
    });

    function saveBulk() {
        var subjectId = parseInt($('#bulkSubjectId').val());
        var examTypeId = parseInt($('#bulkExamTypeId').val());
        var yearId = parseInt($('#bulkAcademicYearId').val());
        var maxMark = parseFloat($('#bulkMaxMark').val()) || 100;
        var schoolId = isSuperAdmin ? parseInt($('#bulkSchoolId').val()) || 0 : 0;

        if (!subjectId || !examTypeId || !yearId) {
            toastr.error('Please select Subject, Exam Type, and Academic Year');
            return;
        }

        var grades = [];
        $('#bulkTable tbody tr').each(function () {
            if ($(this).find('.student-check').is(':checked')) {
                var mark = parseFloat($(this).find('.mark-input').val()) || 0;
                grades.push({
                    studentId: parseInt($(this).data('student-id')),
                    subjectId: subjectId,
                    examTypeId: examTypeId,
                    academicYearId: yearId,
                    mark: mark,
                    maxMark: maxMark,
                    schoolId: schoolId
                });
            }
        });

        if (grades.length === 0) {
            toastr.warning('No students selected');
            return;
        }

        $.ajax({
            url: '@Url.Action("BulkCreate")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(grades),
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            success: function () {
                toastr.success('Grades saved successfully!');
                setTimeout(function () { location.href = '@Url.Action("Index")'; }, 1000);
            },
            error: function () { toastr.error('An error occurred'); }
        });
    }
</script>
}
