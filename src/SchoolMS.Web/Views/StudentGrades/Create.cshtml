@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (StudentGradeDto)Model : null;
    var students = ViewBag.Students as List<StudentDto> ?? new();
    var subjects = ViewBag.Subjects as List<SubjectDto> ?? new();
    var examTypes = ViewBag.ExamTypes as List<ExamTypeDto> ?? new();
    var years = ViewBag.AcademicYears as List<AcademicYearDto> ?? new();
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2 text-primary"></i>@(isEdit ? Localizer["EditGrade"] : Localizer["AddGrade"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>
<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            @if (isSuperAdmin)
            {
                <div class="col-md-4">
                    <label class="form-label">@Localizer["School"] *</label>
                    <select name="SchoolId" class="form-select select2" required>
                        <option value="">-- @Localizer["Select"] --</option>
                        @foreach (var s in schools) { <option value="@s.Id" selected="@(item?.SchoolId == s.Id)">@s.Name</option> }
                    </select>
                </div>
            }
            <div class="col-md-4">
                <label class="form-label">@Localizer["Student"] *</label>
                <select name="StudentId" class="form-select select2" required>
                    <option value="">-- @Localizer["SelectStudent"] --</option>
                    @foreach (var s in students) { <option value="@s.Id" selected="@(item?.StudentId == s.Id)">@s.FullName</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Subject"] *</label>
                <select name="SubjectId" class="form-select select2" required>
                    <option value="">-- @Localizer["SelectSubject"] --</option>
                    @foreach (var s in subjects) { <option value="@s.Id" selected="@(item?.SubjectId == s.Id)">@s.SubjectName</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["ExamType"] *</label>
                <select name="ExamTypeId" class="form-select" required>
                    <option value="">-- @Localizer["Select"] --</option>
                    @foreach (var e in examTypes) { <option value="@e.Id" selected="@(item?.ExamTypeId == e.Id)">@e.TypeName</option> }
                </select>
            </div>
            <div class="col-md-3"><label class="form-label">@Localizer["Mark"] *</label><input type="number" step="0.01" name="Mark" class="form-control" value="@(item?.Mark ?? 0)" required /></div>
            <div class="col-md-3"><label class="form-label">@Localizer["MaxMark"] *</label><input type="number" step="0.01" name="MaxMark" class="form-control" value="@(item?.MaxMark ?? 100)" required /></div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["AcademicYear"] *</label>
                <select name="AcademicYearId" class="form-select" required>
                    @foreach (var y in years) { <option value="@y.Id" selected="@(item?.AcademicYearId == y.Id)">@y.YearName</option> }
                </select>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
