@using SchoolMS.Application.DTOs
@using SchoolMS.Domain.Enums
@model List<StudentSubscriptionDto>
@{
    ViewData["Title"] = Localizer["StudentSubscriptions"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-id-card text-primary"></i>@Localizer["StudentSubscriptions"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("ExportExcel")" class="btn btn-success"><i class="fas fa-file-excel me-1"></i>@Localizer["ExportExcel"]</a>
        <button class="btn btn-outline-secondary" onclick="window.print()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddSubscription"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-id-card"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-check-circle"></i></div><div class="stat-info"><h6>@Localizer["Approved"]</h6><div class="stat-value">@Model.Count(s => s.Status == SubscriptionStatus.Approved)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-warning-soft"><i class="fas fa-clock"></i></div><div class="stat-info"><h6>@Localizer["Pending"]</h6><div class="stat-value">@Model.Count(s => s.Status == SubscriptionStatus.Pending)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-danger-soft"><i class="fas fa-times-circle"></i></div><div class="stat-info"><h6>@Localizer["Rejected"]</h6><div class="stat-value">@Model.Count(s => s.Status == SubscriptionStatus.Rejected)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon" style="background:rgba(99,102,241,0.15);"><i class="fas fa-graduation-cap" style="color:#6366f1;"></i></div><div class="stat-info"><h6>@Localizer["Course"]</h6><div class="stat-value">@Model.Count(s => s.SubscriptionType == SubscriptionType.Course)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon" style="background:rgba(239,68,68,0.15);"><i class="fas fa-broadcast-tower" style="color:#ef4444;"></i></div><div class="stat-info"><h6>@Localizer["LiveStream"]</h6><div class="stat-value">@Model.Count(s => s.SubscriptionType == SubscriptionType.LiveStream)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-money-bill-wave"></i></div><div class="stat-info"><h6>@Localizer["TotalPaid"]</h6><div class="stat-value">@Model.Sum(s => s.PaidAmount).ToString("N2")</div></div></div>
</div>

@{
    var byStatus = Model.GroupBy(s => s.Status.ToString()).Select(g => new { Name = g.Key, Count = g.Count() }).ToList();
    var byPlan = Model.GroupBy(s => s.PlanName ?? "Other").Select(g => new { Name = g.Key, Count = g.Count() }).OrderByDescending(x => x.Count).ToList();
}

<div class="row mb-4" data-aos="fade-up">
    <div class="col-lg-4">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-pie me-2 text-primary"></i>@Localizer["ByStatus"]</h6><canvas id="chartStatus" height="220"></canvas></div>
    </div>
    <div class="col-lg-8">
        <div class="dashboard-card card p-3 hover-lift"><h6 class="mb-3"><i class="fas fa-chart-bar me-2 text-primary"></i>@Localizer["ByPlan"]</h6><canvas id="chartPlan" height="220"></canvas></div>
    </div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterBranch" class="form-select">
                <option value="">@Localizer["AllBranches"]</option>
                @foreach (var b in branches) { <option value="@b.Name">@b.Name</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterStatus" class="form-select">
                <option value="">@Localizer["AllStatuses"]</option>
                @foreach (var status in Enum.GetValues<SubscriptionStatus>()) { <option value="@status.ToString()">@status</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterType" class="form-select">
                <option value="">@Localizer["AllTypes"]</option>
                <option value="Course">@Localizer["Course"]</option>
                <option value="LiveStream">@Localizer["LiveStream"]</option>
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterPlan" class="form-select">
                <option value="">@Localizer["AllPlans"]</option>
                @foreach (var p in Model.Select(s => s.PlanName).Distinct().OrderBy(x => x)) { <option value="@p">@p</option> }
            </select>
        </div>
        <div class="col-md-2">
            <input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." />
        </div>
        <div class="col-md-1">
            <button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button>
        </div>
        <div class="col-md-1">
            <button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button>
        </div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["Student"]</th>
                <th>@Localizer["Plan"]</th>
                <th>@Localizer["Type"]</th>
                <th>@Localizer["Subject"]</th>
                <th>@Localizer["Status"]</th>
                <th>@Localizer["OriginalAmount"]</th>
                <th>@Localizer["Discount"]</th>
                <th>@Localizer["PaidAmount"]</th>
                <th>@Localizer["PromoCode"]</th>
                <th>@Localizer["StartDate"]</th>
                <th>@Localizer["EndDate"]</th>
                <th>@Localizer["Branch"]</th>
                @if (isSuperAdmin) { <th>@Localizer["School"]</th> }
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var statusClass = Model[i].Status switch
                {
                    SubscriptionStatus.Approved => "status-active",
                    SubscriptionStatus.Pending => "bg-warning text-dark",
                    SubscriptionStatus.Rejected => "bg-danger",
                    _ => "bg-secondary"
                };
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td><strong>@Model[i].StudentName</strong></td>
                    <td>@Model[i].PlanName</td>
                    <td>
                        @{
                            var typeBadge = Model[i].SubscriptionType == SubscriptionType.LiveStream ? "bg-danger" : "bg-primary";
                            var typeIcon = Model[i].SubscriptionType == SubscriptionType.LiveStream ? "fa-broadcast-tower" : "fa-graduation-cap";
                        }
                        <span class="badge @typeBadge"><i class="fas @typeIcon me-1"></i>@Model[i].SubscriptionType</span>
                    </td>
                    <td>@Model[i].SubjectName</td>
                    <td>
                        @if (Model[i].Status == SubscriptionStatus.Approved)
                        {
                            <span class="status-badge status-active"><span class="status-dot"></span> @Model[i].Status</span>
                        }
                        else
                        {
                            <span class="badge @statusClass">@Model[i].Status</span>
                        }
                    </td>
                    <td>@Model[i].OriginalAmount.ToString("N2")</td>
                    <td>
                        @if (Model[i].DiscountAmount > 0)
                        { <span class="badge bg-danger">-@Model[i].DiscountAmount.ToString("N2")</span> }
                        else { <span class="text-muted">—</span> }
                    </td>
                    <td><span class="badge bg-success">@Model[i].PaidAmount.ToString("N2")</span></td>
                    <td>
                        @if (!string.IsNullOrEmpty(Model[i].PromoCode))
                        { <code>@Model[i].PromoCode</code> }
                        else { <span class="text-muted">—</span> }
                    </td>
                    <td>@Model[i].StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@Model[i].EndDate.ToString("yyyy-MM-dd")</td>
                    <td>@Model[i].BranchName</td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td>
                        <div class="action-group">
                            @if (Model[i].Status != SubscriptionStatus.Approved)
                            {
                                <button class="btn-act btn-act-success" onclick="changeStatus(@Model[i].Id, 'Approve')" data-bs-toggle="tooltip" title="@Localizer["Approve"]"><i class="fas fa-check"></i></button>
                            }
                            @if (Model[i].Status != SubscriptionStatus.Rejected)
                            {
                                <button class="btn-act btn-act-warning" onclick="changeStatus(@Model[i].Id, 'Reject')" data-bs-toggle="tooltip" title="@Localizer["Reject"]"><i class="fas fa-ban"></i></button>
                            }
                            @if (Model[i].Status != SubscriptionStatus.Pending)
                            {
                                <button class="btn-act btn-act-dark" onclick="changeStatus(@Model[i].Id, 'SetPending')" data-bs-toggle="tooltip" title="@Localizer["SetPending"]"><i class="fas fa-clock"></i></button>
                            }
                            <button class="btn-act btn-act-view" onclick="changeStatus(@Model[i].Id, 'MarkAsPaid')" data-bs-toggle="tooltip" title="@Localizer["MarkAsPaid"]"><i class="fas fa-money-bill-wave"></i></button>
                            <span class="action-divider"></span>
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn-act btn-act-edit" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });

        var statusLabels = [@Html.Raw(string.Join(",", byStatus.Select(x => $"\"{x.Name}\"")))];
        var statusData = [@Html.Raw(string.Join(",", byStatus.Select(x => x.Count)))];
        var statusColors = { 'Approved': '#22c55e', 'Pending': '#f59e0b', 'Rejected': '#ef4444' };
        var sColors = statusLabels.map(function (l) { return statusColors[l] || '#94a3b8'; });

        new Chart(document.getElementById('chartStatus'), { type: 'doughnut', data: { labels: statusLabels, datasets: [{ data: statusData, backgroundColor: sColors, borderWidth: 0 }] }, options: { responsive: true, plugins: { legend: { position: 'bottom' } } } });

        var planLabels = [@Html.Raw(string.Join(",", byPlan.Select(x => $"\"{x.Name}\"")))];
        var planData = [@Html.Raw(string.Join(",", byPlan.Select(x => x.Count)))];
        var colors = ['#6366f1','#ec4899','#22c55e','#f59e0b','#06b6d4','#8b5cf6','#ef4444','#14b8a6'];

        new Chart(document.getElementById('chartPlan'), { type: 'bar', data: { labels: planLabels, datasets: [{ label: '@Localizer["Subscriptions"]', data: planData, backgroundColor: colors.slice(0, planLabels.length), borderRadius: 8 }] }, options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
    });

    function applyFilters() {
        dt.search($('#searchInput').val());
        var statusCol = 5;
        var typeCol = 3;
        var planCol = 2;
        var branchCol = 12;
        var schoolCol = @(isSuperAdmin ? 13 : -1);
        dt.column(statusCol).search($('#filterStatus').val());
        dt.column(typeCol).search($('#filterType').val());
        dt.column(planCol).search($('#filterPlan').val());
        dt.column(branchCol).search($('#filterBranch').val());
        if (isSuperAdmin) { dt.column(schoolCol).search($('#filterSchool').val()); }
        dt.draw();
    }

    function resetFilters() {
        $('#searchInput, #filterStatus, #filterType, #filterPlan, #filterBranch').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }

    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }

    function changeStatus(id, action) {
        var titles = { 'Approve': '@Localizer["Approve"]', 'Reject': '@Localizer["Reject"]', 'SetPending': '@Localizer["SetPending"]', 'MarkAsPaid': '@Localizer["MarkAsPaid"]' };
        Swal.fire({ title: titles[action] + '?', icon: 'question', showCancelButton: true, confirmButtonText: '@Localizer["Yes"]', cancelButtonText: '@Localizer["Cancel"]' }).then(function(result) {
            if (result.isConfirmed) {
                $.ajax({ url: '@Url.Action("")/' + action + '?id=' + id, type: 'POST', headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    success: function () { location.reload(); },
                    error: function () { toastr.error('@Localizer["Error"]'); }
                });
            }
        });
    }
</script>
}
