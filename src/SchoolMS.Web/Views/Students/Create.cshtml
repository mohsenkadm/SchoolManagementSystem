@using SchoolMS.Application.DTOs
@{
    var isEdit = Model != null;
    var item = isEdit ? (StudentDto)Model : null;
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
    var years = ViewBag.AcademicYears as List<AcademicYearDto> ?? new();
    var classRooms = ViewBag.ClassRooms as List<ClassRoomDto> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-down">
    <h4 class="mb-0"><i class="fas @(isEdit ? "fa-user-edit" : "fa-user-plus") me-2 text-primary"></i>@(isEdit ? Localizer["EditStudent"] : Localizer["AddStudent"])</h4>
    <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>@Localizer["Back"]</a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger" data-aos="fade-up">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<div class="dashboard-card card p-4" data-aos="fade-up">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" name="Id" value="@item!.Id" /> }
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">@Localizer["FullName"] *</label>
                <input type="text" name="FullName" class="form-control" value="@item?.FullName" required />
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["FullName"] (AR)</label>
                <input type="text" name="FullNameAr" class="form-control" value="@item?.FullNameAr" dir="rtl" />
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["DateOfBirth"] *</label>
                <input type="date" name="DateOfBirth" class="form-control" value="@(item?.DateOfBirth.ToString("yyyy-MM-dd") ?? "")" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Gender"]</label>
                <select name="Gender" class="form-select">
                    <option value="Male" selected="@(item?.Gender == "Male")">@Localizer["Male"]</option>
                    <option value="Female" selected="@(item?.Gender == "Female")">@Localizer["Female"]</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">National ID</label>
                <input type="text" name="NationalId" class="form-control" value="@item?.NationalId" />
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["Phone"]</label>
                <input type="tel" name="Phone" class="form-control" value="@item?.Phone" />
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["Email"]</label>
                <input type="email" name="Email" class="form-control" value="@item?.Email" />
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["GuardianName"]</label>
                <input type="text" name="ParentName" class="form-control" value="@item?.ParentName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">@Localizer["GuardianPhone"]</label>
                <input type="tel" name="ParentPhone" class="form-control" value="@item?.ParentPhone" />
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Branch"] *</label>
                <select name="BranchId" class="form-select" required>
                    @foreach (var b in branches) { <option value="@b.Id" selected="@(item?.BranchId == b.Id)">@b.Name</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["ClassRoom"] *</label>
                <select name="ClassRoomId" class="form-select select2" required>
                    <option value="">-- @Localizer["Select"] --</option>
                    @foreach (var c in classRooms) { <option value="@c.Id" selected="@(item?.ClassRoomId == c.Id)">@c.GradeName - @c.DivisionName</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["AcademicYear"] *</label>
                <select name="AcademicYearId" class="form-select" required>
                    @foreach (var y in years) { <option value="@y.Id" selected="@(item?.AcademicYearId == y.Id || (!isEdit && y.IsCurrent))">@y.YearName</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Badge Card Number</label>
                <input type="text" name="BadgeCardNumber" class="form-control" value="@item?.BadgeCardNumber" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Username</label>
                <input type="text" name="Username" class="form-control" value="@item?.Username" />
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Password"]</label>
                <input type="password" name="Password" class="form-control" />
            </div>
            <div class="col-12">
                <label class="form-label">@Localizer["Address"]</label>
                <input type="text" name="Address" class="form-control" value="@item?.Address" />
            </div>
            <div class="col-12">
                <label class="form-label">@Localizer["Notes"]</label>
                <textarea name="Notes" class="form-control" rows="2">@item?.Notes</textarea>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-accent"><i class="fas fa-save me-1"></i>@Localizer["Save"]</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
