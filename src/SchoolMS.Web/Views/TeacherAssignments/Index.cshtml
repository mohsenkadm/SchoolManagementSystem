@using SchoolMS.Application.DTOs
@model List<TeacherAssignmentDto>
@{
    ViewData["Title"] = Localizer["TeacherAssignments"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-chalkboard text-primary"></i>@Localizer["TeacherAssignments"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddAssignment"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-chalkboard"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-chalkboard-teacher"></i></div><div class="stat-info"><h6>@Localizer["Teachers"]</h6><div class="stat-value">@Model.Select(a => a.TeacherId).Distinct().Count()</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-book"></i></div><div class="stat-info"><h6>@Localizer["Subjects"]</h6><div class="stat-value">@Model.Select(a => a.SubjectId).Distinct().Count()</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-3"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2"><select id="filterSubject" class="form-select"><option value="">@Localizer["AllSubjects"]</option>@foreach (var s in Model.Select(a => a.SubjectName).Distinct().OrderBy(s => s)) { <option value="@s">@s</option> }</select></div>
        <div class="col-md-2"><select id="filterBranch" class="form-select"><option value="">@Localizer["AllBranches"]</option>@foreach (var b in Model.Select(a => a.BranchName).Distinct().OrderBy(b => b)) { <option value="@b">@b</option> }</select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["Teacher"]</th>
                <th>@Localizer["Subject"]</th>
                <th>@Localizer["Grade"]</th>
                <th>@Localizer["Division"]</th>
                <th>@Localizer["Branch"]</th>
                @if (isSuperAdmin) { <th>@Localizer["School"]</th> }
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td>@Model[i].TeacherName</td>
                    <td>@Model[i].SubjectName</td>
                    <td>@Model[i].GradeName</td>
                    <td>@Model[i].DivisionName</td>
                    <td>@Model[i].BranchName</td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td>
                        <div class="action-group">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn-act btn-act-edit" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn-act btn-act-delete" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var subjectCol = 2, branchCol = 5;
    var schoolCol = isSuperAdmin ? 6 : -1;
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });
    });
    function applyFilters() {
        dt.search($('#searchInput').val());
        dt.column(subjectCol).search($('#filterSubject').val());
        dt.column(branchCol).search($('#filterBranch').val());
        if (isSuperAdmin) { dt.column(schoolCol).search($('#filterSchool').val()); }
        dt.draw();
    }
    function resetFilters() {
        $('#searchInput, #filterSubject, #filterBranch').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
</script>
}
