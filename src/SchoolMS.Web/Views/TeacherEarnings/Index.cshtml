@using SchoolMS.Application.DTOs
@using SchoolMS.Domain.Enums
@model List<TeacherEarningDto>
@{
    ViewData["Title"] = Localizer["TeacherEarnings"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var teachers = ViewBag.Teachers as List<TeacherDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-coins text-primary"></i> @Localizer["TeacherEarnings"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("ExportExcel")" class="btn btn-success"><i class="fas fa-file-excel me-1"></i>@Localizer["ExportExcel"]</a>
        <button class="btn btn-outline-secondary" onclick="window.print()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
    </div>
</div>

<!-- Statistics Ribbon -->
<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-primary-soft"><i class="fas fa-coins"></i></div>
        <div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div>
    </div>
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-warning-soft"><i class="fas fa-clock"></i></div>
        <div class="stat-info"><h6>@Localizer["Pending"]</h6><div class="stat-value">@Model.Count(e => e.Status == TeacherEarningStatus.Pending)</div></div>
    </div>
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-info-soft"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info"><h6>@Localizer["Approved"]</h6><div class="stat-value">@Model.Count(e => e.Status == TeacherEarningStatus.Approved)</div></div>
    </div>
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-success-soft"><i class="fas fa-money-bill-wave"></i></div>
        <div class="stat-info"><h6>@Localizer["Paid"]</h6><div class="stat-value">@Model.Count(e => e.Status == TeacherEarningStatus.Paid)</div></div>
    </div>
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-primary-soft"><i class="fas fa-dollar-sign"></i></div>
        <div class="stat-info"><h6>@Localizer["TotalEarnings"]</h6><div class="stat-value">@Model.Sum(e => e.EarningAmount).ToString("N2")</div></div>
    </div>
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-warning-soft"><i class="fas fa-hourglass-half"></i></div>
        <div class="stat-info"><h6>@Localizer["PendingAmount"]</h6><div class="stat-value">@Model.Where(e => e.Status == TeacherEarningStatus.Pending).Sum(e => e.EarningAmount).ToString("N2")</div></div>
    </div>
    <div class="stat-item stagger-item">
        <div class="stat-icon bg-success-soft"><i class="fas fa-hand-holding-usd"></i></div>
        <div class="stat-info"><h6>@Localizer["PaidAmount"]</h6><div class="stat-value">@Model.Where(e => e.Status == TeacherEarningStatus.Paid).Sum(e => e.EarningAmount).ToString("N2")</div></div>
    </div>
</div>

<!-- Charts -->
@{
    var byStatus = Model.GroupBy(e => e.Status.ToString()).Select(g => new { Name = g.Key, Count = g.Count(), Amount = g.Sum(x => x.EarningAmount) }).ToList();
    var byTeacher = Model.GroupBy(e => e.TeacherName ?? "Unknown").Select(g => new { Name = g.Key, Amount = g.Sum(x => x.EarningAmount) }).OrderByDescending(x => x.Amount).Take(10).ToList();
    var byCourse = Model.Where(e => e.CourseTitle != null).GroupBy(e => e.CourseTitle!).Select(g => new { Name = g.Key, Amount = g.Sum(x => x.EarningAmount) }).OrderByDescending(x => x.Amount).Take(10).ToList();
}

<div class="row mb-4" data-aos="fade-up">
    <div class="col-lg-4">
        <div class="dashboard-card card p-3 hover-lift">
            <h6 class="mb-3"><i class="fas fa-chart-pie me-2 text-primary"></i>@Localizer["ByStatus"]</h6>
            <canvas id="chartStatus" height="220"></canvas>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="dashboard-card card p-3 hover-lift">
            <h6 class="mb-3"><i class="fas fa-chart-bar me-2 text-success"></i>@Localizer["TopTeachers"]</h6>
            <canvas id="chartTeacher" height="220"></canvas>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="dashboard-card card p-3 hover-lift">
            <h6 class="mb-3"><i class="fas fa-chart-bar me-2 text-info"></i>@Localizer["TopCourses"]</h6>
            <canvas id="chartCourse" height="220"></canvas>
        </div>
    </div>
</div>

<!-- Advanced Filters -->
<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterTeacher" class="form-select select2">
                <option value="">@Localizer["AllTeachers"]</option>
                @foreach (var t in teachers) { <option value="@t.FullName">@t.FullName</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterStatus" class="form-select">
                <option value="">@Localizer["AllStatuses"]</option>
                @foreach (var status in Enum.GetValues<TeacherEarningStatus>()) { <option value="@status.ToString()">@status</option> }
            </select>
        </div>
        <div class="col-md-2">
            <select id="filterCourse" class="form-select select2">
                <option value="">@Localizer["AllCourses"]</option>
                @foreach (var c in Model.Select(e => e.CourseTitle).Where(c => c != null).Distinct().OrderBy(x => x)) { <option value="@c">@c</option> }
            </select>
        </div>
        <div class="col-md-2">
            <input type="date" id="filterDateFrom" class="form-control" placeholder="@Localizer["From"]" />
        </div>
        <div class="col-md-2">
            <input type="date" id="filterDateTo" class="form-control" placeholder="@Localizer["To"]" />
        </div>
    </div>
    <div class="row g-2 align-items-end mt-2">
        <div class="col-md-3">
            <input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." />
        </div>
        <div class="col-md-2">
            <input type="number" id="filterMinAmount" class="form-control" step="0.01" placeholder="@Localizer["MinAmount"]" />
        </div>
        <div class="col-md-2">
            <input type="number" id="filterMaxAmount" class="form-control" step="0.01" placeholder="@Localizer["MaxAmount"]" />
        </div>
        <div class="col-md-1">
            <button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button>
        </div>
        <div class="col-md-1">
            <button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button>
        </div>
    </div>
</div>

<!-- Data Table -->
<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["Teacher"]</th>
                <th>@Localizer["Course"]</th>
                <th>@Localizer["Student"]</th>
                <th>@Localizer["Plan"]</th>
                <th>@Localizer["SubscriptionAmount"]</th>
                <th>@Localizer["CommissionRate"]</th>
                <th>@Localizer["EarningAmount"]</th>
                <th>@Localizer["Status"]</th>
                <th>@Localizer["PaidAt"]</th>
                <th>@Localizer["Date"]</th>
                @if (isSuperAdmin) { <th>@Localizer["School"]</th> }
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var statusClass = Model[i].Status switch
                {
                    TeacherEarningStatus.Approved => "status-active",
                    TeacherEarningStatus.Pending => "bg-warning text-dark",
                    TeacherEarningStatus.Paid => "bg-success",
                    _ => "bg-secondary"
                };
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td><strong>@Model[i].TeacherName</strong></td>
                    <td>@(Model[i].CourseTitle ?? "—")</td>
                    <td>@(Model[i].StudentName ?? "—")</td>
                    <td>@(Model[i].PlanName ?? "—")</td>
                    <td>@Model[i].SubscriptionAmount.ToString("N2")</td>
                    <td><span class="badge bg-info">@Model[i].CommissionRate%</span></td>
                    <td><span class="badge bg-primary">@Model[i].EarningAmount.ToString("N2")</span></td>
                    <td>
                        @if (Model[i].Status == TeacherEarningStatus.Paid)
                        {
                            <span class="status-badge status-active"><span class="status-dot"></span> @Model[i].Status</span>
                        }
                        else
                        {
                            <span class="badge @statusClass">@Model[i].Status</span>
                        }
                    </td>
                    <td>@(Model[i].PaidAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                    <td>@Model[i].CreatedAt.ToString("yyyy-MM-dd")</td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td>
                        <div class="action-group">
                            @if (Model[i].Status != TeacherEarningStatus.Approved)
                            {
                                <button class="btn-act btn-act-view" onclick="changeStatus(@Model[i].Id, 'Approve')" data-bs-toggle="tooltip" title="@Localizer["Approve"]"><i class="fas fa-check"></i></button>
                            }
                            @if (Model[i].Status != TeacherEarningStatus.Paid)
                            {
                                <button class="btn-act btn-act-success" onclick="changeStatus(@Model[i].Id, 'MarkAsPaid')" data-bs-toggle="tooltip" title="@Localizer["MarkAsPaid"]"><i class="fas fa-money-bill-wave"></i></button>
                            }
                            @if (Model[i].Status != TeacherEarningStatus.Pending)
                            {
                                <button class="btn-act btn-act-dark" onclick="changeStatus(@Model[i].Id, 'SetPending')" data-bs-toggle="tooltip" title="@Localizer["SetPending"]"><i class="fas fa-clock"></i></button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Teacher Summary Cards -->
@{
    var summaries = Model.GroupBy(e => new { e.TeacherId, e.TeacherName })
        .Select(g => new
        {
            g.Key.TeacherId,
            TeacherName = g.Key.TeacherName ?? "Unknown",
            Total = g.Sum(x => x.EarningAmount),
            Pending = g.Where(x => x.Status == TeacherEarningStatus.Pending).Sum(x => x.EarningAmount),
            Approved = g.Where(x => x.Status == TeacherEarningStatus.Approved).Sum(x => x.EarningAmount),
            Paid = g.Where(x => x.Status == TeacherEarningStatus.Paid).Sum(x => x.EarningAmount),
            Count = g.Count()
        }).OrderByDescending(x => x.Total).ToList();
}

@if (summaries.Any())
{
    <div class="mt-4" data-aos="fade-up">
        <h5 class="mb-3"><i class="fas fa-user-tie me-2 text-primary"></i>@Localizer["TeacherSummary"]</h5>
        <div class="row g-3">
            @foreach (var s in summaries)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="dashboard-card card p-3 hover-lift">
                        <h6 class="fw-bold mb-2"><i class="fas fa-chalkboard-teacher me-1 text-primary"></i> @s.TeacherName</h6>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">@Localizer["TotalEarnings"]</span>
                            <strong class="text-primary">@s.Total.ToString("N2")</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">@Localizer["Pending"]</span>
                            <span class="text-warning">@s.Pending.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">@Localizer["Approved"]</span>
                            <span class="text-info">@s.Approved.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">@Localizer["Paid"]</span>
                            <span class="text-success">@s.Paid.ToString("N2")</span>
                        </div>
                        <hr class="my-2" />
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">@Localizer["Transactions"]</span>
                            <span class="badge bg-secondary">@s.Count</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var dt;
    $(function () {
        dt = $('#dataTable').DataTable({
            responsive: true,
            pageLength: 25,
            dom: 'rtip',
            order: [[10, 'desc']]
        });
        $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); });

        // Status Chart
        var statusLabels = [@Html.Raw(string.Join(",", byStatus.Select(x => $"\"{x.Name}\"")))];
        var statusData = [@Html.Raw(string.Join(",", byStatus.Select(x => x.Count)))];
        var statusColors = { 'Pending': '#f59e0b', 'Approved': '#06b6d4', 'Paid': '#22c55e' };
        var sColors = statusLabels.map(function (l) { return statusColors[l] || '#94a3b8'; });
        new Chart(document.getElementById('chartStatus'), {
            type: 'doughnut',
            data: { labels: statusLabels, datasets: [{ data: statusData, backgroundColor: sColors, borderWidth: 0 }] },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });

        // Teacher Chart
        var teacherLabels = [@Html.Raw(string.Join(",", byTeacher.Select(x => $"\"{x.Name}\"")))];
        var teacherData = [@Html.Raw(string.Join(",", byTeacher.Select(x => x.Amount.ToString("F2"))))];
        var tColors = ['#6366f1','#ec4899','#22c55e','#f59e0b','#06b6d4','#8b5cf6','#ef4444','#14b8a6','#f97316','#3b82f6'];
        new Chart(document.getElementById('chartTeacher'), {
            type: 'bar',
            data: { labels: teacherLabels, datasets: [{ label: '@Localizer["Earnings"]', data: teacherData, backgroundColor: tColors.slice(0, teacherLabels.length), borderRadius: 8 }] },
            options: { responsive: true, indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true } } }
        });

        // Course Chart
        var courseLabels = [@Html.Raw(string.Join(",", byCourse.Select(x => $"\"{x.Name}\"")))];
        var courseData = [@Html.Raw(string.Join(",", byCourse.Select(x => x.Amount.ToString("F2"))))];
        var cColors = ['#3b82f6','#8b5cf6','#14b8a6','#f97316','#ef4444','#22c55e','#ec4899','#06b6d4','#f59e0b','#6366f1'];
        new Chart(document.getElementById('chartCourse'), {
            type: 'bar',
            data: { labels: courseLabels, datasets: [{ label: '@Localizer["Earnings"]', data: courseData, backgroundColor: cColors.slice(0, courseLabels.length), borderRadius: 8 }] },
            options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
        });

        // Date range filter
        $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
            var dateCol = 10;
            var dateStr = data[dateCol];
            var from = $('#filterDateFrom').val();
            var to = $('#filterDateTo').val();
            if (from && dateStr < from) return false;
            if (to && dateStr > to) return false;

            var amountCol = 7;
            var amount = parseFloat(data[amountCol].replace(/,/g, '')) || 0;
            var min = parseFloat($('#filterMinAmount').val()) || 0;
            var max = parseFloat($('#filterMaxAmount').val()) || Infinity;
            if (amount < min || amount > max) return false;

            return true;
        });
    });

    function applyFilters() {
        var statusCol = 8;
        var teacherCol = 1;
        var courseCol = 2;
        var schoolCol = @(isSuperAdmin ? 11 : -1);

        dt.column(statusCol).search($('#filterStatus').val());
        dt.column(teacherCol).search($('#filterTeacher').val());
        dt.column(courseCol).search($('#filterCourse').val());
        if (isSuperAdmin && schoolCol > 0) { dt.column(schoolCol).search($('#filterSchool').val()); }
        dt.search($('#searchInput').val()).draw();
    }

    function resetFilters() {
        $('#searchInput, #filterStatus, #filterTeacher, #filterCourse, #filterDateFrom, #filterDateTo, #filterMinAmount, #filterMaxAmount').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }

    function changeStatus(id, action) {
        var titles = { 'Approve': '@Localizer["Approve"]', 'MarkAsPaid': '@Localizer["MarkAsPaid"]', 'SetPending': '@Localizer["SetPending"]' };
        Swal.fire({
            title: titles[action] + '?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: '@Localizer["Yes"]',
            cancelButtonText: '@Localizer["Cancel"]'
        }).then(function (result) {
            if (result.isConfirmed) {
                $.ajax({
                    url: '@Url.Action("")/' + action + '?id=' + id,
                    type: 'POST',
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    success: function () { location.reload(); },
                    error: function () { toastr.error('@Localizer["Error"]'); }
                });
            }
        });
    }
</script>
}
