@using SchoolMS.Application.DTOs
@model List<VisitorDto>
@using SchoolMS.Domain.Enums
@{
    ViewData["Title"] = Localizer["Visitors"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
    var branches = ViewBag.Branches as List<BranchDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-id-badge text-primary"></i>@Localizer["Visitors"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["CheckIn"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-sign-in-alt"></i></div><div class="stat-info"><h6>@Localizer["CheckedIn"]</h6><div class="stat-value">@Model.Count(v => v.Status == VisitorStatus.CheckedIn)</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-sign-out-alt"></i></div><div class="stat-info"><h6>@Localizer["CheckedOut"]</h6><div class="stat-value">@Model.Count(v => v.Status != VisitorStatus.CheckedIn)</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2">
            <select id="filterBranch" class="form-select">
                <option value="">@Localizer["AllBranches"]</option>
                @foreach (var b in branches) { <option value="@b.Name">@b.Name</option> }
            </select>
        </div>
        <div class="col-md-3"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["SearchVisitor"]..." /></div>
        <div class="col-md-2"><select id="filterStatus" class="form-select"><option value="">@Localizer["AllStatuses"]</option><option value="CheckedIn">@Localizer["CheckedIn"]</option><option value="CheckedOut">@Localizer["CheckedOut"]</option></select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead><tr><th>#</th><th>@Localizer["Name"]</th><th>@Localizer["Phone"]</th><th>@Localizer["Purpose"]</th><th>@Localizer["Branch"]</th><th>@Localizer["CheckIn"]</th><th>@Localizer["CheckOut"]</th><th>@Localizer["Status"]</th>@if (isSuperAdmin){<th>@Localizer["School"]</th>}<th>@Localizer["Actions"]</th></tr></thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var sBadge = Model[i].Status == VisitorStatus.CheckedIn ? "bg-success" : "bg-secondary";
                <tr class="table-row-animated">
                    <td>@(i + 1)</td><td>@Model[i].VisitorName</td><td>@Model[i].Phone</td><td>@Model[i].Purpose</td><td>@Model[i].BranchName</td><td>@Model[i].CheckInTime.ToString("yyyy-MM-dd HH:mm")</td><td>@Model[i].CheckOutTime?.ToString("HH:mm")</td><td><span class="badge @sBadge">@Model[i].Status</span></td>
                    @if (isSuperAdmin){<td>@Model[i].SchoolName</td>}
                    <td>
                        <div class="action-group">
                            @if (Model[i].Status == VisitorStatus.CheckedIn) { <button class="btn-act btn-act-warning" onclick="checkout(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["CheckOut"]"><i class="fas fa-sign-out-alt"></i></button> }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<script>
    var dt, isSA = @(isSuperAdmin ? "true" : "false");
    var branchCol = 4, statusCol = 7, schoolCol = isSA ? 8 : -1;
    $(function () { dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip', order: [[5, 'desc']] }); $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); }); });
    function applyFilters() { dt.search($('#searchInput').val()); dt.column(statusCol).search($('#filterStatus').val()); dt.column(branchCol).search($('#filterBranch').val()); if (isSA) dt.column(schoolCol).search($('#filterSchool').val()); dt.draw(); }
    function resetFilters() { $('#searchInput, #filterStatus, #filterBranch').val(''); if (isSA) $('#filterSchool').val(''); dt.search('').columns().search('').draw(); }
    function checkout(id) { $.post('@Url.Action("CheckOut")', { id: id }, function () { location.reload(); }); }
</script>
}
