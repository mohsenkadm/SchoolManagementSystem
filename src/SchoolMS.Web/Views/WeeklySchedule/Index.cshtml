@using SchoolMS.Application.DTOs
@model List<WeeklyScheduleDto>
@{
    ViewData["Title"] = Localizer["WeeklySchedule"].Value;
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var schools = ViewBag.Schools as List<SchoolDto> ?? new();
}
@Html.AntiForgeryToken()

<div class="page-header" data-aos="fade-down">
    <div>
        <h4 class="page-title"><i class="fas fa-calendar-week text-primary"></i>@Localizer["WeeklySchedule"]</h4>
        <span class="record-count"><i class="fas fa-layer-group"></i> @Model.Count</span>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-primary" onclick="printSchedule()"><i class="fas fa-print me-1"></i>@Localizer["Print"]</button>
        <a href="@Url.Action("ExportExcel")" class="btn btn-success"><i class="fas fa-file-excel me-1"></i>@Localizer["Export"]</a>
        <a href="@Url.Action("BulkCreate")" class="btn btn-warning"><i class="fas fa-layer-group me-1"></i>@Localizer["BulkAdd"]</a>
        <a href="@Url.Action("Create")" class="btn btn-accent"><i class="fas fa-plus me-1"></i>@Localizer["AddSchedule"]</a>
    </div>
</div>

<div class="stat-ribbon" data-aos="fade-up">
    <div class="stat-item stagger-item"><div class="stat-icon bg-primary-soft"><i class="fas fa-calendar-week"></i></div><div class="stat-info"><h6>@Localizer["Total"]</h6><div class="stat-value">@Model.Count</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-info-soft"><i class="fas fa-chalkboard-teacher"></i></div><div class="stat-info"><h6>@Localizer["Teachers"]</h6><div class="stat-value">@Model.Select(w => w.TeacherId).Distinct().Count()</div></div></div>
    <div class="stat-item stagger-item"><div class="stat-icon bg-success-soft"><i class="fas fa-book"></i></div><div class="stat-info"><h6>@Localizer["Subjects"]</h6><div class="stat-value">@Model.Select(w => w.SubjectId).Distinct().Count()</div></div></div>
</div>

<div class="filter-panel" data-aos="fade-up">
    <div class="filter-title"><i class="fas fa-filter"></i> @Localizer["Filter"]</div>
    <div class="row g-2 align-items-end">
        @if (isSuperAdmin)
        {
            <div class="col-md-2">
                <select id="filterSchool" class="form-select select2">
                    <option value="">@Localizer["AllSchools"]</option>
                    @foreach (var s in schools) { <option value="@s.Name">@s.Name</option> }
                </select>
            </div>
        }
        <div class="col-md-2"><input type="text" id="searchInput" class="form-control" placeholder="🔍 @Localizer["Search"]..." /></div>
        <div class="col-md-2"><select id="filterDay" class="form-select"><option value="">@Localizer["AllDays"]</option>@foreach (var d in Model.Select(x => x.DayOfWeek).Distinct().OrderBy(d => d)) { <option value="@d">@d</option> }</select></div>
        <div class="col-md-2"><select id="filterSubject" class="form-select"><option value="">@Localizer["AllSubjects"]</option>@foreach (var s in Model.Select(x => x.SubjectName).Distinct().OrderBy(s => s)) { <option value="@s">@s</option> }</select></div>
        <div class="col-md-2"><select id="filterBranch" class="form-select"><option value="">@Localizer["AllBranches"]</option>@foreach (var b in Model.Select(x => x.BranchName).Where(b => b != null).Distinct().OrderBy(b => b)) { <option value="@b">@b</option> }</select></div>
        <div class="col-md-1"><button class="btn btn-filter w-100" onclick="applyFilters()"><i class="fas fa-search"></i></button></div>
        <div class="col-md-1"><button class="btn btn-reset w-100" onclick="resetFilters()"><i class="fas fa-redo"></i></button></div>
    </div>
</div>

<div class="table-card hover-lift" data-aos="fade-up" id="printArea">
    <table id="dataTable" class="table table-hover" style="width:100%">
        <thead>
            <tr>
                <th>#</th>
                <th>@Localizer["Day"]</th>
                <th>@Localizer["Subject"]</th>
                <th>@Localizer["Teacher"]</th>
                <th>@Localizer["Grade"]</th>
                <th>@Localizer["Division"]</th>
                <th>@Localizer["Branch"]</th>
                <th>@Localizer["Time"]</th>
                @if (isSuperAdmin) { <th>@Localizer["School"]</th> }
                <th class="no-print">@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                <tr class="table-row-animated">
                    <td>@(i + 1)</td>
                    <td><span class="badge bg-primary">@Model[i].DayOfWeek</span></td>
                    <td>@Model[i].SubjectName</td>
                    <td>@Model[i].TeacherName</td>
                    <td>@Model[i].GradeName</td>
                    <td>@Model[i].DivisionName</td>
                    <td>@Model[i].BranchName</td>
                    <td>@Model[i].StartTime.ToString(@"hh\:mm") - @Model[i].EndTime.ToString(@"hh\:mm")</td>
                    @if (isSuperAdmin) { <td>@Model[i].SchoolName</td> }
                    <td class="no-print">
                        <div class="d-flex gap-1">
                            <a href="@Url.Action("Edit", new { id = Model[i].Id })" class="btn btn-sm btn-primary" data-bs-toggle="tooltip" title="@Localizer["Edit"]"><i class="fas fa-edit"></i></a>
                            <button class="btn btn-sm btn-danger" onclick="del(@Model[i].Id)" data-bs-toggle="tooltip" title="@Localizer["Delete"]"><i class="fas fa-trash"></i></button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
<style media="print">
    .page-header, .stat-ribbon, .filter-panel, .no-print, nav, .sidebar, footer { display: none !important; }
    .table-card { box-shadow: none !important; border: none !important; }
    table { font-size: 12px; }
    th, td { padding: 4px 8px !important; }
</style>
<script>
    var isSuperAdmin = @(isSuperAdmin ? "true" : "false");
    var dayColIdx = 1, subjectColIdx = 2, branchColIdx = 6;
    var schoolColIdx = isSuperAdmin ? 8 : -1;
    var dt;
    $(function () { dt = $('#dataTable').DataTable({ responsive: true, pageLength: 25, dom: 'rtip' }); $('#searchInput').on('keyup', function () { dt.search(this.value).draw(); }); });
    function applyFilters() {
        dt.search($('#searchInput').val());
        dt.column(dayColIdx).search($('#filterDay').val());
        dt.column(subjectColIdx).search($('#filterSubject').val());
        dt.column(branchColIdx).search($('#filterBranch').val());
        if (isSuperAdmin) { dt.column(schoolColIdx).search($('#filterSchool').val()); }
        dt.draw();
    }
    function resetFilters() {
        $('#searchInput, #filterDay, #filterSubject, #filterBranch').val('');
        if (isSuperAdmin) { $('#filterSchool').val(''); }
        dt.search('').columns().search('').draw();
    }
    function del(id) { confirmDelete('@Url.Action("Delete")', id, function () { location.reload(); }); }
    function printSchedule() { window.print(); }
</script>
}
