{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SchoolMS;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "SchoolMS-Super-Secret-Key-2025-Must-Be-At-Least-32-Characters",
    "Issuer": "SchoolMS",
    "Audience": "SchoolMS-API",
    "ExpiryInMinutes": 60
  },
  "BunnyStream": {
    "ApiKey": "YOUR_BUNNY_STREAM_API_KEY",
    "LibraryId": "YOUR_LIBRARY_ID",
    "CdnHostname": "YOUR_CDN_HOSTNAME.b-cdn.net"
  },
  "CloudflareLive": {
    "AccessToken": "YOUR_CLOUDFLARE_ACCESS_TOKEN",
    "AccountId": "YOUR_CLOUDFLARE_ACCOUNT_ID"
  },
  "OneSignal": {
    "AppId": "YOUR_ONESIGNAL_APP_ID",
    "RestApiKey": "YOUR_ONESIGNAL_REST_API_KEY"
  }
}
