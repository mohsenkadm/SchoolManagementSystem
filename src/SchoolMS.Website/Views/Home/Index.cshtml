                                <option>دهوك</option>
                                <option>ديالى</option>
                                <option>الأنبار</option>
                                <option>واسط</option>
                                <option>ميسان</option>
                                <option>ذي قار</option>
                                <option>المثنى</option>
                                <option>القادسية</option>
                                <option>بابل</option>
                                <option>صلاح الدين</option>
                                <option>كركوك</option>
