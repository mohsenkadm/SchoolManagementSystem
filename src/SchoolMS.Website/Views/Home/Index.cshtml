<!-- ============ PRICING ============ -->
<section class="pricing-section" id="pricing">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <span class="section-badge">الأسعار</span>
            <h2 class="section-title">خطط <span class="gradient-text">تناسب الجميع</span></h2>
            <p class="section-subtitle">اختر الخطة المناسبة لحجم مدرستك واحتياجاتك</p>
        </div>
        <div class="pricing-grid">
            @{
                var plans = ViewBag.Plans as List<SchoolMS.Application.DTOs.SubscriptionPlanDto>;
                var icons = new[] { "🏫", "🏛️", "🌐", "🚀", "⭐" };
                var labels = new[] { "للمدارس الصغيرة", "للمدارس المتوسطة", "للمدارس الكبيرة", "للمؤسسات", "مخصص" };
                var idx = 0;
            }
            @if (plans != null && plans.Count > 0)
            {
                @foreach (var p in plans)
                {
                    var isFeatured = idx == 1;
                    var icon = idx < icons.Length ? icons[idx] : "🏫";
                    var label = idx < labels.Length ? labels[idx] : "خطة مخصصة";
                    <div class="pricing-card @(isFeatured ? "featured" : "")" data-aos="fade-up" data-aos-delay="@(idx * 100)">
                        @if (isFeatured)
                        {
                            <div class="featured-ribbon">الأكثر شعبية</div>
                        }
                        <div class="pricing-header">
                            <div class="pricing-icon">@icon</div>
                            <h4>@p.PlanName</h4>
                            <p>@label</p>
                        </div>
                        <div class="pricing-amount">
                            <span class="currency">$</span>
                            <span class="price">@p.Price</span>
                            <span class="period">/ @p.DurationMonths شهر</span>
                        </div>
                        <ul class="pricing-features">
                            <li><i class="fas fa-check"></i> حتى <strong>@p.MaxUsers مستخدمين</strong></li>
                            <li><i class="fas fa-check"></i> حتى <strong>@p.MaxStudents طالب</strong></li>
                            @if (p.IncludesCourses)
                            {
                                <li><i class="fas fa-check"></i> المنصة الإلكترونية <strong>(@p.StorageLimitGB GB)</strong></li>
                            }
                            else
                            {
                                <li class="disabled"><i class="fas fa-times"></i> المنصة الإلكترونية</li>
                            }
                            @if (p.IncludesLiveStream)
                            {
                                <li><i class="fas fa-check"></i> البث المباشر</li>
                            }
                            else
                            {
                                <li class="disabled"><i class="fas fa-times"></i> البث المباشر</li>
                            }
                            @if (p.IncludesHrModule)
                            {
                                <li><i class="fas fa-check"></i> نظام HR متكامل</li>
                            }
                            else
                            {
                                <li class="disabled"><i class="fas fa-times"></i> نظام HR</li>
                            }
                        </ul>
                        <a href="#register" class="btn-pricing @(isFeatured ? "btn-gradient" : "btn-outline-gradient")">ابدأ مجاناً</a>
                    </div>
                    idx++;
                }
            }
            else
            {
                <div class="pricing-card" data-aos="fade-up">
                    <div class="pricing-header">
                        <div class="pricing-icon">🏫</div>
                        <h4>المبتدئ</h4>
                        <p>للمدارس الصغيرة</p>
                    </div>
                    <div class="pricing-amount">
                        <span class="currency">$</span>
                        <span class="price">49</span>
                        <span class="period">/ شهرياً</span>
                    </div>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check"></i> حتى <strong>3 مستخدمين</strong></li>
                        <li><i class="fas fa-check"></i> حتى <strong>200 طالب</strong></li>
                        <li><i class="fas fa-check"></i> إدارة الطلاب والأساتذة</li>
                    </ul>
                    <a href="#register" class="btn-pricing btn-outline-gradient">ابدأ مجاناً</a>
                </div>
            }
        </div>
    </div>
</section>

