@{
    ViewData["Title"] = "شروط الاستخدام";
}

<nav class="website-navbar scrolled" style="position:fixed">
    <div class="container">
        <a href="/" class="navbar-brand">
            <i class="fas fa-graduation-cap" style="color:#6366f1;font-size:1.6rem;"></i>
            <span class="gradient-text">SchoolMS</span>
        </a>
        <div class="nav-actions">
            <a href="/" class="btn-glass-website">الصفحة الرئيسية</a>
        </div>
    </div>
</nav>

<section style="padding-top:140px;min-height:80vh;">
    <div class="container" style="max-width:800px;">
        <h1 class="section-title" data-aos="fade-up">شروط <span class="gradient-text">الاستخدام</span></h1>
        <div data-aos="fade-up" data-aos-delay="100" style="color:#94a3b8;line-height:2;">
            <h4 style="color:#e2e8f0;margin-top:32px;">1. القبول</h4>
            <p>باستخدامك لنظام SchoolMS فإنك توافق على هذه الشروط والأحكام.</p>
            <h4 style="color:#e2e8f0;margin-top:24px;">2. الخدمة</h4>
            <p>نوفر نظام إدارة مدارس سحابي (SaaS) يشمل إدارة الطلاب، الأساتذة، الرواتب، الأقساط، والمزيد.</p>
            <h4 style="color:#e2e8f0;margin-top:24px;">3. الاشتراك والدفع</h4>
            <p>تتجدد الاشتراكات تلقائياً. يمكنك الإلغاء في أي وقت من لوحة التحكم.</p>
            <h4 style="color:#e2e8f0;margin-top:24px;">4. المسؤولية</h4>
            <p>أنت مسؤول عن دقة البيانات المُدخلة وعن الحفاظ على أمان بيانات الدخول الخاصة بك.</p>
            <h4 style="color:#e2e8f0;margin-top:24px;">5. التعديلات</h4>
            <p>نحتفظ بحق تعديل هذه الشروط في أي وقت مع إشعارك مسبقاً.</p>
        </div>
    </div>
</section>

<footer class="website-footer">
    <div class="container">
        <div class="footer-bottom">
            <p>© 2026 SchoolMS. جميع الحقوق محفوظة.</p>
            <p>صنع بـ ❤️ في العراق</p>
        </div>
    </div>
</footer>
